    <field name="connection_type">sequence</field>
    <field name="source_port">bottom</field>
    <field name="target_port">top</field>
</record>

<record id="pm_ov_c08" model="myschool.process.connection">
    <field name="map_id" ref="pm_sapsync_overview"/>
    <field name="source_step_id" ref="pm_ov_analyse_roles"/>
    <field name="target_step_id" ref="pm_ov_role_betasks"/>
    <field name="connection_type">sequence</field>
    <field name="source_port">bottom</field>
    <field name="target_port">top</field>
</record>

<record id="pm_ov_c09" model="myschool.process.connection">
    <field name="map_id" ref="pm_sapsync_overview"/>
    <field name="source_step_id" ref="pm_ov_role_betasks"/>
    <field name="target_step_id" ref="pm_ov_emp_gw"/>
    <field name="connection_type">sequence</field>
    <field name="source_port">right</field>
    <field name="target_port">bottom</field>
</record>

<!-- Rollen skip naar Medewerkers gateway -->
<record id="pm_ov_c10" model="myschool.process.connection">
    <field name="map_id" ref="pm_sapsync_overview"/>
    <field name="source_step_id" ref="pm_ov_roles_gw"/>
    <field name="target_step_id" ref="pm_ov_emp_gw"/>
    <field name="label">Nee</field>
    <field name="connection_type">sequence</field>
    <field name="source_port">right</field>
    <field name="target_port">left</field>
</record>

<!-- Fase 1b: Medewerkers -->
<record id="pm_ov_c11" model="myschool.process.connection">
    <field name="map_id" ref="pm_sapsync_overview"/>
