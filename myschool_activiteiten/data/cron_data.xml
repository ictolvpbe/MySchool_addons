<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_reminder_aanwezigheid" model="ir.cron">
        <field name="name">Activiteiten: reminder aanwezigheid invullen</field>
        <field name="model_id" ref="model_myschool_activiteiten_record"/>
        <field name="state">code</field>
        <field name="code">model._cron_reminder_aanwezigheid()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_reminder_facturen" model="ir.cron">
        <field name="name">Activiteiten: reminder facturen opstellen</field>
        <field name="model_id" ref="model_myschool_activiteiten_record"/>
        <field name="state">code</field>
        <field name="code">model._cron_reminder_facturen()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
