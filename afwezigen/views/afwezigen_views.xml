<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_afwezigen_list" model="ir.ui.view">
        <field name="name">afwezigen.activiteiten.list</field>
        <field name="model">activiteiten.record</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" default_order="datetime asc">
                <field name="create_uid" string="Naam"/>
                <field name="titel" string="Activiteit"/>
                <field name="datetime" string="Datum en tijdstip"/>
                <field name="name" string="Referentie"/>
            </list>
        </field>
    </record>

    <record id="action_afwezigen_open" model="ir.actions.server">
        <field name="name">Afwezigen</field>
        <field name="model_id" ref="model_myschool_afwezigen"/>
        <field name="state">code</field>
        <field name="code">action = env['myschool.afwezigen'].action_open_dashboard()</field>
    </record>
</odoo>
