<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Asset User Group -->
        <record id="group_asset_user" model="res.groups">
            <field name="name">Asset User</field>
            <field name="implied_ids" eval="[(4, ref('myschool_core.group_myschool_core_user'))]"/>
            <field name="comment">Read access to asset management models.</field>
        </record>

        <!-- Asset Manager Group -->
        <record id="group_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="implied_ids" eval="[(4, ref('myschool_asset.group_asset_user'))]"/>
            <field name="comment">Full access to asset management models.</field>
        </record>

    </data>
</odoo>
