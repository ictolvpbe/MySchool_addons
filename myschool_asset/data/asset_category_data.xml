<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Top-level categories -->
        <record id="category_hardware" model="asset.category">
            <field name="name">Hardware</field>
            <field name="asset_type">hardware</field>
        </record>

        <record id="category_software" model="asset.category">
            <field name="name">Software</field>
            <field name="asset_type">software</field>
        </record>

        <record id="category_network" model="asset.category">
            <field name="name">Network Equipment</field>
            <field name="asset_type">network</field>
        </record>

        <record id="category_av_equipment" model="asset.category">
            <field name="name">AV Equipment</field>
            <field name="asset_type">av_equipment</field>
        </record>

        <record id="category_furniture" model="asset.category">
            <field name="name">Furniture</field>
            <field name="asset_type">furniture</field>
        </record>

        <!-- Hardware subcategories -->
        <record id="category_laptop" model="asset.category">
            <field name="name">Laptop</field>
            <field name="asset_type">hardware</field>
            <field name="parent_id" ref="category_hardware"/>
        </record>

        <record id="category_desktop" model="asset.category">
            <field name="name">Desktop</field>
            <field name="asset_type">hardware</field>
            <field name="parent_id" ref="category_hardware"/>
        </record>

        <record id="category_tablet" model="asset.category">
            <field name="name">Tablet</field>
            <field name="asset_type">hardware</field>
            <field name="parent_id" ref="category_hardware"/>
        </record>

        <record id="category_phone" model="asset.category">
            <field name="name">Phone</field>
            <field name="asset_type">hardware</field>
            <field name="parent_id" ref="category_hardware"/>
        </record>

        <record id="category_server" model="asset.category">
            <field name="name">Server</field>
            <field name="asset_type">hardware</field>
            <field name="parent_id" ref="category_hardware"/>
        </record>

        <!-- Network Equipment subcategories -->
        <record id="category_router" model="asset.category">
            <field name="name">Router</field>
            <field name="asset_type">network</field>
            <field name="parent_id" ref="category_network"/>
        </record>

        <record id="category_switch" model="asset.category">
            <field name="name">Switch</field>
            <field name="asset_type">network</field>
            <field name="parent_id" ref="category_network"/>
        </record>

        <record id="category_access_point" model="asset.category">
            <field name="name">Access Point</field>
            <field name="asset_type">network</field>
            <field name="parent_id" ref="category_network"/>
        </record>

        <!-- AV Equipment subcategories -->
        <record id="category_projector" model="asset.category">
            <field name="name">Projector</field>
            <field name="asset_type">av_equipment</field>
            <field name="parent_id" ref="category_av_equipment"/>
        </record>

        <record id="category_interactive_whiteboard" model="asset.category">
            <field name="name">Interactive Whiteboard</field>
            <field name="asset_type">av_equipment</field>
            <field name="parent_id" ref="category_av_equipment"/>
        </record>

        <record id="category_camera" model="asset.category">
            <field name="name">Camera</field>
            <field name="asset_type">av_equipment</field>
            <field name="parent_id" ref="category_av_equipment"/>
        </record>

    </data>
</odoo>
