<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="asset_category_view_list" model="ir.ui.view">
        <field name="name">asset.category.list</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_type"/>
                <field name="parent_id"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="asset_category_view_form" model="ir.ui.view">
        <field name="name">asset.category.form</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_type"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Description..."/>
                    </group>
                    <notebook>
                        <page string="Subcategories" name="subcategories">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="asset_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="asset_category_view_search" model="ir.ui.view">
        <field name="name">asset.category.search</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_type"/>
                <filter string="Hardware" name="hardware" domain="[('asset_type', '=', 'hardware')]"/>
                <filter string="Software" name="software" domain="[('asset_type', '=', 'software')]"/>
                <filter string="Network" name="network" domain="[('asset_type', '=', 'network')]"/>
                <filter string="AV Equipment" name="av_equipment" domain="[('asset_type', '=', 'av_equipment')]"/>
                <filter string="Furniture" name="furniture" domain="[('asset_type', '=', 'furniture')]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

</odoo>
