<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="asset_license_view_list" model="ir.ui.view">
        <field name="name">asset.license.list</field>
        <field name="model">asset.license</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="license_type"/>
                <field name="vendor"/>
                <field name="total_seats"/>
                <field name="used_seats"/>
                <field name="available_seats"/>
                <field name="expiry_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'expired'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="asset_license_view_form" model="ir.ui.view">
        <field name="name">asset.license.form</field>
        <field name="model">asset.license</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="License Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="License Details">
                            <field name="license_type"/>
                            <field name="license_key"/>
                            <field name="vendor"/>
                            <field name="asset_id"/>
                            <field name="org_id"/>
                        </group>
                        <group string="Seats">
                            <field name="total_seats"/>
                            <field name="used_seats"/>
                            <field name="available_seats"/>
                        </group>
                    </group>
                    <group>
                        <group string="Dates">
                            <field name="purchase_date"/>
                            <field name="expiry_date"/>
                        </group>
                        <group string="Cost">
                            <field name="renewal_cost"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="asset_license_view_search" model="ir.ui.view">
        <field name="name">asset.license.search</field>
        <field name="model">asset.license</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vendor"/>
                <field name="license_key"/>
                <field name="asset_id"/>
                <separator/>
                <filter string="Active" name="active_state" domain="[('state', '=', 'active')]"/>
                <filter string="Expired" name="expired" domain="[('state', '=', 'expired')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Per Seat" name="per_seat" domain="[('license_type', '=', 'per_seat')]"/>
                <filter string="Per Device" name="per_device" domain="[('license_type', '=', 'per_device')]"/>
                <filter string="Site License" name="site" domain="[('license_type', '=', 'site')]"/>
                <filter string="Subscription" name="subscription" domain="[('license_type', '=', 'subscription')]"/>
                <filter string="Open Source" name="open_source" domain="[('license_type', '=', 'open_source')]"/>
<!--                <group string="Group By">-->
<!--                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>-->
<!--                    <filter string="License Type" name="group_type" context="{'group_by': 'license_type'}"/>-->
<!--                    <filter string="Vendor" name="group_vendor" context="{'group_by': 'vendor'}"/>-->
<!--                </group>-->
            </search>
        </field>
    </record>

</odoo>
