<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="group_appfoundry_user" model="res.groups">
        <field name="name">AppFoundry User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Read access to AppFoundry models.</field>
    </record>

    <record id="group_appfoundry_manager" model="res.groups">
        <field name="name">AppFoundry Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_appfoundry_user'))]"/>
        <field name="comment">Full access to all AppFoundry models.</field>
    </record>

    <!-- MySchool admin automatically gets AppFoundry manager access -->
    <record id="myschool_core.group_myschool_core_admin" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_appfoundry_manager'))]"/>
    </record>

    </data>
</odoo>
