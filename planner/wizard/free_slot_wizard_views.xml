<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_planner_free_slot_wizard_form" model="ir.ui.view">
        <field name="name">planner.free.slot.wizard.form</field>
        <field name="model">planner.free.slot.wizard</field>
        <field name="arch" type="xml">
            <form string="Vrij moment zoeken">
                <sheet>
                    <group>
                        <group string="Filter">
                            <field name="planner_id" invisible="1"/>
                            <field name="leerkracht_id" readonly="1"/>
                            <field name="affected_klas_ids" widget="many2many_tags"
                                   readonly="1"
                                   string="Klassen met gemiste lessen"
                                   invisible="not affected_klas_ids"/>
                            <field name="klas_id"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="search_from"/>
                            <field name="search_until"/>
                            <field name="no_klas_warning" invisible="1"/>
                        </group>
                        <group string="Toelichting">
                            <div colspan="2" class="text-muted">
                                Zoekt momenten in het lessenrooster waarop
                                <strong>noch de leerkracht, noch de gekozen klas</strong>
                                een les heeft staan. Klik op een suggestie om die
                                datum + lesuur toe te passen op het inhaalplan.
                            </div>
                        </group>
                    </group>
                    <div class="alert alert-warning"
                         invisible="not no_klas_warning">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        <strong>Selecteer eerst een klas.</strong>
                        Zonder klas zou de zoeker elke uur waarop de leerkracht
                        niets staat als "vrij" tonen — niet bruikbaar voor een
                        inhaalmoment voor een specifieke klas.
                    </div>
                    <field name="suggestion_ids" readonly="1"
                           invisible="not has_searched">
                        <list>
                            <field name="date"/>
                            <field name="day_name" string="Dag"/>
                            <field name="lesuur"/>
                            <field name="klas_id"/>
                            <button name="action_apply_to_planner"
                                    string="Toepassen"
                                    type="object"
                                    class="btn-primary"
                                    icon="fa-check"/>
                        </list>
                    </field>
                    <field name="has_searched" invisible="1"/>
                    <div invisible="not has_searched or suggestion_ids" class="alert alert-warning mt-3">
                        <i class="fa fa-info-circle me-1"/>
                        Geen vrije momenten gevonden in dit tijdsvenster. Verbreed
                        de zoekperiode of controleer het lessenrooster.
                    </div>
                </sheet>
                <footer>
                    <button name="action_search" type="object"
                            string="Zoek vrije momenten"
                            class="btn-primary"/>
                    <button string="Sluiten" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
