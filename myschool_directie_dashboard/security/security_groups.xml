<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <record id="module_category_directie_dashboard" model="ir.module.category">
        <field name="name">Directie Dashboard</field>
        <field name="sequence">60</field>
    </record>

    <record id="privilege_directie_dashboard" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_directie_dashboard"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_directie_dashboard" model="res.groups">
        <field name="name">Directie Dashboard</field>
        <field name="privilege_id" ref="privilege_directie_dashboard"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
