<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="ai_asset_checkout_view_list" model="ir.ui.view">
        <field name="name">a_i.asset.checkout.list</field>
        <field name="model">a_i.asset.checkout</field>
        <field name="arch" type="xml">
            <list>
                <field name="asset_id"/>
                <field name="person_id"/>
                <field name="checkout_date"/>
                <field name="expected_return_date"/>
                <field name="actual_return_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'checked_out'"
                       decoration-success="state == 'returned'"
                       decoration-danger="state == 'overdue'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ai_asset_checkout_view_form" model="ir.ui.view">
        <field name="name">a_i.asset.checkout.form</field>
        <field name="model">a_i.asset.checkout</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_return" string="Return"
                            type="object" class="oe_highlight"
                            invisible="state != 'checked_out'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Checkout Details">
                            <field name="asset_id"/>
                            <field name="person_id"/>
                        </group>
                        <group string="Dates">
                            <field name="checkout_date"/>
                            <field name="expected_return_date"/>
                            <field name="actual_return_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ai_asset_checkout_view_search" model="ir.ui.view">
        <field name="name">a_i.asset.checkout.search</field>
        <field name="model">a_i.asset.checkout</field>
        <field name="arch" type="xml">
            <search>
                <field name="asset_id"/>
                <field name="person_id"/>
                <separator/>
                <filter string="Checked Out" name="checked_out" domain="[('state', '=', 'checked_out')]"/>
                <filter string="Returned" name="returned" domain="[('state', '=', 'returned')]"/>
                <filter string="Overdue" name="overdue" domain="[('state', '=', 'overdue')]"/>
            </search>
        </field>
    </record>

</odoo>
