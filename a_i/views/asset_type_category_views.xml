<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="ai_asset_type_category_view_list" model="ir.ui.view">
        <field name="name">a_i.asset.type.category.list</field>
        <field name="model">a_i.asset.type.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="complete_name"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ai_asset_type_category_view_form" model="ir.ui.view">
        <field name="name">a_i.asset.type.category.form</field>
        <field name="model">a_i.asset.type.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Description..."/>
                    </group>
                    <notebook>
                        <page string="Subcategories" name="subcategories">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="complete_name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Asset Types" name="asset_types">
                            <field name="asset_type_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="is_room"/>
                                    <field name="active" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ai_asset_type_category_view_search" model="ir.ui.view">
        <field name="name">a_i.asset.type.category.search</field>
        <field name="model">a_i.asset.type.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="complete_name"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

</odoo>
