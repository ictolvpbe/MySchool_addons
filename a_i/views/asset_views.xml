<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="ai_asset_view_list" model="ir.ui.view">
        <field name="name">a_i.asset.list</field>
        <field name="model">a_i.asset</field>
        <field name="arch" type="xml">
            <list>
                <field name="asset_tag"/>
                <field name="name"/>
                <field name="asset_type_id"/>
                <field name="asset_type_category_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'procurement'"
                       decoration-success="state in ('received', 'deployed')"
                       decoration-danger="state in ('retired', 'disposed')"
                       decoration-muted="state == 'maintenance'"/>
                <field name="user_id"/>
                <field name="owner_id"/>
                <field name="location_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ai_asset_view_form" model="ir.ui.view">
        <field name="name">a_i.asset.form</field>
        <field name="model">a_i.asset</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_receive" string="Receive"
                            type="object" class="oe_highlight"
                            invisible="state != 'procurement'"/>
                    <button name="action_deploy" string="Deploy"
                            type="object" class="oe_highlight"
                            invisible="state not in ('received', 'maintenance')"/>
                    <button name="action_maintenance" string="Maintenance"
                            type="object"
                            invisible="state not in ('received', 'deployed')"/>
                    <button name="action_retire" string="Retire"
                            type="object"
                            invisible="state in ('retired', 'disposed', 'draft')"/>
                    <button name="action_dispose" string="Dispose"
                            type="object"
                            invisible="state != 'retired'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"
                            confirm="Are you sure you want to reset this asset to draft?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,procurement,received,deployed,maintenance,retired,disposed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Asset Name"/>
                        </h1>
                        <div class="o_row">
                            <field name="asset_tag" placeholder="Asset Tag"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="asset_type_id"/>
                            <field name="asset_type_category_id"/>
                        </group>
                        <group>
                            <field name="owner_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="General Information" name="general">
                            <group>
                                <group string="Product Details">
                                    <field name="serial_number"/>
                                    <field name="model_name"/>
                                    <field name="manufacturer"/>
                                    <field name="barcode"/>
                                </group>
                                <group string="Supplier">
                                    <field name="supplier"/>
                                    <field name="supplier_contact"/>
                                </group>
                            </group>
                            <group>
                                <field name="description" placeholder="Description..."/>
                            </group>
                        </page>
                        <page string="Location &amp; Assignment" name="location">
                            <group>
                                <group string="Location">
                                    <field name="location_id"/>
                                </group>
                                <group string="Assignment">
                                    <field name="user_id"/>
                                    <field name="parent_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Financial" name="financial">
                            <group>
                                <group string="Purchase">
                                    <field name="purchase_date"/>
                                    <field name="purchase_price"/>
                                    <field name="warranty_expiry"/>
                                </group>
                                <group string="Depreciation">
                                    <field name="depreciation_method"/>
                                    <field name="useful_life_years"/>
                                    <field name="residual_value"/>
                                    <field name="current_value"/>
                                </group>
                            </group>
                        </page>
                        <page string="Child Assets" name="children">
                            <field name="child_ids">
                                <list>
                                    <field name="asset_tag"/>
                                    <field name="name"/>
                                    <field name="asset_type_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Licenses" name="licenses">
                            <field name="license_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="license_type"/>
                                    <field name="vendor"/>
                                    <field name="license_key"/>
                                    <field name="expiry_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Checkouts" name="checkouts">
                            <field name="checkout_ids">
                                <list>
                                    <field name="person_id"/>
                                    <field name="checkout_date"/>
                                    <field name="expected_return_date"/>
                                    <field name="actual_return_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ai_asset_view_search" model="ir.ui.view">
        <field name="name">a_i.asset.search</field>
        <field name="model">a_i.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="serial_number"/>
                <field name="asset_type_id"/>
                <field name="asset_type_category_id"/>
                <field name="owner_id"/>
                <field name="user_id"/>
                <field name="location_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Procurement" name="procurement" domain="[('state', '=', 'procurement')]"/>
                <filter string="Received" name="received" domain="[('state', '=', 'received')]"/>
                <filter string="Deployed" name="deployed" domain="[('state', '=', 'deployed')]"/>
                <filter string="Maintenance" name="maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Retired" name="retired" domain="[('state', '=', 'retired')]"/>
                <filter string="Disposed" name="disposed" domain="[('state', '=', 'disposed')]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Asset Type" name="group_type" context="{'group_by': 'asset_type_id'}"/>
                <filter string="Category" name="group_category" context="{'group_by': 'asset_type_category_id'}"/>
                <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
                <filter string="Location" name="group_location" context="{'group_by': 'location_id'}"/>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="ai_asset_view_kanban" model="ir.ui.view">
        <field name="name">a_i.asset.kanban</field>
        <field name="model">a_i.asset</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="asset_type_id"/>
                <field name="state"/>
                <field name="user_id"/>
                <field name="owner_id"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="state" widget="badge"
                                       decoration-info="state == 'draft'"
                                       decoration-success="state == 'deployed'"
                                       decoration-warning="state == 'maintenance'"
                                       decoration-danger="state == 'retired'"/>
                            </div>
                            <div class="text-muted"><field name="asset_tag"/></div>
                            <div><field name="asset_type_id"/></div>
                            <div class="o_kanban_record_bottom mt-1">
                                <div class="oe_kanban_bottom_left">
                                    <field name="owner_id"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
