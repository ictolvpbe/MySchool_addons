<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="ai_access_policy_view_list" model="ir.ui.view">
        <field name="name">a_i.access.policy.list</field>
        <field name="model">a_i.access.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="group_id"/>
                <field name="org_id"/>
                <field name="asset_type_category_id"/>
                <field name="asset_type_id"/>
                <field name="access_level" widget="badge"
                       decoration-info="access_level == 'read'"
                       decoration-success="access_level == 'write'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="ai_access_policy_view_form" model="ir.ui.view">
        <field name="name">a_i.access.policy.form</field>
        <field name="model">a_i.access.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Access">
                            <field name="group_id"/>
                            <field name="access_level"/>
                        </group>
                        <group string="Scope">
                            <field name="org_id"/>
                            <field name="asset_type_category_id"/>
                            <field name="asset_type_id"
                                   domain="[('category_id', 'child_of', asset_type_category_id)]"
                                   invisible="not asset_type_category_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="ai_access_policy_view_search" model="ir.ui.view">
        <field name="name">a_i.access.policy.search</field>
        <field name="model">a_i.access.policy</field>
        <field name="arch" type="xml">
            <search>
                <field name="group_id"/>
                <field name="org_id"/>
                <field name="asset_type_category_id"/>
                <field name="asset_type_id"/>
                <separator/>
                <filter string="Read" name="read" domain="[('access_level', '=', 'read')]"/>
                <filter string="Read &amp; Write" name="write" domain="[('access_level', '=', 'write')]"/>
            </search>
        </field>
    </record>

</odoo>
