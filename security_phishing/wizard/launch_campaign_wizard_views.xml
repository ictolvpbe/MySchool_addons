<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- Launch Wizard: Form View -->
    <record id="view_phishing_launch_wizard_form" model="ir.ui.view">
        <field name="name">phishing.launch.wizard.form</field>
        <field name="model">phishing.launch.wizard</field>
        <field name="arch" type="xml">
            <form string="Campagne Starten">
                <group>
                    <field name="campaign_id" readonly="1"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="send_immediately"/>
                </group>
                <footer>
                    <button name="action_launch"
                            string="Starten"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuleren" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    </data>
</odoo>
