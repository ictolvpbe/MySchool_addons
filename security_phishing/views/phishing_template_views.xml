<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- Template: List View -->
    <record id="view_phishing_template_list" model="ir.ui.view">
        <field name="name">phishing.template.list</field>
        <field name="model">phishing.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="subject"/>
                <field name="sender_name"/>
                <field name="sender_address"/>
                <field name="campaign_count" string="Campagnes"/>
            </list>
        </field>
    </record>

    <!-- Template: Form View -->
    <record id="view_phishing_template_form" model="ir.ui.view">
        <field name="name">phishing.template.form</field>
        <field name="model">phishing.template</field>
        <field name="arch" type="xml">
            <form string="Phishing Sjabloon">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_campaigns"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-bullhorn">
                            <field name="campaign_count" widget="statinfo" string="Campagnes"/>
                        </button>
                    </div>
                    <group>
                        <group string="Algemeen">
                            <field name="name"/>
                            <field name="subject"/>
                        </group>
                        <group string="Afzender">
                            <field name="sender_name"/>
                            <field name="sender_address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="E-mail Inhoud" name="body">
                            <field name="body_html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Template: Search View -->
    <record id="view_phishing_template_search" model="ir.ui.view">
        <field name="name">phishing.template.search</field>
        <field name="model">phishing.template</field>
        <field name="arch" type="xml">
            <search string="Phishing Sjablonen">
                <field name="name" string="Naam"/>
                <field name="subject" string="Onderwerp"/>
                <field name="sender_name" string="Afzender"/>
            </search>
        </field>
    </record>

    <!-- Template: Action -->
    <record id="action_phishing_template" model="ir.actions.act_window">
        <field name="name">Sjablonen</field>
        <field name="res_model">phishing.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_phishing_template_search"/>
    </record>

    </data>
</odoo>
