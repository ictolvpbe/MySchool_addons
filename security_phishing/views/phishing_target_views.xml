<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- Target: List View -->
    <record id="view_phishing_target_list" model="ir.ui.view">
        <field name="name">phishing.target.list</field>
        <field name="model">phishing.target</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'credentials_entered'"
                  decoration-warning="state == 'clicked'"
                  decoration-info="state == 'sent'"
                  decoration-muted="state == 'pending'">
                <field name="campaign_id"/>
                <field name="partner_id"/>
                <field name="user_id" optional="show"/>
                <field name="email"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-warning="state == 'sent'"
                       decoration-danger="state in ('clicked', 'credentials_entered')"/>
                <field name="reported"/>
                <field name="date_sent"/>
                <field name="date_clicked"/>
                <field name="date_reported"/>
            </list>
        </field>
    </record>

    <!-- Target: Form View -->
    <record id="view_phishing_target_form" model="ir.ui.view">
        <field name="name">phishing.target.form</field>
        <field name="model">phishing.target</field>
        <field name="arch" type="xml">
            <form string="Phishing Doelwit">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,sent,clicked,credentials_entered"/>
                </header>
                <sheet>
                    <group>
                        <group string="Doelwit">
                            <field name="campaign_id"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="email"/>
                            <field name="token"/>
                        </group>
                        <group string="Tracking">
                            <field name="state"/>
                            <field name="reported"/>
                            <field name="date_sent"/>
                            <field name="date_clicked"/>
                            <field name="date_reported"/>
                            <field name="date_credentials"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Target: Search View -->
    <record id="view_phishing_target_search" model="ir.ui.view">
        <field name="name">phishing.target.search</field>
        <field name="model">phishing.target</field>
        <field name="arch" type="xml">
            <search string="Phishing Doelwitten">
                <field name="partner_id" string="Contactpersoon"/>
                <field name="campaign_id" string="Campagne"/>
                <separator/>
                <filter name="pending" string="Wachtend" domain="[('state', '=', 'pending')]"/>
                <filter name="sent" string="Verstuurd" domain="[('state', '=', 'sent')]"/>
                <filter name="clicked" string="Geklikt" domain="[('state', '=', 'clicked')]"/>
                <filter name="credentials" string="Inloggegevens"
                        domain="[('state', '=', 'credentials_entered')]"/>
                <separator/>
                <filter name="reported" string="Gerapporteerd" domain="[('reported', '=', True)]"/>
                <separator/>
                <filter name="group_campaign" string="Campagne"
                        context="{'group_by': 'campaign_id'}"/>
                <filter name="group_state" string="Status"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Target: Action -->
    <record id="action_phishing_target" model="ir.actions.act_window">
        <field name="name">Doelwitten</field>
        <field name="res_model">phishing.target</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_phishing_target_search"/>
    </record>

    </data>
</odoo>
