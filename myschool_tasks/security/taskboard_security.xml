<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Taskboard User Group -->
        <record id="group_taskboard_user" model="res.groups">
            <field name="name">Takenbord Gebruiker</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Taskboard Manager Group -->
        <record id="group_taskboard_manager" model="res.groups">
            <field name="name">Takenbord Beheerder</field>
            <field name="implied_ids" eval="[(4, ref('group_taskboard_user'))]"/>
        </record>

        <!-- Record rules: users see their own tasks + group tasks -->
        <record id="rule_process_task_user" model="ir.rule">
            <field name="name">Process Task: eigen + groepstaken</field>
            <field name="model_id" ref="myschool_core.model_myschool_process_task"/>
            <field name="domain_force">[
                '|',
                ('assigned_user_id', '=', user.id),
                '|',
                ('assigned_group_id', 'in', user.all_group_ids.ids),
                ('assigned_user_id', '=', False)
            ]</field>
            <field name="groups" eval="[(4, ref('group_taskboard_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers can see all tasks -->
        <record id="rule_process_task_manager" model="ir.rule">
            <field name="name">Process Task: alle taken (beheerder)</field>
            <field name="model_id" ref="myschool_core.model_myschool_process_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_taskboard_manager'))]"/>
        </record>

        <!-- Instance rules: users see instances they started or have tasks in -->
        <record id="rule_process_instance_user" model="ir.rule">
            <field name="name">Process Instance: eigen processen</field>
            <field name="model_id" ref="myschool_core.model_myschool_process_instance"/>
            <field name="domain_force">[
                '|',
                ('started_by_id', '=', user.id),
                ('task_ids.assigned_user_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_taskboard_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Managers can see all instances -->
        <record id="rule_process_instance_manager" model="ir.rule">
            <field name="name">Process Instance: alle processen (beheerder)</field>
            <field name="model_id" ref="myschool_core.model_myschool_process_instance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_taskboard_manager'))]"/>
        </record>

    </data>
</odoo>
