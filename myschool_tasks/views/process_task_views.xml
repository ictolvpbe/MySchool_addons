<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Process Task: List View -->
    <record id="view_process_task_list" model="ir.ui.view">
        <field name="name">myschool.process.task.list</field>
        <field name="model">myschool.process.task</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'"
                  decoration-danger="is_overdue == True">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="instance_id"/>
                <field name="process_map_id"/>
                <field name="assigned_user_id" widget="many2one_avatar_user"/>
                <field name="assigned_group_id"/>
                <field name="deadline"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'todo'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state in ('cancelled', 'blocked')"/>
                <field name="is_overdue" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Process Task: Form View -->
    <record id="view_process_task_form" model="ir.ui.view">
        <field name="name">myschool.process.task.form</field>
        <field name="model">myschool.process.task</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Starten"
                            class="oe_highlight"
                            invisible="state != 'todo'"/>
                    <button name="action_done" type="object" string="Voltooien"
                            class="oe_highlight"
                            invisible="state not in ('todo', 'in_progress')"/>
                    <button name="action_assign_to_me" type="object"
                            string="Aan mij toewijzen"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_block" type="object" string="Blokkeren"
                            invisible="state not in ('todo', 'in_progress')"/>
                    <button name="action_reset" type="object" string="Terugzetten"
                            invisible="state not in ('in_progress', 'blocked', 'done')"/>
                    <button name="action_cancel" type="object" string="Annuleren"
                            invisible="state in ('done', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="todo,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Taaknaam..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="instance_id"/>
                            <field name="process_map_id"/>
                            <field name="step_id"/>
                        </group>
                        <group>
                            <field name="assigned_user_id" widget="many2one_avatar_user"/>
                            <field name="assigned_group_id"/>
                            <field name="deadline"/>
                            <field name="priority" widget="priority"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_done"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Beschrijving" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Notities" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Process Task: Search View -->
    <record id="view_process_task_search" model="ir.ui.view">
        <field name="name">myschool.process.task.search</field>
        <field name="model">myschool.process.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="instance_id"/>
                <field name="process_map_id"/>
                <field name="assigned_user_id"/>
                <filter name="filter_my_tasks" string="Mijn taken"
                        domain="[('assigned_user_id', '=', uid)]"/>
                <filter name="filter_unassigned" string="Niet toegewezen"
                        domain="[('assigned_user_id', '=', False)]"/>
                <separator/>
                <filter name="filter_todo" string="Te doen" domain="[('state', '=', 'todo')]"/>
                <filter name="filter_in_progress" string="Bezig" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Voltooid" domain="[('state', '=', 'done')]"/>
                <filter name="filter_blocked" string="Geblokkeerd" domain="[('state', '=', 'blocked')]"/>
                <filter name="filter_overdue" string="Verlopen"
                        domain="[('deadline', '&lt;', (context_today()).strftime('%Y-%m-%d')), ('state', 'not in', ['done', 'cancelled'])]"/>
                <separator/>
                <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                <filter name="group_process" string="Proces" context="{'group_by': 'process_map_id'}"/>
                <filter name="group_user" string="Toegewezen aan" context="{'group_by': 'assigned_user_id'}"/>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_process_task_all" model="ir.actions.act_window">
        <field name="name">Alle taken</field>
        <field name="res_model">myschool.process.task</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_process_task_search"/>
    </record>

    <record id="action_process_task_my" model="ir.actions.act_window">
        <field name="name">Mijn taken</field>
        <field name="res_model">myschool.process.task</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_process_task_search"/>
        <field name="context">{'search_default_filter_my_tasks': 1}</field>
    </record>

</odoo>
