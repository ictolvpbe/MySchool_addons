<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard landing page -->
    <record id="view_myschool_dashboard_form" model="ir.ui.view">
        <field name="name">myschool.dashboard.form</field>
        <field name="model">myschool.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard" create="false" delete="false" class="o_myschool_dashboard">
                <!-- Hidden access fields -->
                <field name="has_professionalisering_access" invisible="1"/>
                <field name="has_activiteiten_access" invisible="1"/>
                <field name="has_drukwerk_access" invisible="1"/>
                <field name="is_prof_manager" invisible="1"/>
                <field name="is_act_manager" invisible="1"/>
                <field name="is_drukwerk_manager" invisible="1"/>
                <field name="is_drukwerk_drukwerk" invisible="1"/>
                <field name="is_drukwerk_boekhouding" invisible="1"/>
                <field name="is_act_vervangingen" invisible="1"/>
                <field name="is_act_aankoop" invisible="1"/>
                <field name="is_act_boekhouding" invisible="1"/>
                <field name="is_act_directie" invisible="1"/>
                <field name="is_only_teacher" invisible="1"/>
                <sheet>
                    <div class="ms-page-title">Mijn Aanvragen</div>

                    <!-- ===== MAIN GRID ===== -->
                    <div class="ms-grid">
                        <!-- LEFT COLUMN: Aanvragen -->
                        <div>
                            <!-- Quick Actions -->
                            <div class="ms-card">
                                <div class="ms-card-header">Aanvragen</div>
                                <div class="ms-card-body">
                                    <div class="ms-quick-actions">
                                        <button name="action_new_professionalisering" type="object"
                                                class="ms-qa-btn"
                                                invisible="not has_professionalisering_access">
                                            <div class="ms-qa-icon c2"><i class="fa fa-plus"/></div>
                                            <div class="ms-qa-text">
                                                <strong>Nieuwe professionalisering</strong>
                                                <span>Aanvraag indienen</span>
                                            </div>
                                        </button>
                                        <button name="action_open_professionalisering" type="object"
                                                context="{'search_default_my_requests': 1}"
                                                class="ms-qa-btn"
                                                invisible="not has_professionalisering_access">
                                            <div class="ms-qa-icon c4"><i class="fa fa-list"/></div>
                                            <div class="ms-qa-text">
                                                <strong>Mijn professionalisering</strong>
                                                <span>Overzicht bekijken</span>
                                            </div>
                                        </button>
                                        <button name="action_new_activiteit" type="object"
                                                class="ms-qa-btn"
                                                invisible="not has_activiteiten_access">
                                            <div class="ms-qa-icon c1"><i class="fa fa-plus"/></div>
                                            <div class="ms-qa-text">
                                                <strong>Nieuwe activiteit</strong>
                                                <span>Aanvraag indienen</span>
                                            </div>
                                        </button>
                                        <button name="action_open_activiteiten_list" type="object"
                                                context="{'search_default_my_requests': 1}"
                                                class="ms-qa-btn"
                                                invisible="not has_activiteiten_access">
                                            <div class="ms-qa-icon c3"><i class="fa fa-list"/></div>
                                            <div class="ms-qa-text">
                                                <strong>Mijn activiteiten</strong>
                                                <span>Overzicht bekijken</span>
                                            </div>
                                        </button>
                                        <button name="action_new_drukwerk" type="object"
                                                class="ms-qa-btn"
                                                invisible="not has_drukwerk_access">
                                            <div class="ms-qa-icon c1"><i class="fa fa-plus"/></div>
                                            <div class="ms-qa-text">
                                                <strong>Nieuw drukwerk</strong>
                                                <span>Aanvraag indienen</span>
                                            </div>
                                        </button>
                                        <button name="action_open_drukwerk_list" type="object"
                                                context="{'search_default_my_requests': 1}"
                                                class="ms-qa-btn"
                                                invisible="not has_drukwerk_access">
                                            <div class="ms-qa-icon c3"><i class="fa fa-list"/></div>
                                            <div class="ms-qa-text">
                                                <strong>Mijn drukwerk</strong>
                                                <span>Overzicht bekijken</span>
                                            </div>
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- RIGHT COLUMN: Aanvragen cards -->
                        <div>
                            <!-- Professionalisering -->
                            <div class="ms-card" invisible="not has_professionalisering_access">
                                <div class="ms-card-header">
                                    <span><i class="fa fa-graduation-cap me-1"/> Professionalisering</span>
                                    <button name="action_open_professionalisering" type="object"
                                            class="ms-link">Bekijk alles &#8594;</button>
                                </div>
                                <div class="ms-card-body">
                                    <field name="is_prof_directie" invisible="1"/>
                                    <field name="is_prof_boekhouding" invisible="1"/>
                                    <field name="is_prof_vervangingen" invisible="1"/>
                                    <field name="is_prof_only_directie" invisible="1"/>
                                    <field name="is_prof_only_boekhouding" invisible="1"/>
                                    <field name="is_prof_only_vervangingen" invisible="1"/>
                                    <field name="is_prof_only_medewerker" invisible="1"/>
                                    <field name="prof_action_count" invisible="1"/>
                                    <button type="object" name="action_open_professionalisering"
                                            class="ms-action-banner"
                                            invisible="prof_action_count == 0">
                                        <i class="fa fa-bolt"/>
                                        <field name="prof_action_label" class="d-inline"/>
                                    </button>
                                    <div class="d-flex gap-2 flex-wrap mb-3">
                                        <button type="object" name="action_open_professionalisering"
                                                context="{'search_default_state_selection_of_form': 1}"
                                                class="ms-badge-status ms-badge-info ms-badge-btn"
                                                invisible="is_prof_only_boekhouding or is_prof_only_directie or is_prof_only_vervangingen">
                                            <field name="prof_draft" class="d-inline"/> Concepten
                                        </button>
                                        <button type="object" name="action_open_professionalisering"
                                                context="{'search_default_state_submitted': 1}"
                                                class="ms-badge-status ms-badge-warning ms-badge-btn"
                                                invisible="is_prof_only_boekhouding or is_prof_only_vervangingen">
                                            <field name="prof_submitted" class="d-inline"/> Goed te keuren
                                        </button>
                                        <button type="object" name="action_open_professionalisering"
                                                context="{'search_default_state_bevestiging': 1}"
                                                class="ms-badge-status ms-badge-success ms-badge-btn"
                                                invisible="is_prof_only_directie">
                                            <field name="prof_approved" class="d-inline"/> Goedgekeurd
                                        </button>
                                        <button type="object" name="action_open_professionalisering"
                                                context="{'search_default_state_bewijs': 1}"
                                                class="ms-badge-status ms-badge-warning ms-badge-btn"
                                                invisible="is_prof_only_directie or is_prof_only_vervangingen">
                                            <field name="prof_bewijs_pending" class="d-inline"/> Bewijs in te dienen
                                        </button>
                                        <button type="object" name="action_open_professionalisering"
                                                context="{'search_default_state_weigering': 1}"
                                                class="ms-badge-status ms-badge-error ms-badge-btn"
                                                invisible="is_prof_only_directie or is_prof_only_vervangingen">
                                            <field name="prof_rejected" class="d-inline"/> Afgekeurd
                                        </button>
                                        <button type="object" name="action_open_professionalisering"
                                                context="{'search_default_state_done': 1}"
                                                class="ms-badge-status ms-badge-success ms-badge-btn"
                                                invisible="is_prof_only_directie or is_prof_only_medewerker or is_prof_only_vervangingen">
                                            <field name="prof_done" class="d-inline"/> Afgerond
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Activiteiten -->
                            <div class="ms-card" invisible="not has_activiteiten_access">
                                <div class="ms-card-header">
                                    <span><i class="fa fa-calendar me-1"/> Activiteiten</span>
                                    <button name="action_open_activiteiten_list" type="object"
                                            class="ms-link">Bekijk alles &#8594;</button>
                                </div>
                                <div class="ms-card-body">
                                    <field name="is_only_aankoop" invisible="1"/>
                                    <field name="is_only_boekhouding" invisible="1"/>
                                    <field name="is_only_directie" invisible="1"/>
                                    <field name="is_only_medewerker" invisible="1"/>
                                    <field name="is_only_vervangingen" invisible="1"/>
                                    <field name="act_action_count" invisible="1"/>
                                    <button type="object" name="action_open_activiteiten_list"
                                            class="ms-action-banner"
                                            invisible="act_action_count == 0">
                                        <i class="fa fa-bolt"/>
                                        <field name="act_action_label" class="d-inline"/>
                                    </button>
                                    <div class="d-flex gap-2 flex-wrap mb-3">
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_state_draft': 1}"
                                                class="ms-badge-status ms-badge-info ms-badge-btn"
                                                invisible="is_only_aankoop or is_only_boekhouding or is_only_directie or is_only_vervangingen">
                                            <field name="act_form_invullen" class="d-inline"/> Concepten
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_bus_check': 1}"
                                                class="ms-badge-status ms-badge-warning ms-badge-btn"
                                                invisible="not is_act_aankoop or is_only_boekhouding or is_only_directie or is_only_medewerker or is_only_vervangingen">
                                            <field name="act_bus_check" class="d-inline"/> Bus controle
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_state_bus_refused': 1}"
                                                class="ms-badge-status ms-badge-error ms-badge-btn"
                                                invisible="is_only_aankoop or is_only_boekhouding or is_only_directie or is_only_medewerker or is_only_vervangingen">
                                            <field name="act_bus_refused" class="d-inline"/> Bus geweigerd
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_to_approve': 1}"
                                                class="ms-badge-status ms-badge-warning ms-badge-btn"
                                                invisible="not is_act_directie or is_only_boekhouding or is_only_medewerker or is_only_vervangingen">
                                            <field name="act_pending_approval" class="d-inline"/> Wacht op goedkeuring
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_state_approved': 1}"
                                                class="ms-badge-status ms-badge-success ms-badge-btn"
                                                invisible="is_only_aankoop or is_only_directie or is_only_vervangingen">
                                            <field name="act_approved" class="d-inline"/> Goedgekeurd
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_state_rejected': 1}"
                                                class="ms-badge-status ms-badge-error ms-badge-btn"
                                                invisible="is_only_aankoop or is_only_directie or is_only_vervangingen">
                                            <field name="act_rejected" class="d-inline"/> Afgekeurd
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_s_code_pending': 1}"
                                                class="ms-badge-status ms-badge-info ms-badge-btn"
                                                invisible="not is_act_boekhouding or is_only_directie or is_only_medewerker or is_only_vervangingen">
                                            <field name="act_s_code" class="d-inline"/> S-Code
                                        </button>
                                        <button type="object" name="action_open_activiteiten_list"
                                                context="{'search_default_state_done': 1}"
                                                class="ms-badge-status ms-badge-success ms-badge-btn"
                                                invisible="not is_act_manager or is_only_aankoop or is_only_boekhouding or is_only_directie or is_only_medewerker or is_only_vervangingen">
                                            <field name="act_done" class="d-inline"/> Afgerond
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <!-- Drukwerk -->
                            <div class="ms-card" invisible="not has_drukwerk_access">
                                <div class="ms-card-header">
                                    <span><i class="fa fa-print me-1"/> Drukwerk</span>
                                    <button name="action_open_drukwerk_list" type="object"
                                            class="ms-link">Bekijk alles &#8594;</button>
                                </div>
                                <div class="ms-card-body">
                                    <field name="druk_action_count" invisible="1"/>
                                    <button type="object" name="action_open_drukwerk_list"
                                            class="ms-action-banner"
                                            invisible="druk_action_count == 0">
                                        <i class="fa fa-bolt"/>
                                        <field name="druk_action_label" class="d-inline"/>
                                    </button>
                                    <div class="d-flex gap-2 flex-wrap mb-3">
                                        <button type="object" name="action_open_drukwerk_list"
                                                context="{'search_default_state_form_invullen': 1}"
                                                class="ms-badge-status ms-badge-info ms-badge-btn">
                                            <field name="druk_form_invullen" class="d-inline"/> Concepten
                                        </button>
                                        <button type="object" name="action_open_drukwerk_list"
                                                context="{'search_default_to_print': 1}"
                                                class="ms-badge-status ms-badge-warning ms-badge-btn">
                                            <field name="druk_afdrukken" class="d-inline"/> Af te drukken
                                        </button>
                                        <button type="object" name="action_open_drukwerk_list"
                                                context="{'search_default_done': 1}"
                                                class="ms-badge-status ms-badge-success ms-badge-btn">
                                            <field name="druk_done" class="d-inline"/> Afgedrukt
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Keep old act_window action (cannot change model of existing xmlid) -->
    <record id="action_myschool_dashboard" model="ir.actions.act_window">
        <field name="name">Aanvragen</field>
        <field name="res_model">myschool.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" eval="ref('dashboard_singleton')"/>
        <field name="target">current</field>
    </record>

    <!-- Dashboard client action (landing page) — no breadcrumb/pager -->
    <record id="action_myschool_dashboard_client" model="ir.actions.client">
        <field name="name">Aanvragen</field>
        <field name="tag">myschool_dashboard_action</field>
    </record>
</odoo>
