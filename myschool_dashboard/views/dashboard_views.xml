<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard landing page (simplified overview) -->
    <record id="view_myschool_dashboard_form" model="ir.ui.view">
        <field name="name">myschool.dashboard.form</field>
        <field name="model">myschool.dashboard</field>
        <field name="arch" type="xml">
            <form string="Aanvragen" create="false" delete="false" class="o_myschool_dashboard">
                <field name="has_activiteit_access" invisible="1"/>
                <field name="has_professionalisering_access" invisible="1"/>
                <field name="has_activiteiten_access" invisible="1"/>
                <field name="is_activiteit_manager" invisible="1"/>
                <field name="is_prof_manager" invisible="1"/>
                <field name="is_act_manager" invisible="1"/>
                <field name="is_act_vervangingen" invisible="1"/>
                <field name="is_act_aankoop" invisible="1"/>
                <field name="is_act_boekhouding" invisible="1"/>
                <field name="is_act_directie" invisible="1"/>
                <div class="o_form_view">
                    <!-- Quick-access cards -->
                    <div class="d-flex gap-3 mb-4 mx-2 mt-3 flex-wrap">
                        <button name="action_open_activiteiten" type="object"
                                class="o_dashboard_card btn btn-outline-primary p-3 flex-fill text-start"
                                invisible="not has_activiteit_access">
                            <div class="fw-bold fs-5 mb-2">Buitenschoolse Activiteiten</div>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge text-bg-info">
                                    <field name="activiteit_draft" class="d-inline"/> Concept
                                </span>
                                <span class="badge text-bg-warning">
                                    <field name="activiteit_submitted" class="d-inline"/> Ingediend
                                </span>
                                <span class="badge text-bg-success">
                                    <field name="activiteit_approved" class="d-inline"/> Goedgekeurd
                                </span>
                                <span class="badge text-bg-danger">
                                    <field name="activiteit_rejected" class="d-inline"/> Afgekeurd
                                </span>
                                <span class="badge text-bg-success" invisible="not is_activiteit_manager">
                                    <field name="activiteit_done" class="d-inline"/> Afgerond
                                </span>
                            </div>
                            <div class="text-muted small mt-2">
                                <field name="activiteit_total" class="d-inline"/> totaal — klik om te openen
                            </div>
                        </button>
                        <button name="action_open_professionalisering" type="object"
                                class="o_dashboard_card btn btn-outline-primary p-3 flex-fill text-start"
                                invisible="not has_professionalisering_access">
                            <div class="fw-bold fs-5 mb-2">Professionalisering</div>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge text-bg-info">
                                    <field name="prof_draft" class="d-inline"/> Concept
                                </span>
                                <span class="badge text-bg-warning">
                                    <field name="prof_submitted" class="d-inline"/> Ingediend
                                </span>
                                <span class="badge text-bg-success">
                                    <field name="prof_approved" class="d-inline"/> Goedgekeurd
                                </span>
                                <span class="badge text-bg-danger">
                                    <field name="prof_rejected" class="d-inline"/> Afgekeurd
                                </span>
                                <span class="badge text-bg-success" invisible="not is_prof_manager">
                                    <field name="prof_done" class="d-inline"/> Afgerond
                                </span>
                            </div>
                            <div class="text-muted small mt-2">
                                <field name="prof_total" class="d-inline"/> totaal — klik om te openen
                            </div>
                        </button>
                        <button name="action_open_activiteiten_list" type="object"
                                class="o_dashboard_card btn btn-outline-primary p-3 flex-fill text-start"
                                invisible="not has_activiteiten_access">
                            <div class="fw-bold fs-5 mb-2">Activiteiten</div>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge text-bg-info">
                                    <field name="act_draft" class="d-inline"/> Concept
                                </span>
                                <span class="badge text-bg-info">
                                    <field name="act_form_invullen" class="d-inline"/> Formulier
                                </span>
                                <span class="badge text-bg-warning" invisible="not is_act_aankoop">
                                    <field name="act_bus_check" class="d-inline"/> Bus controle
                                </span>
                                <span class="badge text-bg-danger">
                                    <field name="act_bus_refused" class="d-inline"/> Bus geweigerd
                                </span>
                                <span class="badge text-bg-warning" invisible="not is_act_directie">
                                    <field name="act_pending_approval" class="d-inline"/> Wachten op goedkeuring
                                </span>
                                <span class="badge text-bg-success">
                                    <field name="act_approved" class="d-inline"/> Goedgekeurd
                                </span>
                                <span class="badge text-bg-danger">
                                    <field name="act_rejected" class="d-inline"/> Afgekeurd
                                </span>
                                <span class="badge text-bg-primary" invisible="not is_act_boekhouding">
                                    <field name="act_s_code" class="d-inline"/> S-Code
                                </span>
                                <span class="badge text-bg-primary" invisible="not is_act_vervangingen">
                                    <field name="act_vervanging" class="d-inline"/> Vervanging
                                </span>
                                <span class="badge text-bg-success" invisible="not is_act_manager">
                                    <field name="act_done" class="d-inline"/> Afgerond
                                </span>
                            </div>
                            <div class="text-muted small mt-2">
                                <field name="act_total" class="d-inline"/> totaal — klik om te openen
                            </div>
                        </button>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions that open the REAL list views with native Odoo search bar -->
    <record id="action_open_activiteiten" model="ir.actions.act_window">
        <field name="name">Buitenschoolse Activiteiten</field>
        <field name="res_model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <record id="action_open_professionalisering" model="ir.actions.act_window">
        <field name="name">Professionalisering</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <record id="action_open_activiteiten_list" model="ir.actions.act_window">
        <field name="name">Activiteiten</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <!-- Add module name title to each form view -->
    <record id="view_buitenschoolse_activiteit_form_title" model="ir.ui.view">
        <field name="name">aanvraag_buitenschoolse_activiteit.record.form.title</field>
        <field name="model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="inherit_id" ref="aanvraag_buitenschoolse_activiteit.view_buitenschoolse_activiteit_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="before">
                <h2 class="text-muted">Buitenschoolse Activiteit</h2>
            </xpath>
        </field>
    </record>

    <record id="view_professionalisering_form_title" model="ir.ui.view">
        <field name="name">professionalisering.record.form.title</field>
        <field name="model">professionalisering.record</field>
        <field name="inherit_id" ref="professionalisering.view_professionalisering_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="before">
                <h2 class="text-muted">Professionalisering</h2>
            </xpath>
        </field>
    </record>

    <record id="view_activiteiten_form_title" model="ir.ui.view">
        <field name="name">activiteiten.record.form.title</field>
        <field name="model">activiteiten.record</field>
        <field name="inherit_id" ref="activiteiten.view_activiteiten_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='oe_title']" position="before">
                <h2 class="text-muted">Activiteit</h2>
            </xpath>
        </field>
    </record>

    <!-- Hide the individual module root menus (we provide our own sub-menus) -->
    <record id="aanvraag_buitenschoolse_activiteit.menu_buitenschoolse_activiteit_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="professionalisering.menu_professionalisering_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="activiteiten.menu_activiteiten_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Dashboard action (landing page) -->
    <record id="action_myschool_dashboard" model="ir.actions.act_window">
        <field name="name">Aanvragen</field>
        <field name="res_model">myschool.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" eval="ref('dashboard_singleton')"/>
        <field name="target">current</field>
    </record>
</odoo>
