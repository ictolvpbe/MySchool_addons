<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Test School -->
        <record id="test_school" model="myschool.org">
            <field name="name">Testschool</field>
            <field name="name_short">TEST</field>
            <field name="inst_nr">999999</field>
            <field name="is_active">True</field>
            <field name="automatic_sync">False</field>
        </record>

        <!-- ============================================================ -->
        <!-- 1. MEDEWERKER — basic employee, sees own records only        -->
        <!-- ============================================================ -->
        <record id="test_user_medewerker" model="res.users">
            <field name="name">Test Medewerker</field>
            <field name="login">medewerker@test.com</field>
            <field name="password">test12346</field>
            <field name="school_ids" eval="[(4, ref('test_school'))]"/>
            <field name="group_ids" eval="[
                (4, ref('professionalisering.group_professionalisering_user')),
            ]"/>
        </record>
        <record id="test_employee_medewerker" model="hr.employee">
            <field name="name">Test Medewerker</field>
            <field name="user_id" ref="test_user_medewerker"/>
        </record>

        <!-- ============================================================ -->
