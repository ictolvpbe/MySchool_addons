<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sprint List View -->
    <record id="devhub_sprint_view_list" model="ir.ui.view">
        <field name="name">devhub.sprint.list</field>
        <field name="model">devhub.sprint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'active'"
                    decoration-muted="state == 'done'"/>
                <field name="item_count"/>
                <field name="total_points"/>
                <field name="completed_points"/>
                <field name="velocity" widget="progressbar"/>
            </list>
        </field>
    </record>

    <!-- Sprint Form View -->
    <record id="devhub_sprint_view_form" model="ir.ui.view">
        <field name="name">devhub.sprint.form</field>
        <field name="model">devhub.sprint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Start Sprint" type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>
                    <button name="action_complete" string="Complete Sprint" type="object"
                        class="btn-primary"
                        invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Sprint Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group>
                            <field name="item_count"/>
                            <field name="total_points"/>
                            <field name="completed_points"/>
                            <field name="velocity" widget="progressbar"/>
                        </group>
                    </group>
                    <group string="Sprint Goal">
                        <field name="goal" nolabel="1" placeholder="What is the goal for this sprint?"/>
                    </group>
                    <notebook>
                        <page string="Items" name="items">
                            <field name="item_ids">
                                <list>
                                    <field name="sequence" string="#"/>
                                    <field name="name"/>
                                    <field name="item_type" widget="badge"
                                        decoration-danger="item_type == 'bug'"
                                        decoration-info="item_type == 'story'"
                                        decoration-success="item_type == 'task'"
                                        decoration-warning="item_type == 'improvement'"/>
                                    <field name="stage_id"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assigned_id" widget="many2one_avatar_user"/>
                                    <field name="story_points"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sprint Search View -->
    <record id="devhub_sprint_view_search" model="ir.ui.view">
        <field name="name">devhub.sprint.search</field>
        <field name="model">devhub.sprint</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- Sprint Action -->
    <record id="devhub_sprint_action" model="ir.actions.act_window">
        <field name="name">Sprints</field>
        <field name="res_model">devhub.sprint</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
