<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Project Kanban View -->
    <record id="devhub_project_view_kanban" model="ir.ui.view">
        <field name="name">devhub.project.kanban</field>
        <field name="model">devhub.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="responsible_id"/>
                <field name="item_count"/>
                <field name="open_bug_count"/>
                <field name="process_map_count"/>
                <field name="test_progress"/>
                <field name="is_active"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <strong class="fs-5"><field name="name"/></strong>
                            <span class="badge text-bg-secondary"><field name="code"/></span>
                        </div>
                        <field name="responsible_id" widget="many2one_avatar_user"/>
                        <div class="d-flex gap-3 mt-2 text-muted small">
                            <span title="Items"><i class="fa fa-tasks"/> <field name="item_count"/></span>
                            <span title="Open Bugs" t-if="record.open_bug_count.raw_value > 0"
                                  class="text-danger">
                                <i class="fa fa-bug"/> <field name="open_bug_count"/>
                            </span>
                            <span title="Process Maps" t-if="record.process_map_count.raw_value > 0">
                                <i class="fa fa-sitemap"/> <field name="process_map_count"/>
                            </span>
                        </div>
                        <div class="mt-2" t-if="record.test_progress.raw_value > 0">
                            <field name="test_progress" widget="progressbar"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Project List View -->
    <record id="devhub_project_view_list" model="ir.ui.view">
        <field name="name">devhub.project.list</field>
        <field name="model">devhub.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="item_count"/>
                <field name="open_bug_count"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <!-- Action to open items kanban for a project -->
    <record id="devhub_project_open_items_action" model="ir.actions.act_window">
        <field name="name">Items</field>
        <field name="res_model">devhub.item</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_project_id': active_id}</field>
        <field name="domain">[('project_id', '=', active_id)]</field>
    </record>

    <!-- Action to open bugs kanban for a project -->
    <record id="devhub_project_open_bugs_action" model="ir.actions.act_window">
        <field name="name">Bugs</field>
        <field name="res_model">devhub.item</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_project_id': active_id, 'default_item_type': 'bug'}</field>
        <field name="domain">[('project_id', '=', active_id), ('item_type', '=', 'bug')]</field>
    </record>

    <!-- Action to open improvements kanban for a project -->
    <record id="devhub_project_open_improvements_action" model="ir.actions.act_window">
        <field name="name">Improvements</field>
        <field name="res_model">devhub.item</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_project_id': active_id, 'default_item_type': 'improvement'}</field>
        <field name="domain">[('project_id', '=', active_id), ('item_type', '=', 'improvement')]</field>
    </record>

    <!-- Project Form View (workspace) -->
    <record id="devhub_project_view_form" model="ir.ui.view">
        <field name="name">devhub.project.form</field>
        <field name="model">devhub.project</field>
        <field name="arch" type="xml">
            <form class="o_devhub_project_form">
                <header>
                    <button name="action_save_form" type="object"
                        string="Save" class="btn-primary" icon="fa-save"/>
                    <button string="Cancel" special="cancel"
                        class="btn-secondary" icon="fa-undo"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_process_maps" type="object"
                                class="oe_stat_button" icon="fa-sitemap"
                                invisible="process_map_count == 0">
                            <field name="process_map_count" string="Process Maps" widget="statinfo"/>
                        </button>
                        <button name="action_open_test_items" type="object"
                                class="oe_stat_button" icon="fa-check-square-o"
                                invisible="test_item_count == 0">
                            <field name="test_item_count" string="Test Items" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="module_ids" widget="many2many_tags"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <div class="mb-3">
                        <button name="action_open_or_create_process_map" type="object"
                            string="Process Map" class="btn btn-secondary"
                            icon="fa-sitemap"/>
                    </div>
                    <notebook>
                        <page string="User Stories" name="stories">
                            <field name="story_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_name" string="Story"/>
                                    <button name="action_open_sub_items" type="object"
                                        string="Open Items" icon="fa-th-large"
                                        class="btn btn-link"/>
                                    <field name="project_id" string="Parent Project"/>
                                    <field name="stage_id"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assigned_id" widget="many2one_avatar_user"/>
                                    <field name="child_count" string="Sub-items"/>
                                    <field name="story_points"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Bugs" name="bugs">
                            <button name="%(devhub_project_open_bugs_action)d" type="action"
                                string="Open Kanban" class="btn btn-primary mb-3"
                                icon="fa-th-large"/>
                            <field name="bug_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_name" string="Item"/>
                                    <field name="stage_id"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assigned_id" widget="many2one_avatar_user"/>
                                    <field name="sprint_id" optional="show"/>
                                    <field name="story_points"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Improvements" name="improvements">
                            <button name="%(devhub_project_open_improvements_action)d" type="action"
                                string="Open Kanban" class="btn btn-primary mb-3"
                                icon="fa-th-large"/>
                            <field name="improvement_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_name" string="Item"/>
                                    <field name="item_type" widget="badge"
                                        decoration-info="item_type == 'story'"
                                        decoration-warning="item_type == 'improvement'"/>
                                    <field name="stage_id"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assigned_id" widget="many2one_avatar_user"/>
                                    <field name="sprint_id" optional="show"/>
                                    <field name="story_points"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="All Items" name="items">
                            <button name="%(devhub_project_open_items_action)d" type="action"
                                string="Open Kanban" class="btn btn-primary mb-3"
                                icon="fa-th-large"/>
                            <field name="item_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_name" string="Item"/>
                                    <field name="item_type" widget="badge"
                                        decoration-danger="item_type == 'bug'"
                                        decoration-info="item_type == 'story'"
                                        decoration-success="item_type == 'task'"
                                        decoration-warning="item_type == 'improvement'"/>
                                    <field name="stage_id"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="assigned_id" widget="many2one_avatar_user"/>
                                    <field name="sprint_id" optional="show"/>
                                    <field name="story_points"/>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Sprints" name="sprints">
                            <field name="sprint_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="state" widget="badge"/>
                                    <field name="total_points"/>
                                    <field name="completed_points"/>
                                </list>
                            </field>
                        </page>
                        <page string="Releases" name="releases">
                            <field name="release_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date_planned"/>
                                    <field name="state" widget="badge"/>
                                    <field name="progress" widget="progressbar"/>
                                </list>
                            </field>
                        </page>
                        <page string="Process Maps" name="process_maps">
                            <button name="action_create_process_map" type="object"
                                string="New Process Map" class="btn btn-primary mb-3"
                                icon="fa-plus"/>
                            <field name="process_map_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="state" widget="badge"/>
                                    <field name="version"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tests (3T)" name="tests">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <button name="action_generate_test_items" type="object"
                                    string="Generate 3T from Modules" class="btn btn-primary"
                                    icon="fa-magic"
                                    confirm="This will scan linked modules and generate test items. Continue?"/>
                                <button name="action_open_test_items" type="object"
                                    string="Open Tests" class="btn btn-secondary"
                                    icon="fa-external-link"
                                    invisible="test_item_count == 0"/>
                                <span class="text-muted" invisible="test_item_count == 0">
                                    <field name="test_item_count"/> items |
                                    Progress: <field name="test_progress" widget="progressbar" class="d-inline"/>
                                </span>
                            </div>
                        </page>
                        <page string="Team" name="team">
                            <field name="member_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Documentation" name="documentation">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <button name="action_generate_user_doc" type="object"
                                    string="Generate End-User Doc" class="btn btn-primary"
                                    icon="fa-book"
                                    confirm="Generate end-user documentation from project data?"/>
                                <button name="action_generate_tech_doc" type="object"
                                    string="Generate Technical Doc" class="btn btn-primary"
                                    icon="fa-cogs"
                                    confirm="Generate technical documentation from project data?"/>
                                <button name="%(myschool_devhub.action_report_user_doc)d" type="action"
                                    string="Download User Doc PDF" class="btn btn-secondary"
                                    icon="fa-file-pdf-o"
                                    invisible="not doc_user_html"/>
                                <button name="%(myschool_devhub.action_report_tech_doc)d" type="action"
                                    string="Download Tech Doc PDF" class="btn btn-secondary"
                                    icon="fa-file-pdf-o"
                                    invisible="not doc_technical_html"/>
                                <span class="text-muted" invisible="not doc_generated_date">
                                    Last generated: <field name="doc_generated_date" widget="datetime"/>
                                </span>
                            </div>
                            <div invisible="not doc_user_html" class="mb-4">
                                <h3>End-User Documentation</h3>
                                <field name="doc_user_html" class="devhub-doc-container"/>
                            </div>
                            <div invisible="not doc_technical_html" class="mb-4">
                                <h3>Technical Documentation</h3>
                                <field name="doc_technical_html" class="devhub-doc-container"/>
                            </div>
                            <div invisible="doc_user_html or doc_technical_html">
                                <p class="text-muted">
                                    No documentation generated yet. Click one of the buttons above to generate.
                                </p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Project Search View -->
    <record id="devhub_project_view_search" model="ir.ui.view">
        <field name="name">devhub.project.search</field>
        <field name="model">devhub.project</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="responsible_id"/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <separator/>
                <filter string="Project Lead" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
            </search>
        </field>
    </record>

    <!-- Project Action -->
    <record id="devhub_project_action" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">devhub.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
