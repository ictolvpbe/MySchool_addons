<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Test Item List View -->
    <record id="devhub_test_item_view_list" model="ir.ui.view">
        <field name="name">devhub.test.item.list</field>
        <field name="model">devhub.test.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="test_type_id" widget="badge" options="{'color_field': 'color'}"/>
                <field name="module_id" optional="show"/>
                <field name="item_id" string="Story" optional="show"/>
                <field name="state" widget="badge"
                    decoration-muted="state == 'not_tested'"
                    decoration-success="state == 'passed'"
                    decoration-danger="state == 'failed'"
                    decoration-warning="state == 'blocked'"/>
                <field name="tester_id" widget="many2one_avatar_user" optional="show"/>
                <field name="source" optional="hide"/>
                <button name="action_pass" type="object" string="Pass"
                    icon="fa-check" class="btn btn-link text-success"
                    invisible="state == 'passed'"/>
                <button name="action_fail" type="object" string="Fail"
                    icon="fa-times" class="btn btn-link text-danger"
                    invisible="state == 'failed'"/>
                <button name="action_reset" type="object" string="Reset"
                    icon="fa-undo" class="btn btn-link text-muted"
                    invisible="state == 'not_tested'"/>
            </list>
        </field>
    </record>

    <!-- Test Item Form View -->
    <record id="devhub_test_item_view_form" model="ir.ui.view">
        <field name="name">devhub.test.item.form</field>
        <field name="model">devhub.test.item</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_pass" type="object" string="Pass"
                        class="btn-success" invisible="state == 'passed'"/>
                    <button name="action_fail" type="object" string="Fail"
                        class="btn-danger" invisible="state == 'failed'"/>
                    <button name="action_block" type="object" string="Blocked"
                        class="btn-warning" invisible="state == 'blocked'"/>
                    <button name="action_reset" type="object" string="Reset"
                        invisible="state == 'not_tested'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="not_tested,passed,failed,blocked"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="What to test"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="item_id" string="User Story"
                                domain="[('project_id', '=', project_id), ('item_type', '=', 'story')]"/>
                            <field name="test_type_id"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="module_id"/>
                            <field name="view_name" readonly="source == 'auto'"/>
                            <field name="element_info" readonly="source == 'auto'"/>
                            <field name="source"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="tester_id" widget="many2one_avatar_user"/>
                            <field name="test_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Test Item Search View -->
    <record id="devhub_test_item_view_search" model="ir.ui.view">
        <field name="name">devhub.test.item.search</field>
        <field name="model">devhub.test.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="item_id" string="User Story"/>
                <field name="test_type_id"/>
                <field name="module_id"/>
                <field name="tester_id"/>
                <filter string="Not Tested" name="not_tested" domain="[('state', '=', 'not_tested')]"/>
                <filter string="Passed" name="passed" domain="[('state', '=', 'passed')]"/>
                <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Blocked" name="blocked" domain="[('state', '=', 'blocked')]"/>
                <separator/>
                <filter string="Manual" name="manual" domain="[('source', '=', 'manual')]"/>
                <filter string="Auto-generated" name="auto" domain="[('source', '=', 'auto')]"/>
                <separator/>
                <filter string="My Tests" name="my_tests" domain="[('tester_id', '=', uid)]"/>
                <separator/>
                <filter string="View" name="group_view" context="{'group_by': 'view_display_name'}"/>
                <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Test Type" name="group_type" context="{'group_by': 'test_type_id'}"/>
                <filter string="Module" name="group_module" context="{'group_by': 'module_id'}"/>
                <filter string="Story" name="group_story" context="{'group_by': 'item_id'}"/>
                <filter string="Tester" name="group_tester" context="{'group_by': 'tester_id'}"/>
            </search>
        </field>
    </record>

    <!-- Test Item Action -->
    <record id="devhub_test_item_action" model="ir.actions.act_window">
        <field name="name">Things To Test (3T)</field>
        <field name="res_model">devhub.test.item</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_not_tested': 1, 'search_default_group_type': 1}</field>
    </record>

    <!-- Test Type Action (for config) -->
    <record id="devhub_test_type_action" model="ir.actions.act_window">
        <field name="name">Test Types</field>
        <field name="res_model">devhub.test.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
