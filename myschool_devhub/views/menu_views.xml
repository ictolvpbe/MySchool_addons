<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root Menu -->
    <menuitem id="devhub_menu_root"
        name="DevHub"
        web_icon="myschool_devhub,static/description/icon.png"
        sequence="40"/>

    <!-- Projects (primary entry point) -->
    <menuitem id="devhub_menu_projects"
        name="Projects"
        parent="devhub_menu_root"
        action="devhub_project_action"
        sequence="10"/>

    <!-- Configuration -->
    <menuitem id="devhub_menu_config"
        name="Configuration"
        parent="devhub_menu_root"
        groups="myschool_devhub.group_devhub_manager"
        sequence="90"/>

    <!-- Stage Action (for config menu) -->
    <record id="devhub_stage_action" model="ir.actions.act_window">
        <field name="name">Stages</field>
        <field name="res_model">devhub.item.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Tag Action (for config menu) -->
    <record id="devhub_tag_action" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">devhub.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="devhub_menu_config_stages"
        name="Stages"
        parent="devhub_menu_config"
        action="devhub_stage_action"
        sequence="10"/>

    <menuitem id="devhub_menu_config_tags"
        name="Tags"
        parent="devhub_menu_config"
        action="devhub_tag_action"
        sequence="20"/>

</odoo>
