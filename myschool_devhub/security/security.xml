<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="module_category_devhub" model="ir.module.category">
        <field name="name">DevHub</field>
        <field name="sequence">40</field>
    </record>

    <record id="privilege_devhub" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_devhub"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_devhub_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_devhub"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Read access to DevHub models.</field>
    </record>

    <record id="group_devhub_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_devhub"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_devhub_user'))]"/>
        <field name="comment">Full access to all DevHub models.</field>
    </record>

    </data>
</odoo>
