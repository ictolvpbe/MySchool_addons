<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_lessenrooster_import_wizard" model="ir.ui.view">
        <field name="name">lessenrooster.import.wizard.form</field>
        <field name="model">lessenrooster.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Lessenrooster importeren">
                <!-- Upload state -->
                <group invisible="state != 'upload'">
                    <group>
                        <field name="schooljaar"/>
                        <field name="school_id" options="{'no_open': True}"/>
                        <field name="replace_existing"/>
                    </group>
                    <group>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                </group>

                <!-- Done state -->
                <div invisible="state != 'done'">
                    <div class="alert alert-success" role="alert">
                        <strong>Import voltooid!</strong>
                    </div>
                    <group>
                        <group>
                            <field name="imported_count"/>
                            <field name="created_klassen"/>
                        </group>
                        <group>
                            <field name="missing_teachers"
                                   invisible="not missing_teachers"/>
                        </group>
                    </group>
                </div>

                <field name="state" invisible="1"/>
                <footer>
                    <button name="action_import" string="Importeren"
                            type="object" class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button string="Sluiten" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_lessenrooster_import" model="ir.actions.act_window">
        <field name="name">Lessenrooster importeren</field>
        <field name="res_model">lessenrooster.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
