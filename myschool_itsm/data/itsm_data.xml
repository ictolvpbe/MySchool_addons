<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

    <!-- Default Service Categories -->
    <record id="service_cat_infrastructure" model="itsm.service.category">
        <field name="name">Infrastructure</field>
        <field name="description">Servers, network, storage, and cloud infrastructure</field>
        <field name="sequence">10</field>
    </record>

    <record id="service_cat_applications" model="itsm.service.category">
        <field name="name">Applications</field>
        <field name="description">Business and educational applications</field>
        <field name="sequence">20</field>
    </record>

    <record id="service_cat_communication" model="itsm.service.category">
        <field name="name">Communication</field>
        <field name="description">Email, messaging, video conferencing</field>
        <field name="sequence">30</field>
    </record>

    <record id="service_cat_security" model="itsm.service.category">
        <field name="name">Security</field>
        <field name="description">Access control, antivirus, firewalls</field>
        <field name="sequence">40</field>
    </record>

    <record id="service_cat_end_user" model="itsm.service.category">
        <field name="name">End User Support</field>
        <field name="description">Desktop support, printing, peripherals</field>
        <field name="sequence">50</field>
    </record>

    </data>
</odoo>
