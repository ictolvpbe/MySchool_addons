<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

    <record id="seq_itsm_ticket_incident" model="ir.sequence">
        <field name="name">ITSM Incident Sequence</field>
        <field name="code">itsm.ticket.incident</field>
        <field name="prefix">INC-</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_itsm_ticket_request" model="ir.sequence">
        <field name="name">ITSM Service Request Sequence</field>
        <field name="code">itsm.ticket.request</field>
        <field name="prefix">SR-</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_itsm_problem" model="ir.sequence">
        <field name="name">ITSM Problem Sequence</field>
        <field name="code">itsm.problem</field>
        <field name="prefix">PRB-</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_itsm_change" model="ir.sequence">
        <field name="name">ITSM Change Sequence</field>
        <field name="code">itsm.change</field>
        <field name="prefix">CHG-</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_itsm_improvement" model="ir.sequence">
        <field name="name">ITSM Improvement Sequence</field>
        <field name="code">itsm.improvement</field>
        <field name="prefix">IMP-</field>
        <field name="padding">5</field>
    </record>

    </data>
</odoo>
