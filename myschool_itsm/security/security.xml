<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

    <record id="module_category_itsm" model="ir.module.category">
        <field name="name">IT Service Management</field>
        <field name="sequence">30</field>
    </record>

    <record id="privilege_itsm" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_itsm"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_itsm_user" model="res.groups">
        <field name="name">ITSM User</field>
        <field name="privilege_id" ref="privilege_itsm"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('myschool_core.group_myschool_core_user'))]"/>
        <field name="comment">Read access to ITSM. Can submit tickets.</field>
    </record>

    <record id="group_itsm_agent" model="res.groups">
        <field name="name">ITSM Agent</field>
        <field name="privilege_id" ref="privilege_itsm"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_itsm_user'))]"/>
        <field name="comment">IT support agent. Can manage tickets, problems, and knowledge.</field>
    </record>

    <record id="group_itsm_manager" model="res.groups">
        <field name="name">ITSM Manager</field>
        <field name="privilege_id" ref="privilege_itsm"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('group_itsm_agent'))]"/>
        <field name="comment">Full ITSM access including changes, services, SLAs, and CMDB.</field>
    </record>

    </data>
</odoo>
