<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="itsm_service_category_view_list" model="ir.ui.view">
        <field name="name">itsm.service.category.list</field>
        <field name="model">itsm.service.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="itsm_service_category_view_form" model="ir.ui.view">
        <field name="name">itsm.service.category.form</field>
        <field name="model">itsm.service.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
