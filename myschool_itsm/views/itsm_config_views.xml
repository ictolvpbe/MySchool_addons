<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form_itsm" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.itsm</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="IT Service Management" string="IT Service Management"
                     name="myschool_itsm">
                    <block title="Email Integration" name="itsm_email">
                        <setting string="Service Desk Email"
                                 help="The email address used to receive service desk requests (e.g. helpdesk@yourschool.be). Configure your email server under Settings &gt; Technical &gt; Incoming Mail Servers to fetch from this mailbox.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="itsm_alias_name" class="col-lg-3 o_light_label"/>
                                    <field name="itsm_alias_name" placeholder="helpdesk@yourschool.be"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Auto-Acknowledgment"
                                 help="Automatically send a confirmation email to the reporter when a ticket is created from an incoming email.">
                            <field name="itsm_auto_reply"/>
                        </setting>
                    </block>
                    <block title="Email Ticket Defaults" name="itsm_email_defaults">
                        <setting string="Default Ticket Type"
                                 help="Default type assigned to tickets created from incoming emails.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="itsm_default_ticket_type" class="col-lg-3 o_light_label"/>
                                    <field name="itsm_default_ticket_type"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
