<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================
         Root Menu
         ================================================================ -->
    <menuitem id="menu_itsm_root"
              name="IT Service Management"
              web_icon="myschool_itsm,static/description/icon.png"
              groups="myschool_itsm.group_itsm_user"
              sequence="30"/>

    <!-- ================================================================
         Service Desk
         ================================================================ -->
    <menuitem id="menu_itsm_service_desk"
              name="Service Desk"
              parent="menu_itsm_root"
              sequence="10"/>

    <!-- All Tickets -->
    <record id="itsm_ticket_action" model="ir.actions.act_window">
        <field name="name">All Tickets</field>
        <field name="res_model">itsm.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itsm_ticket_view_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>
    <menuitem id="menu_itsm_tickets_all"
              name="All Tickets"
              parent="menu_itsm_service_desk"
              action="itsm_ticket_action"
              sequence="10"/>

    <!-- My Tickets -->
    <record id="itsm_ticket_action_my" model="ir.actions.act_window">
        <field name="name">My Tickets</field>
        <field name="res_model">itsm.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itsm_ticket_view_search"/>
        <field name="context">{'search_default_my_tickets': 1, 'search_default_open': 1}</field>
    </record>
    <menuitem id="menu_itsm_tickets_my"
              name="My Tickets"
              parent="menu_itsm_service_desk"
              action="itsm_ticket_action_my"
              sequence="20"/>

    <!-- Incidents -->
    <record id="itsm_ticket_action_incidents" model="ir.actions.act_window">
        <field name="name">Incidents</field>
        <field name="res_model">itsm.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itsm_ticket_view_search"/>
        <field name="domain">[('ticket_type', '=', 'incident')]</field>
        <field name="context">{'default_ticket_type': 'incident', 'search_default_open': 1}</field>
    </record>
    <menuitem id="menu_itsm_incidents"
              name="Incidents"
              parent="menu_itsm_service_desk"
              action="itsm_ticket_action_incidents"
              sequence="30"/>

    <!-- Service Requests -->
    <record id="itsm_ticket_action_requests" model="ir.actions.act_window">
        <field name="name">Service Requests</field>
        <field name="res_model">itsm.ticket</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="itsm_ticket_view_search"/>
        <field name="domain">[('ticket_type', '=', 'service_request')]</field>
        <field name="context">{'default_ticket_type': 'service_request', 'search_default_open': 1}</field>
    </record>
    <menuitem id="menu_itsm_requests"
              name="Service Requests"
              parent="menu_itsm_service_desk"
              action="itsm_ticket_action_requests"
              sequence="40"/>

    <!-- ================================================================
         Problems
         ================================================================ -->
    <record id="itsm_problem_action" model="ir.actions.act_window">
        <field name="name">Problems</field>
        <field name="res_model">itsm.problem</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_problem_view_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>
    <menuitem id="menu_itsm_problems"
              name="Problems"
              parent="menu_itsm_root"
              action="itsm_problem_action"
              sequence="20"/>

    <!-- ================================================================
         Changes
         ================================================================ -->
    <record id="itsm_change_action" model="ir.actions.act_window">
        <field name="name">Changes</field>
        <field name="res_model">itsm.change</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_change_view_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>
    <menuitem id="menu_itsm_changes"
              name="Changes"
              parent="menu_itsm_root"
              action="itsm_change_action"
              sequence="30"/>

    <!-- ================================================================
         Services
         ================================================================ -->
    <menuitem id="menu_itsm_services"
              name="Services"
              parent="menu_itsm_root"
              sequence="40"/>

    <record id="itsm_service_action" model="ir.actions.act_window">
        <field name="name">Service Catalog</field>
        <field name="res_model">itsm.service</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_service_view_search"/>
    </record>
    <menuitem id="menu_itsm_service_catalog"
              name="Service Catalog"
              parent="menu_itsm_services"
              action="itsm_service_action"
              sequence="10"/>

    <record id="itsm_sla_action" model="ir.actions.act_window">
        <field name="name">SLA Definitions</field>
        <field name="res_model">itsm.sla</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_sla_view_search"/>
    </record>
    <menuitem id="menu_itsm_sla"
              name="SLA Definitions"
              parent="menu_itsm_services"
              action="itsm_sla_action"
              sequence="20"/>

    <record id="itsm_service_category_action" model="ir.actions.act_window">
        <field name="name">Service Categories</field>
        <field name="res_model">itsm.service.category</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_itsm_service_categories"
              name="Service Categories"
              parent="menu_itsm_services"
              action="itsm_service_category_action"
              sequence="30"/>

    <!-- ================================================================
         CMDB
         ================================================================ -->
    <record id="itsm_ci_action" model="ir.actions.act_window">
        <field name="name">Configuration Items</field>
        <field name="res_model">itsm.ci</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_ci_view_search"/>
    </record>
    <menuitem id="menu_itsm_cmdb"
              name="CMDB"
              parent="menu_itsm_root"
              action="itsm_ci_action"
              sequence="50"/>

    <!-- ================================================================
         Knowledge Base
         ================================================================ -->
    <record id="itsm_knowledge_action" model="ir.actions.act_window">
        <field name="name">Knowledge Articles</field>
        <field name="res_model">itsm.knowledge.article</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_knowledge_article_view_search"/>
    </record>
    <menuitem id="menu_itsm_knowledge"
              name="Knowledge Base"
              parent="menu_itsm_root"
              action="itsm_knowledge_action"
              sequence="60"/>

    <!-- ================================================================
         Continual Improvement
         ================================================================ -->
    <record id="itsm_improvement_action" model="ir.actions.act_window">
        <field name="name">Improvements</field>
        <field name="res_model">itsm.improvement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="itsm_improvement_view_search"/>
    </record>
    <menuitem id="menu_itsm_improvement"
              name="Continual Improvement"
              parent="menu_itsm_root"
              action="itsm_improvement_action"
              sequence="70"/>

    <!-- ================================================================
         Configuration
         ================================================================ -->
    <menuitem id="menu_itsm_configuration"
              name="Configuration"
              parent="menu_itsm_root"
              sequence="100"/>

    <record id="action_itsm_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_view_form_itsm"/>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'myschool_itsm'}</field>
    </record>
    <menuitem id="menu_itsm_config_settings"
              name="Settings"
              parent="menu_itsm_configuration"
              action="action_itsm_config"
              sequence="10"/>

    <record id="action_itsm_mail_templates" model="ir.actions.act_window">
        <field name="name">Email Templates</field>
        <field name="res_model">mail.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('model_id.model', '=', 'itsm.ticket')]</field>
    </record>
    <menuitem id="menu_itsm_mail_templates"
              name="Email Templates"
              parent="menu_itsm_configuration"
              action="action_itsm_mail_templates"
              sequence="30"/>

</odoo>
