<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="itsm_ticket_view_list" model="ir.ui.view">
        <field name="name">itsm.ticket.list</field>
        <field name="model">itsm.ticket</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority == 'p1'" decoration-warning="priority == 'p2'">
                <field name="name"/>
                <field name="subject"/>
                <field name="ticket_type" widget="badge"/>
                <field name="priority" widget="badge"
                       decoration-danger="priority == 'p1'"
                       decoration-warning="priority == 'p2'"
                       decoration-info="priority == 'p3'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'closed'"
                       decoration-info="state in ('assigned', 'in_progress')"
                       decoration-warning="state == 'pending'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="assigned_to_id" widget="many2one_avatar_user"/>
                <field name="reported_by_id"/>
                <field name="date_created"/>
                <field name="sla_resolution_met" invisible="not sla_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="itsm_ticket_view_form" model="ir.ui.view">
        <field name="name">itsm.ticket.form</field>
        <field name="model">itsm.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_assign" type="object" string="Assign to Me"
                            class="btn-primary"
                            invisible="state not in ('new',)"/>
                    <button name="action_start" type="object" string="Start"
                            class="btn-primary"
                            invisible="state not in ('assigned', 'pending')"/>
                    <button name="action_pending" type="object" string="Pending"
                            invisible="state not in ('in_progress',)"/>
                    <button name="action_resolve" type="object" string="Resolve"
                            class="btn-primary"
                            invisible="state not in ('in_progress', 'assigned')"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state not in ('resolved',)"/>
                    <button name="action_reopen" type="object" string="Reopen"
                            invisible="state not in ('resolved', 'closed')"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-success"
                            invisible="not approval_required"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_send_reply" type="object" string="Reply"
                            class="btn-secondary" icon="fa-reply"
                            invisible="state in ('cancelled',) or not reporter_email"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,assigned,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <label for="subject"/>
                        <h2>
                            <field name="subject" placeholder="Ticket subject..."/>
                        </h2>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="ticket_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="impact"/>
                            <field name="urgency"/>
                            <field name="is_major_incident"/>
                        </group>
                        <group string="Assignment">
                            <field name="service_id"/>
                            <field name="category_id"/>
                            <field name="reported_by_id"/>
                            <field name="reporter_email"/>
                            <field name="assigned_to_id" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Related Assets" name="assets">
                            <field name="asset_ids">
                                <list>
                                    <field name="asset_tag"/>
                                    <field name="name"/>
                                    <field name="category_id"/>
                                    <field name="state"/>
                                    <field name="location_building"/>
                                    <field name="location_room"/>
                                </list>
                            </field>
                        </page>
                        <page string="SLA" name="sla">
                            <group>
                                <group>
                                    <field name="sla_id" readonly="1"/>
                                    <field name="sla_response_deadline" readonly="1"/>
                                    <field name="sla_resolution_deadline" readonly="1"/>
                                </group>
                                <group>
                                    <field name="sla_response_met" readonly="1"
                                           widget="boolean_toggle"/>
                                    <field name="sla_resolution_met" readonly="1"
                                           widget="boolean_toggle"/>
                                    <field name="duration_to_response" readonly="1"
                                           widget="float_time"/>
                                    <field name="duration_to_resolution" readonly="1"
                                           widget="float_time"/>
                                </group>
                            </group>
                        </page>
                        <page string="Resolution" name="resolution">
                            <field name="resolution_notes" placeholder="Describe the resolution..."/>
                        </page>
                        <page string="Related" name="related">
                            <group>
                                <group>
                                    <field name="problem_id"/>
                                    <field name="change_id"/>
                                </group>
                                <group>
                                    <field name="approval_required"/>
                                    <field name="approved_by_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Dates" name="dates">
                            <group>
                                <group>
                                    <field name="date_created"/>
                                    <field name="date_assigned"/>
                                </group>
                                <group>
                                    <field name="date_resolved"/>
                                    <field name="date_closed"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="itsm_ticket_view_search" model="ir.ui.view">
        <field name="name">itsm.ticket.search</field>
        <field name="model">itsm.ticket</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="subject"/>
                <field name="reported_by_id"/>
                <field name="assigned_to_id"/>
                <field name="service_id"/>
                <separator/>
                <filter string="My Tickets" name="my_tickets"
                        domain="[('assigned_to_id', '=', uid)]"/>
                <filter string="Unassigned" name="unassigned"
                        domain="[('assigned_to_id', '=', False)]"/>
                <filter string="Open" name="open"
                        domain="[('state', 'not in', ('closed', 'cancelled', 'resolved'))]"/>
                <separator/>
                <filter string="Incidents" name="incidents"
                        domain="[('ticket_type', '=', 'incident')]"/>
                <filter string="Service Requests" name="service_requests"
                        domain="[('ticket_type', '=', 'service_request')]"/>
                <separator/>
                <filter string="P1 - Critical" name="p1"
                        domain="[('priority', '=', 'p1')]"/>
                <filter string="P2 - High" name="p2"
                        domain="[('priority', '=', 'p2')]"/>
                <filter string="Major Incidents" name="major"
                        domain="[('is_major_incident', '=', True)]"/>
                <filter string="SLA Breached" name="sla_breached"
                        domain="['|', ('sla_response_met', '=', False), ('sla_resolution_met', '=', False)]"/>
<!--                <group string="Group By">-->
<!--                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>-->
<!--                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>-->
<!--                    <filter string="Type" name="group_type" context="{'group_by': 'ticket_type'}"/>-->
<!--                    <filter string="Assigned To" name="group_assigned" context="{'group_by': 'assigned_to_id'}"/>-->
<!--                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>-->
<!--                    <filter string="Service" name="group_service" context="{'group_by': 'service_id'}"/>-->
<!--                </group>-->
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="itsm_ticket_view_kanban" model="ir.ui.view">
        <field name="name">itsm.ticket.kanban</field>
        <field name="model">itsm.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="subject"/>
                <field name="priority"/>
                <field name="ticket_type"/>
                <field name="assigned_to_id"/>
                <field name="state"/>
                <field name="date_created"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="text-truncate"><field name="subject"/></div>
                            <div class="o_kanban_record_bottom mt-1">
                                <div class="oe_kanban_bottom_left">
                                    <field name="ticket_type" widget="badge"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="assigned_to_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
