<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_planner" model="ir.module.category">
        <field name="name">Planner</field>
        <field name="sequence">65</field>
    </record>

    <record id="privilege_planner" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_planner"/>
        <field name="sequence">10</field>
    </record>

    <!-- Personeelslid (was: Gebruiker) -->
    <record id="group_planner_user" model="res.groups">
        <field name="name">Personeelslid</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Drukwerk -->
    <record id="group_planner_drukwerk" model="res.groups">
        <field name="name">Drukwerk</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_planner_user'))]"/>
    </record>

    <!-- Aankoop -->
    <record id="group_planner_aankoop" model="res.groups">
        <field name="name">Aankoop</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('group_planner_user'))]"/>
    </record>

    <!-- Boekhouding -->
    <record id="group_planner_boekhouding" model="res.groups">
        <field name="name">Boekhouding</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">40</field>
        <field name="implied_ids" eval="[(4, ref('group_planner_user'))]"/>
    </record>

    <!-- Vervangingen -->
    <record id="group_planner_vervangingen" model="res.groups">
        <field name="name">Vervangingen</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">50</field>
        <field name="implied_ids" eval="[(4, ref('group_planner_user'))]"/>
    </record>

    <!-- Directie -->
    <record id="group_planner_directie" model="res.groups">
        <field name="name">Directie</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">60</field>
        <field name="implied_ids" eval="[(4, ref('group_planner_user'))]"/>
    </record>

    <!-- Beheerder -->
    <record id="group_planner_admin" model="res.groups">
        <field name="name">Beheerder</field>
        <field name="privilege_id" ref="privilege_planner"/>
        <field name="sequence">70</field>
        <field name="implied_ids" eval="[(4, ref('group_planner_user'))]"/>
    </record>
</odoo>
