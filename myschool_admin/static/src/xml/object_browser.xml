<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Context Menu Template -->
    <t t-name="myschool_admin.ContextMenu" owl="1">
        <div class="ob-context-menu" t-att-style="'left: ' + props.x + 'px; top: ' + props.y + 'px;'">
            <div class="ob-context-menu-header">
                <t t-esc="props.node.name"/>
            </div>
            <t t-foreach="menuItems" t-as="item" t-key="item.action || item_index">
                <t t-if="item.divider">
                    <div class="ob-context-menu-divider"/>
                </t>
                <t t-else="">
                    <div class="ob-context-menu-item" 
                         t-att-class="{ 'ob-context-menu-item-danger': item.danger }"
                         t-on-click="onMenuItemClick"
                         t-att-data-action="item.action">
                        <i t-att-class="item.iconClass" style="margin-right: 8px; width: 18px;"/>
                        <t t-esc="item.label"/>
                    </div>
                </t>
            </t>
        </div>
    </t>

    <!-- Tree Node Template -->
    <t t-name="myschool_admin.TreeNode" owl="1">
        <div class="ob-node" 
             t-att-style="'padding-left: ' + (level * 12) + 'px;'"
             t-att-class="{ 'ob-node-dragging': isDragging, 'ob-node-drag-over': state.dragOver, 'ob-node-active': isActiveNode }"
             draggable="true"
             t-on-dragstart="onDragStart"
             t-on-dragover="onDragOver"
             t-on-dragleave="onDragLeave"
             t-on-drop="onDrop"
             t-on-dragend="onDragEnd"
             t-on-contextmenu="onContextMenu">
            <!-- Node Row -->
            <div class="ob-row" t-att-class="{ 'ob-row-expandable': hasChildren, 'ob-row-selected': isSelected }" t-on-click="onRowClick">
                <!-- Toggle Button -->
                <t t-if="hasChildren">
                    <span class="ob-toggle" t-on-click.stop="toggle">
                        <i t-att-class="isExpanded ? 'fa fa-caret-down' : 'fa fa-caret-right'"/>
                    </span>
                </t>
                <t t-else="">
                    <span class="ob-toggle ob-toggle-empty"></span>
                </t>
                
                <!-- Icon -->
                <span class="ob-icon">
                    <t t-if="props.node.type === 'org' and props.node.org_type_name === 'PERSONGROUP'">
                        <i class="fa fa-users text-info"/>
                    </t>
                    <t t-elif="props.node.type === 'org'">
                        <i class="fa fa-building text-gray"/>
                    </t>
                    <t t-elif="props.node.type === 'person'">
                        <i class="fa fa-user text-info"/>
                    </t>
                    <t t-else="">
                        <i class="fa fa-file"/>
                    </t>
                </span>
                
                <!-- Name with tooltip showing full name -->
                <span class="ob-name" t-att-title="displayTitle">
                    <t t-esc="props.node.name"/>
                </span>
                
                <!-- Badges -->
                <span class="ob-badges">
                    <t t-if="props.node.is_administrative">
                        <span class="ob-badge ob-badge-admin">ADM</span>
                    </t>
                    <t t-if="props.node.person_count">
                        <span class="ob-tree-count">
                            <t t-esc="props.node.person_count"/>
                        </span>
                    </t>
                </span>
            </div>
            
            <!-- Children (if expanded) -->
            <t t-if="isExpanded and hasChildren">
                <div class="ob-children">
                    <!-- Child Organizations -->
                    <t t-if="props.node.children">
                        <t t-foreach="props.node.children" t-as="child" t-key="child.id">
                            <TreeNode node="child" 
                                      level="childLevel" 
                                      activeNodeId="props.activeNodeId"
                                      activeNodeType="props.activeNodeType"
                                      onSelectNode="props.onSelectNode"
                                      onContextMenu="props.onContextMenu"
                                      onDragStart="props.onDragStart"
                                      onDragOver="props.onDragOver"
                                      onDrop="props.onDrop"
                                      selectedIds="props.selectedIds"
                                      draggedNode="props.draggedNode"
                                      expandedIds="props.expandedIds"
                                      onToggleExpand="props.onToggleExpand"/>
                        </t>
                    </t>
                    
                    <!-- Persons under this org -->
                    <t t-if="props.node.persons">
                        <t t-foreach="props.node.persons" t-as="person" t-key="person.id">
                            <TreeNode node="person" 
                                      level="childLevel" 
                                      activeNodeId="props.activeNodeId"
                                      activeNodeType="props.activeNodeType"
                                      onSelectNode="props.onSelectNode"
                                      onContextMenu="props.onContextMenu"
                                      onDragStart="props.onDragStart"
                                      onDragOver="props.onDragOver"
                                      onDrop="props.onDrop"
                                      selectedIds="props.selectedIds"
                                      draggedNode="props.draggedNode"
                                      expandedIds="props.expandedIds"
                                      onToggleExpand="props.onToggleExpand"/>
                        </t>
                    </t>
                </div>
            </t>
        </div>
    </t>

    <!-- Members Panel Template -->
    <t t-name="myschool_admin.MembersPanel" owl="1">
        <div class="ob-members">
            <div class="ob-members-header">
                <div class="ob-panel-title">
                    <t t-if="props.node">
                        Members of <t t-esc="props.node.name"/>
                        <span class="ob-panel-count"><t t-esc="filteredPersons.length + filteredPersongroups.length"/></span>
                    </t>
                    <t t-else="">Members</t>
                </div>
            </div>
            <div class="ob-members-content">
                <t t-if="!props.node">
                    <div class="ob-members-empty">
                        <i class="fa fa-info-circle text-muted"/>
                        <span>Select an organization to view members</span>
                    </div>
                </t>
                <t t-elif="props.node.type !== 'org'">
                    <div class="ob-members-empty">
                        <i class="fa fa-info-circle text-muted"/>
                        <span>Members view available for organizations only</span>
                    </div>
                </t>
                <t t-elif="props.loading">
                    <div class="ob-members-loading">
                        <i class="fa fa-spinner fa-spin"/>
                        <span>Loading members...</span>
                    </div>
                </t>
                <t t-else="">
                    <!-- Filter Search -->
                    <div class="ob-panel-filter">
                        <input type="text"
                               placeholder="Filter members..."
                               t-att-value="state.filterText"
                               t-on-input="onFilterInput"/>
                    </div>

                    <!-- Members List -->
                    <div class="ob-panel-body">
                        <!-- Persons -->
                        <t t-if="filteredPersons.length">
                            <t t-foreach="filteredPersons" t-as="person" t-key="person.id">
                                <div class="ob-member-row"
                                     t-att-class="{ 'ob-member-row-selected': props.selectedMemberId === person.id and props.selectedMemberType === 'person', 'ob-member-row-multi': isMemberMultiSelected(person.id, 'person') }"
                                     t-on-click="onMemberClick"
                                     t-on-contextmenu="onMemberContextMenu"
                                     t-att-data-model="person.model"
                                     t-att-data-id="person.id"
                                     t-att-data-name="person.name"
                                     t-att-data-type="'person'">
                                    <div t-att-class="'ob-member-avatar ' + (person.person_type === 'STUDENT' ? 'ob-avatar-student' : 'ob-avatar-employee')">
                                        <t t-esc="getInitials(person.name)"/>
                                    </div>
                                    <div class="ob-member-info">
                                        <div class="ob-member-name"><t t-esc="person.name"/></div>
                                        <div class="ob-member-meta">
                                            <t t-if="person.sap_ref">SAP: <t t-esc="person.sap_ref"/></t>
                                            <t t-if="person.sap_ref and person.email"> &#x2022; </t>
                                            <t t-if="person.email"><t t-esc="person.email"/></t>
                                        </div>
                                    </div>
                                    <t t-if="person.roles?.length">
                                        <span t-att-class="'ob-role-chip ' + (person.person_type === 'STUDENT' ? 'ob-chip-student' : 'ob-chip-employee')">
                                            <t t-esc="person.roles[0]"/>
                                        </span>
                                    </t>
                                </div>
                            </t>
                        </t>

                        <!-- Person Groups -->
                        <t t-if="filteredPersongroups.length">
                            <t t-foreach="filteredPersongroups" t-as="group" t-key="group.id">
                                <div class="ob-member-row"
                                     t-att-class="{ 'ob-member-row-selected': props.selectedMemberId === group.id and props.selectedMemberType === 'persongroup', 'ob-member-row-multi': isMemberMultiSelected(group.id, 'persongroup') }"
                                     t-on-click="onMemberClick"
                                     t-on-contextmenu="onMemberContextMenu"
                                     t-att-data-model="group.model"
                                     t-att-data-id="group.id"
                                     t-att-data-name="group.name"
                                     t-att-data-type="'persongroup'">
                                    <div class="ob-member-avatar ob-avatar-group">
                                        <i class="fa fa-users"/>
                                    </div>
                                    <div class="ob-member-info">
                                        <div class="ob-member-name"><t t-esc="group.name"/></div>
                                        <div class="ob-member-meta" t-if="group.full_name !== group.name">
                                            <t t-esc="group.full_name"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>

                        <t t-if="!filteredPersons.length and !filteredPersongroups.length">
                            <div class="ob-members-none">
                                <t t-if="state.filterText">No members matching filter</t>
                                <t t-else="">No members in this organization</t>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <!-- Details Panel Template -->
    <t t-name="myschool_admin.DetailsPanel" owl="1">
        <div class="ob-details">
            <t t-if="!props.node">
                <div class="ob-details-empty">
                    <i class="fa fa-mouse-pointer fa-2x text-muted"/>
                    <p>Select an item to view details</p>
                </div>
            </t>
            <t t-else="">
                <!-- Header -->
                <div class="ob-details-header">
                    <div t-att-class="'ob-details-icon ' + (props.node.type === 'org' ? 'ob-details-icon-org' : 'ob-details-icon-person')">
                        <t t-if="props.node.type === 'org'">
                            <i class="fa fa-building"/>
                        </t>
                        <t t-elif="props.node.type === 'person'">
                            <i class="fa fa-user"/>
                        </t>
                    </div>
                    <div class="ob-details-title">
                        <h3><t t-esc="props.node.full_name or props.node.name"/></h3>
                        <span class="ob-details-sub">
                            <t t-if="props.node.type === 'org'">Organization</t>
                            <t t-elif="props.node.type === 'person'">
                                <t t-if="props.node.person_type"><t t-esc="props.node.person_type"/></t>
                                <t t-else="">Person</t>
                            </t>
                            <t t-if="props.node.sap_ref"> &#x2022; SAP: <t t-esc="props.node.sap_ref"/></t>
                            <t t-if="props.node.is_active !== undefined">
                                &#x2022; <t t-if="props.node.is_active">Active</t><t t-else="">Inactive</t>
                            </t>
                        </span>
                    </div>
                    <a class="ob-details-open-link" t-on-click="openRecord">Open form &#x2192;</a>
                </div>

                <!-- Details Body -->
                <div class="ob-details-body">
                    <!-- Quick Actions Bar -->
                    <div class="ob-quick-actions-bar">
                        <t t-if="props.node.type === 'org' and props.node.org_type_name === 'PERSONGROUP'">
                            <button class="ob-qa-btn" t-on-click="onManageMembersClick">
                                <i class="fa fa-users"/> Members
                            </button>
                            <button class="ob-qa-btn" t-on-click="onConfigurationClick">
                                <i class="fa fa-sliders"/> Configuration
                            </button>
                            <button class="ob-qa-btn" t-on-click="onMoveOrgClick">
                                <i class="fa fa-arrows"/> Move
                            </button>
                            <button class="ob-qa-btn ob-qa-btn-danger" t-on-click="onDeleteOrgClick">
                                <i class="fa fa-trash"/> Delete
                            </button>
                        </t>
                        <t t-elif="props.node.type === 'org'">
                            <button class="ob-qa-btn" t-on-click="onCreatePersonClick">
                                <i class="fa fa-user-plus"/> Create Person
                            </button>
                            <button class="ob-qa-btn" t-on-click="onAddChildOrgClick">
                                <i class="fa fa-plus-circle"/> Add Sub-Org
                            </button>
                            <button class="ob-qa-btn" t-on-click="onManageOrgRolesClick">
                                <i class="fa fa-id-badge"/> Roles
                            </button>
                            <button class="ob-qa-btn" t-on-click="onConfigurationClick">
                                <i class="fa fa-sliders"/> Configuration
                            </button>
                            <button class="ob-qa-btn" t-on-click="onMoveOrgClick">
                                <i class="fa fa-arrows"/> Move
                            </button>
                            <button class="ob-qa-btn ob-qa-btn-danger" t-on-click="onDeleteOrgClick">
                                <i class="fa fa-trash"/> Delete
                            </button>
                        </t>
                        <t t-if="props.node.type === 'person'">
                            <button class="ob-qa-btn" t-on-click="openRecord">
                                <i class="fa fa-pencil"/> Edit
                            </button>
                            <button class="ob-qa-btn" t-on-click="onManagePersonRolesClick">
                                <i class="fa fa-id-badge"/> Manage Roles
                            </button>
                            <button class="ob-qa-btn" t-on-click="onMovePersonClick">
                                <i class="fa fa-arrows"/> Move
                            </button>
                            <button class="ob-qa-btn ob-qa-btn-danger" t-on-click="onDeactivatePersonClick">
                                <i class="fa fa-ban"/> Deactivate
                            </button>
                        </t>
                    </div>

                    <!-- Info Cards Grid -->
                    <div class="ob-info-grid">
                        <t t-if="props.node.type === 'org'">
                            <div class="ob-info-card">
                                <div class="ob-info-label">Short Name</div>
                                <div class="ob-info-value"><t t-esc="props.node.name"/></div>
                            </div>
                            <div class="ob-info-card">
                                <div class="ob-info-label">Full Name</div>
                                <div class="ob-info-value"><t t-esc="props.node.full_name or props.node.name"/></div>
                            </div>
                            <t t-if="props.node.child_count">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">Sub-organizations</div>
                                    <div class="ob-info-value"><t t-esc="props.node.child_count"/></div>
                                </div>
                            </t>
                            <t t-if="props.node.person_count">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">Persons</div>
                                    <div class="ob-info-value"><t t-esc="props.node.person_count"/></div>
                                </div>
                            </t>
                            <t t-if="props.node.is_administrative">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">Type</div>
                                    <div class="ob-info-value"><span class="ob-badge ob-badge-admin">Administrative</span></div>
                                </div>
                            </t>
                            <t t-if="props.node.name_tree">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">Tree Position</div>
                                    <div class="ob-info-value ob-info-mono"><t t-esc="props.node.name_tree"/></div>
                                </div>
                            </t>
                        </t>

                        <t t-if="props.node.type === 'person'">
                            <div class="ob-info-card">
                                <div class="ob-info-label">Full Name</div>
                                <div class="ob-info-value"><t t-esc="props.node.full_name or props.node.name"/></div>
                            </div>
                            <t t-if="props.node.email">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">E-mail Cloud</div>
                                    <div class="ob-info-value"><t t-esc="props.node.email"/></div>
                                </div>
                            </t>
                            <t t-if="props.node.roles and props.node.roles.length">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">Roles</div>
                                    <div class="ob-info-value">
                                        <t t-foreach="props.node.roles" t-as="role" t-key="role">
                                            <span class="ob-badge ob-badge-role"><t t-esc="role"/></span>
                                        </t>
                                    </div>
                                </div>
                            </t>
                            <t t-if="props.node.is_administrative">
                                <div class="ob-info-card">
                                    <div class="ob-info-label">Type</div>
                                    <div class="ob-info-value"><span class="ob-badge ob-badge-admin">Administrative</span></div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- Configuration Items Table -->
                    <t t-if="props.node.type === 'org'">
                        <t t-if="props.node.ciRelations and props.node.ciRelations.length">
                            <div class="ob-section-title">Configuration Items</div>
                            <table class="ob-ci-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Value</th>
                                        <th style="width: 60px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="props.node.ciRelations" t-as="ci" t-key="ci.id">
                                        <tr>
                                            <td><t t-esc="ci.name"/></td>
                                            <td class="ob-info-mono"><t t-esc="ci.value"/></td>
                                            <td>
                                                <div class="ob-ci-actions">
                                                    <button class="ob-ci-btn" t-on-click="onEditCiClick" t-att-data-ci-id="ci.id" title="Edit">
                                                        <i class="fa fa-pencil"/>
                                                    </button>
                                                    <button class="ob-ci-btn ob-ci-btn-danger" t-on-click="onRemoveCiClick" t-att-data-ci-id="ci.id" title="Remove">
                                                        <i class="fa fa-times"/>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-elif="props.node.ci_count">
                            <div class="ob-info-card">
                                <div class="ob-info-label">Config Items</div>
                                <div class="ob-info-value">
                                    <t t-esc="props.node.ci_count"/>
                                    <button class="ob-btn ob-btn-sm" style="margin-left: 8px;" t-on-click="onConfigurationClick">
                                        <i class="fa fa-eye"/> View
                                    </button>
                                </div>
                            </div>
                        </t>
                    </t>

                    <!-- Members Section (for PERSONGROUP orgs) -->
                    <t t-if="isPersongroup">
                        <div class="ob-section-title">
                            Members
                            <span class="ob-panel-count" style="margin-left: 6px;"><t t-esc="pgpMembers.length"/></span>
                            <button class="ob-btn ob-btn-sm" style="margin-left: 8px;" t-on-click="onManageMembersClick">
                                <i class="fa fa-pencil"/> Manage
                            </button>
                        </div>
                        <t t-if="pgpMembers.length">
                            <table class="ob-ci-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>E-mail</th>
                                        <th style="width: 60px;">Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="pgpMembers" t-as="member" t-key="member.id">
                                        <tr t-att-class="{ 'text-muted': !member.is_active }">
                                            <td><t t-esc="member.name"/></td>
                                            <td class="ob-info-mono"><t t-esc="member.email or ''"/></td>
                                            <td>
                                                <t t-if="member.is_active">
                                                    <span class="ob-badge ob-badge-role">Yes</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="ob-badge ob-badge-admin">No</span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <div class="ob-members-none" style="padding: 12px; color: #888;">
                                No members in this group
                            </div>
                        </t>
                    </t>
                </div>
            </t>
        </div>
    </t>

    <!-- Main Object Browser Template -->
    <t t-name="myschool_admin.ObjectBrowserClient" owl="1">
        <div class="ob-container" t-ref="container">
            <!-- Toolbar -->
            <div class="ob-toolbar-bar">
                <div class="ob-toolbar-title">Organisation Manager</div>
                <div class="ob-toolbar-sep"></div>
                <div class="ob-global-search-wrapper">
                    <span class="ob-search-icon-inline"><i class="fa fa-search"/></span>
                    <input type="text"
                           class="ob-global-search"
                           placeholder="Global search..."
                           t-att-value="state.globalSearchText"
                           t-on-input="onGlobalSearchInput"
                           t-on-keydown="onGlobalSearchKeydown"/>
                    <t t-if="state.globalSearchResults?.length > 0">
                        <div class="ob-global-search-results">
                            <t t-foreach="state.globalSearchResults" t-as="result" t-key="result.id + '_' + result.type">
                                <div class="ob-global-search-item"
                                     t-on-click="() => this.onGlobalSearchResultClick(result)">
                                    <i t-att-class="result.type === 'org' ? 'fa fa-building' : 'fa fa-user'"/>
                                    <div class="ob-global-search-item-info">
                                        <div class="ob-global-search-item-name"><t t-esc="result.name"/></div>
                                        <div class="ob-global-search-item-type"><t t-esc="result.type === 'org' ? 'Organization' : 'Person'"/></div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
                <div class="ob-toolbar-spacer"></div>
                <label class="ob-toolbar-check">
                    <input type="checkbox"
                           t-att-checked="state.showInactive"
                           t-on-change="onToggleInactive"/>
                    Inactive
                </label>
                <label class="ob-toolbar-check">
                    <input type="checkbox"
                           t-att-checked="state.showAdministrative"
                           t-on-change="onToggleAdministrative"/>
                    Administrative
                </label>
                <div class="ob-toolbar-sep"></div>
                <button class="ob-toolbar-btn" t-on-click="onRefresh">
                    <i class="fa fa-refresh"/> Refresh
                </button>
            </div>
            
            <!-- Tabs -->
            <div class="ob-tabs">
                <button t-att-class="'ob-tab' + (state.activeTab === 'orgs' ? ' ob-tab-active' : '')"
                        t-on-click="onSwitchToOrgsTab">
                    <i class="fa fa-building"/> Organisation Manager
                </button>
                <button t-att-class="'ob-tab' + (state.activeTab === 'roles' ? ' ob-tab-active' : '')"
                        t-on-click="onSwitchToRolesTab">
                    <i class="fa fa-id-badge"/> Role Relations Manager
                </button>
            </div>
            
            <!-- Bulk Actions Bar (shown whenever ≥1 item is selected) -->
            <t t-if="selectedCount > 0">
                <div class="ob-bulk-bar">
                    <span class="ob-bulk-count"><t t-esc="selectedCount"/> geselecteerd</span>
                    <button class="ob-btn ob-btn-sm" t-on-click="bulkAssignRole">
                        <i class="fa fa-id-badge" style="margin-right: 4px;"/>Assign Role
                    </button>
                    <button class="ob-btn ob-btn-sm" t-on-click="bulkMoveToOrg">
                        <i class="fa fa-arrows" style="margin-right: 4px;"/>Move to Org
                    </button>
                    <button class="ob-btn ob-btn-sm ob-btn-danger" t-on-click="bulkDelete">
                        <i class="fa fa-trash" style="margin-right: 4px;"/>Verwijderen
                    </button>
                </div>
            </t>
            
            <!-- Drag hint -->
            <t t-if="state.draggedNode">
                <div class="ob-drag-hint">
                    <i class="fa fa-hand-rock-o" style="margin-right: 8px;"/>
                    Dragging: <t t-esc="state.draggedNode.name"/> - Drop on an organization
                </div>
            </t>
            
            <!-- Organisation Manager Tab Content -->
            <t t-if="state.activeTab === 'orgs'">
            <!-- Main Content: Tree + Members + Details -->
            <div class="ob-main">
                <!-- Tree Panel -->
                <div class="ob-tree-panel">
                    <div class="ob-tree-header">
                        <input type="text"
                               class="ob-tree-search"
                               placeholder="Filter tree..."
                               t-att-value="state.searchText"
                               t-on-input="onSearchInput"/>
                    </div>
                    <div class="ob-tree-content">
                        <!-- Loading -->
                        <t t-if="state.loading">
                            <div class="ob-loading">
                                <i class="fa fa-spinner fa-spin" style="margin-right: 8px;"/>Loading...
                            </div>
                        </t>
                        
                        <t t-elif="state.treeData.organizations.length === 0">
                            <div class="ob-empty">
                                <i class="fa fa-folder-open-o" style="margin-right: 8px;"/>No organizations found
                            </div>
                        </t>
                        
                        <t t-else="">
                            <t t-foreach="state.treeData.organizations" t-as="org" t-key="org.id">
                                <TreeNode node="org"
                                          level="0"
                                          activeNodeId="state.activeNode?.id"
                                          activeNodeType="state.activeNode?.type"
                                          onSelectNode="onSelectNode"
                                          onContextMenu="onContextMenu"
                                          onDragStart="onDragStart"
                                          onDragOver="onDragOver"
                                          onDrop="onDrop"
                                          selectedIds="state.selectedIds"
                                          draggedNode="state.draggedNode"
                                          expandedIds="state.expandedIds"
                                          onToggleExpand="onToggleExpand"/>
                            </t>
                        </t>
                    </div>
                </div>
                
                <!-- Members Panel -->
                <MembersPanel
                    node="state.activeOrgNode"
                    members="state.membersData"
                    loading="state.membersLoading"
                    onOpenRecord="openRecord"
                    onMemberContextMenu="onMemberContextMenu"
                    onMemberSelect="onMemberSelect"
                    onPasswordClick="onPasswordClick"
                    selectedMemberId="state.activeNode?.id"
                    selectedMemberType="state.activeNode?.type"
                    selectedMemberIds="state.selectedMemberIds"/>
                
                <!-- Details Panel -->
                <DetailsPanel node="state.activeNode"
                              members="state.membersData"
                              onAction="onDetailsAction"
                              onOpenRecord="openActiveRecord"
                              onEditCi="openEditCiWizard"
                              onRemoveCi="openRemoveCiWizard"/>
            </div>
            </t>
            
            <!-- Role Relations Manager Tab Content -->
            <t t-if="state.activeTab === 'roles'">
            <div class="ob-role-manager">
                <div class="ob-role-manager-content">
                    <!-- SRBR Section -->
                    <div class="ob-role-section">
                        <div class="ob-role-section-header">
                            <h3><i class="fa fa-exchange"/> SAP-Role to Backend-Role (SRBR)</h3>
                            <p class="text-muted">Link SAP roles to backend roles for role mapping.</p>
                        </div>
                        <div class="ob-role-section-actions">
                            <button class="ob-btn ob-btn-primary" t-on-click="openAddSRBRWizard">
                                <i class="fa fa-plus"/> Add SRBR Relation
                            </button>
                            <button class="ob-btn ob-btn-secondary" t-on-click="viewSRBRRelations">
                                <i class="fa fa-list"/> View All
                            </button>
                        </div>
                    </div>
                    
                    <!-- BRSO Section -->
                    <div class="ob-role-section">
                        <div class="ob-role-section-header">
                            <h3><i class="fa fa-building"/> Backend-Role to School/Department (BRSO)</h3>
                            <p class="text-muted">Determine where persons with a certain role in a school will be created.</p>
                        </div>
                        <div class="ob-role-section-actions">
                            <button class="ob-btn ob-btn-primary" t-on-click="openAddBRSOWizard">
                                <i class="fa fa-plus"/> Add BRSO Relation
                            </button>
                            <button class="ob-btn ob-btn-secondary" t-on-click="viewBRSORelations">
                                <i class="fa fa-list"/> View All
                            </button>
                        </div>
                    </div>
                    
                    <!-- PPBRSO Section -->
                    <div class="ob-role-section">
                        <div class="ob-role-section-header">
                            <h3><i class="fa fa-user-circle"/> Person/Period BRSO (PPBRSO)</h3>
                            <p class="text-muted">Like BRSO but also includes person and period for specific assignments.</p>
                        </div>
                        <div class="ob-role-section-actions">
                            <button class="ob-btn ob-btn-primary" t-on-click="openAddPPBRSOWizard">
                                <i class="fa fa-plus"/> Add PPBRSO Relation
                            </button>
                            <button class="ob-btn ob-btn-secondary" t-on-click="viewPPBRSORelations">
                                <i class="fa fa-list"/> View All
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            </t>
        
            <!-- Context Menu -->
            <t t-if="state.contextMenu">
                <ContextMenu x="state.contextMenu.x"
                             y="state.contextMenu.y"
                             node="state.contextMenu.node"
                             onAction="onContextMenuAction"
                             onClose="onCloseContextMenu"/>
            </t>
        </div>
    </t>

</templates>
