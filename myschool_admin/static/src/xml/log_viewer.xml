<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="myschool_admin.LogViewerClient">
        <div class="lv-container">

            <!-- ===== Config hint banner ===== -->
            <t t-if="state.showConfigHint">
                <div class="lv-config-hint">
                    <div class="lv-config-hint-content">
                        <strong>No logfile configured.</strong>
                        Odoo is logging to stdout only, so you see the in-memory console buffer below.
                        To enable persistent log file viewing, add this to your
                        <code>odoo.conf</code>:
                        <pre class="lv-config-code">logfile = /path/to/odoo.log</pre>
                        Then restart Odoo. The log file will appear in the dropdown.
                    </div>
                    <button class="lv-config-hint-close" t-on-click="onDismissConfigHint">x</button>
                </div>
            </t>

            <!-- ===== Toolbar ===== -->
            <div class="lv-toolbar">

                <!-- Log file selector -->
                <label>File:</label>
                <select t-on-change="onLogFileChange">
                    <option value="">-- select log --</option>
                    <t t-foreach="state.availableLogs" t-as="log" t-key="log[0]">
                        <option t-att-value="log[0]"
                                t-att-selected="log[0] === state.selectedLog">
                            <t t-esc="log[1]"/>
                        </option>
                    </t>
                </select>

                <div class="lv-separator"/>

                <!-- Lines -->
                <label>Lines:</label>
                <input type="number" min="10" max="5000" step="50"
                       t-att-value="state.numLines"
                       t-on-change="onNumLinesChange"/>

                <div class="lv-separator"/>

                <!-- Level filter -->
                <label>Level:</label>
                <select t-on-change="onFilterLevelChange" t-att-value="state.filterLevel">
                    <option value="all"      t-att-selected="state.filterLevel === 'all'">All</option>
                    <option value="debug"    t-att-selected="state.filterLevel === 'debug'">DEBUG</option>
                    <option value="info"     t-att-selected="state.filterLevel === 'info'">INFO</option>
                    <option value="warning"  t-att-selected="state.filterLevel === 'warning'">WARNING</option>
                    <option value="error"    t-att-selected="state.filterLevel === 'error'">ERROR</option>
                    <option value="critical" t-att-selected="state.filterLevel === 'critical'">CRITICAL</option>
                </select>

                <div class="lv-separator"/>

                <!-- Search -->
                <input type="text" placeholder="Search..."
                       t-att-value="state.searchText"
                       t-on-input="onSearchInput"/>

                <div class="lv-separator"/>

                <!-- Auto-refresh -->
                <div class="lv-auto-refresh">
                    <button t-att-class="state.autoRefresh ? 'lv-btn lv-btn-success' : 'lv-btn'"
                            t-on-click="onToggleAutoRefresh">
                        <t t-if="state.autoRefresh">Auto ON</t>
                        <t t-else="">Auto OFF</t>
                    </button>
                    <input type="number" min="1" max="60"
                           t-att-value="state.refreshInterval"
                           t-on-change="onIntervalChange"/>
                    <span style="font-size:12px;color:#6c757d">s</span>
                </div>

                <div class="lv-separator"/>

                <!-- Action buttons -->
                <button class="lv-btn lv-btn-primary" t-on-click="onClickRefresh"
                        t-att-disabled="state.loading">
                    Refresh
                </button>
                <button class="lv-btn" t-on-click="onClickScrollBottom">
                    Bottom
                </button>
                <button class="lv-btn" t-on-click="onClickDownload">
                    Download
                </button>
                <button class="lv-btn" t-on-click="onClickClearFilters">
                    Clear
                </button>
            </div>

            <!-- ===== Status bar ===== -->
            <div class="lv-status-bar">
                <t t-if="state.autoRefresh">
                    <span class="lv-live-indicator">
                        <span class="lv-live-dot"/>
                        LIVE
                    </span>
                </t>
                <t t-if="state.isConsole">
                    <span class="lv-console-badge">CONSOLE</span>
                </t>
                <span t-if="lineCount">Lines: <t t-esc="lineCount"/></span>
                <span t-if="state.fileSize">Size: <t t-esc="state.fileSize"/></span>
                <span t-if="formattedRefresh">Updated: <t t-esc="formattedRefresh"/></span>
                <t t-if="state.loading">
                    <span class="lv-live-indicator" style="color:#58a6ff">
                        <span class="lv-spinner"/> loading...
                    </span>
                </t>
            </div>

            <!-- ===== Terminal ===== -->
            <div class="lv-terminal-wrapper">
                <div class="lv-terminal-header">
                    <span class="lv-terminal-dot lv-terminal-dot-red"/>
                    <span class="lv-terminal-dot lv-terminal-dot-yellow"/>
                    <span class="lv-terminal-dot lv-terminal-dot-green"/>
                    <span class="lv-terminal-title"><t t-esc="terminalTitle"/></span>
                </div>

                <t t-if="!state.selectedLog">
                    <div class="lv-empty">
                        <div class="lv-empty-icon">&#128196;</div>
                        <div>Select a log file to begin.</div>
                    </div>
                </t>
                <t t-elif="state.loading and !state.logContent">
                    <div class="lv-loading">
                        <span class="lv-spinner"/>
                        Loading log file...
                    </div>
                </t>
                <t t-else="">
                    <pre class="lv-terminal" t-ref="logOutput"><t t-esc="state.logContent"/></pre>
                </t>
            </div>

        </div>
    </t>

</templates>
