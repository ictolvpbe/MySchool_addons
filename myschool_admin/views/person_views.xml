<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================================================================== -->
    <!-- Person List View                                                      -->
    <!-- Mockup: 03-person-list — type badges, email, org tree, status dots    -->
    <!-- ===================================================================== -->

    <record id="view_myschool_person_list" model="ir.ui.view">
        <field name="name">myschool.person.list</field>
        <field name="model">myschool.person</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active"
                  default_order="name">
                <field name="name" string="Person"/>
                <field name="first_name" optional="hide"/>
                <field name="short_name" optional="hide"/>
                <field name="person_type_id" widget="badge"
                       decoration-info="person_type_id.name == 'EMPLOYEE'"
                       decoration-success="person_type_id.name == 'STUDENT'"/>
                <field name="sap_ref" string="SAP Ref" optional="show"/>
                <field name="tree_org_id" string="Organization" optional="show"/>
                <field name="email_cloud" string="E-mail Cloud" optional="show"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Person Form View                                                      -->
    <!-- Mockup: 02-person-form — header actions, stat buttons, status bar,    -->
    <!-- tabs: Overview, Accounts & FQDN, Registration, Relations, Details     -->
    <!-- ===================================================================== -->

    <record id="view_myschool_person_form" model="ir.ui.view">
        <field name="name">myschool.person.form</field>
        <field name="model">myschool.person</field>
        <field name="arch" type="xml">
            <form string="Persoon">
                <header>
                    <button name="action_deactivate_employee"
                            string="Deactivate"
                            type="object"
                            class="btn-secondary"
                            invisible="not is_active"
                            confirm="Are you sure? This will also deactivate the Odoo user, HR employee, and all relations."/>
                    <button name="action_reactivate_employee"
                            string="Reactivate"
                            type="object"
                            class="btn-primary"
                            invisible="is_active"/>
                    <button name="action_create_odoo_user"
                            string="Create Odoo User"
                            type="object"
                            class="btn-secondary"
                            icon="fa-user-plus"
                            invisible="odoo_user_id"/>
                    <button name="action_recalculate_person_tree"
                            string="Recalculate Tree"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"
                            title="Recalculate PERSON-TREE position based on PPSBR relations"/>
                    <button name="action_recalc_roles"
                            string="Recalculate Roles"
                            type="object"
                            class="btn-secondary"
                            icon="fa-id-badge"
                            title="Read hoofd_ambt from person details, resolve via SRBR and create missing PPSBR"/>
                </header>
                <sheet>
                    <!-- Stat Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_odoo_user"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user"
                                invisible="not odoo_user_id">
                            <field name="has_odoo_account" widget="boolean" string="Odoo User"/>
                        </button>
                        <button name="action_view_odoo_employee"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-id-card"
                                invisible="not odoo_employee_id">
                            <span>HR Employee</span>
                        </button>
                        <button name="action_view_proprelations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-link">
                            <field name="proprelation_count" widget="statinfo" string="Relations"/>
                        </button>
                    </div>

                    <!-- Inactive ribbon -->
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="is_active"/>

                    <!-- Identity Header -->
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3 class="text-muted">
                            <field name="first_name" class="oe_inline"/> |
                            <field name="person_type_id" class="oe_inline" options="{'no_create': True}"/>
                        </h3>
                    </div>

                    <!-- Key fields above tabs -->
                    <group>
                        <group string="Status &amp; Type">
                            <field name="person_type_id"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                        <group string="Linked Accounts">
                            <field name="odoo_user_id" readonly="1"/>
                            <field name="odoo_employee_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab 1: Overview (mockup: Identity + References + Tree Position) -->
                        <page string="Overview" name="basic_info">
                            <group>
                                <group string="Identity">
                                    <field name="name" string="Full Name"/>
                                    <field name="first_name"/>
                                    <field name="short_name"/>
                                    <field name="abbreviation"/>
                                    <field name="gender"/>
                                    <field name="birth_date"/>
                                </group>
                                <group string="References">
                                    <field name="sap_ref"/>
                                    <field name="sap_person_uuid"/>
                                    <field name="stam_boek_nr"/>
                                    <field name="insz"/>
                                </group>
                            </group>
                            <group>
                                <group string="Tree Position">
                                    <field name="tree_org_id" readonly="1"/>
                                    <field name="tree_org_name_tree" readonly="1" class="ms-field-mono"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2: Accounts & FQDN (mockup: monospace FQDN fields) -->
                        <page string="Accounts &amp; FQDN" name="accounts">
                            <group>
                                <group string="Cloud Account">
                                    <field name="email_cloud"/>
                                    <field name="email_private"/>
                                    <field name="password" password="True"/>
                                </group>
                                <group string="LDAP Distinguished Names">
                                    <field name="person_fqdn_internal" class="ms-field-mono"/>
                                    <field name="person_fqdn_external" class="ms-field-mono"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 3: Registration -->
                        <page string="Registration" name="registration">
                            <group>
                                <group string="Registration Period">
                                    <field name="reg_start_date"/>
                                    <field name="reg_end_date"/>
                                </group>
                                <group string="Registration Source">
                                    <field name="reg_inst_nr"/>
                                    <field name="reg_group_code"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 4: Relations (mockup: relation badges) -->
                        <page string="Relations" name="relations">
                            <field name="proprelation_all_ids" readonly="1">
                                <list decoration-muted="not is_active">
                                    <field name="name"/>
                                    <field name="proprelation_type_id" widget="badge"
                                           decoration-info="proprelation_type_id.name == 'PPSBR'"
                                           decoration-success="proprelation_type_id.name == 'PERSON-TREE'"
                                           decoration-warning="proprelation_type_id.name == 'BRSO'"/>
                                    <field name="id_role" optional="show"/>
                                    <field name="id_org" optional="show"/>
                                    <field name="id_org_parent" optional="hide"/>
                                    <field name="id_period" optional="hide"/>
                                    <field name="is_active" widget="boolean"/>
                                    <field name="is_master" widget="boolean" optional="show"/>
                                    <field name="automatic_sync" widget="boolean" optional="show"/>
                                    <field name="start_date" optional="hide"/>
                                    <field name="end_date" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab 5: Details -->
                        <page string="Details" name="details">
                            <field name="person_details_set">
                                <list decoration-muted="not is_active">
                                    <field name="create_date" string="Created"/>
                                    <field name="is_active" widget="boolean"/>
                                    <field name="hoofd_ambt"/>
                                    <field name="extra_field_1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Person Search View                                                    -->
    <!-- Mockup: 03-person-list — search by name, SAP ref, email              -->
    <!-- ===================================================================== -->

    <record id="view_myschool_person_search" model="ir.ui.view">
        <field name="name">myschool.person.search</field>
        <field name="model">myschool.person</field>
        <field name="arch" type="xml">
            <search string="Zoek Personen">
                <field name="name" string="Name / SAP / Email"
                       filter_domain="['|','|',('name', 'ilike', self),('sap_ref', 'ilike', self),('email_cloud', 'ilike', self)]"/>
                <field name="first_name"/>
                <field name="sap_ref"/>
                <field name="person_type_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter string="Employees" name="employees" domain="[('person_type_id.name', '=', 'EMPLOYEE')]"/>
                <filter string="Students" name="students" domain="[('person_type_id.name', '=', 'STUDENT')]"/>
            </search>
        </field>
    </record>

    <!-- Person Action -->
    <record id="action_myschool_person" model="ir.actions.act_window">
        <field name="name">Personen</field>
        <field name="res_model">myschool.person</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuwe persoon aan
            </p>
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Server Actions                                                        -->
    <!-- ===================================================================== -->

    <!-- Recalculate All PERSON-TREE Relations -->
    <record id="action_recalculate_all_person_trees" model="ir.actions.server">
        <field name="name">Recalculate All PERSON-TREE Relations</field>
        <field name="model_id" ref="myschool_core.model_myschool_person"/>
        <field name="state">code</field>
        <field name="code">
PropRelation = env['myschool.proprelation']
PropRelationType = env['myschool.proprelation.type']
person_tree_type = PropRelationType.search([('name', '=', 'PERSON-TREE')], limit=1)
removed = 0
if person_tree_type:
    existing = PropRelation.search([('proprelation_type_id', '=', person_tree_type.id)])
    removed = len(existing)
    existing.unlink()
processor = env['myschool.betask.processor']
persons = env['myschool.person'].search([('is_active', '=', True)])
success = 0
skipped = 0
for person in persons:
    result = processor._update_person_tree_position(person)
    if result:
        success += 1
    else:
        skipped += 1
action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'PERSON-TREE Recalculation Complete',
        'message': f'Removed {removed} old relations. {success} created, {skipped} skipped (no active PPSBR) out of {len(persons)} active persons.',
        'type': 'success',
        'sticky': True,
    }
}
        </field>
    </record>

    <!-- Update Person Properties (email_cloud + FQDN) -->
    <record id="action_update_person_properties" model="ir.actions.server">
        <field name="name">Update Person Properties</field>
        <field name="model_id" ref="myschool_core.model_myschool_person"/>
        <field name="state">code</field>
        <field name="code">
processor = env['myschool.betask.processor']
PropRelation = env['myschool.proprelation']
PropRelationType = env['myschool.proprelation.type']
PersonType = env['myschool.person.type']

person_tree_type = PropRelationType.search([('name', '=', 'PERSON-TREE')], limit=1)
if not person_tree_type:
    raise UserError('PERSON-TREE type not found')

person_types = PersonType.search([('name', 'in', ('EMPLOYEE', 'STUDENT'))])
persons = env['myschool.person'].search([
    ('is_active', '=', True),
    ('person_type_id', 'in', person_types.ids),
])

updated = 0
skipped = 0
for person in persons:
    tree_rel = PropRelation.search([
        ('id_person', '=', person.id),
        ('proprelation_type_id', '=', person_tree_type.id),
        ('is_active', '=', True),
    ], limit=1)
    if tree_rel and tree_rel.id_org:
        processor._populate_person_account_fields(person, tree_rel.id_org)
        updated += 1
    else:
        skipped += 1

action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'Update Person Properties Complete',
        'message': f'Updated {updated} persons, skipped {skipped} (no PERSON-TREE) out of {len(persons)} active employees/students.',
        'type': 'success',
        'sticky': True,
    }
}
        </field>
    </record>
</odoo>
