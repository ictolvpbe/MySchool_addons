<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Person Details List View -->
    <record id="view_myschool_person_details_list" model="ir.ui.view">
        <field name="name">myschool.person.details.list</field>
        <field name="model">myschool.person.details</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active">
                <field name="person_id"/>
                <field name="hoofd_ambt" optional="show"/>
                <field name="extra_field_1" optional="show"/>
                <field name="is_active" widget="boolean"/>
                <field name="create_date" string="Created" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Person Details Form View -->
    <record id="view_myschool_person_details_form" model="ir.ui.view">
        <field name="name">myschool.person.details.form</field>
        <field name="model">myschool.person.details</field>
        <field name="arch" type="xml">
            <form string="Persoon Details">
                <header>
                    <button name="action_reformat_json"
                            string="Reformat JSON"
                            type="object"
                            class="btn-secondary"
                            icon="fa-indent"
                            title="Pretty-print all JSON fields for better readability"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="person_id"/></h1>
                        <h3 class="text-muted">
                            <field name="hoofd_ambt" class="oe_inline" placeholder="Assignment"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Person">
                            <field name="person_id" invisible="1"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                        <group string="Details">
                            <field name="hoofd_ambt"/>
                            <field name="extra_field_1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="JSON Data" name="json_data">
                            <field name="full_json_string_html" nolabel="1"/>
                        </page>
                        <page string="Adressen" name="addresses">
                            <field name="addresses_html" nolabel="1"/>
                        </page>
                        <page string="E-mails" name="emails">
                            <field name="emails_html" nolabel="1"/>
                        </page>
                        <page string="Communicatienummers" name="comnrs">
                            <field name="comnrs_html" nolabel="1"/>
                        </page>
                        <page string="Bankrekeningen" name="bank_accounts">
                            <field name="bank_accounts_html" nolabel="1"/>
                        </page>
                        <page string="Relaties" name="relations">
                            <field name="relations_html" nolabel="1"/>
                        </page>
                        <page string="Partner" name="partner">
                            <field name="partner_html" nolabel="1"/>
                        </page>
                        <page string="Kinderen" name="children">
                            <field name="children_html" nolabel="1"/>
                        </page>
                        <page string="Assignments" name="assignments">
                            <field name="assignments_html" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Person Details Action -->
    <record id="action_myschool_person_details" model="ir.actions.act_window">
        <field name="name">Persoon Details</field>
        <field name="res_model">myschool.person.details</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak nieuwe persoon details aan
            </p>
        </field>
    </record>

    <!-- Server Action: Reformat All JSON -->
    <record id="action_reformat_all_person_details_json" model="ir.actions.server">
        <field name="name">Reformat All JSON</field>
        <field name="model_id" ref="myschool_core.model_myschool_person_details"/>
        <field name="binding_model_id" ref="myschool_core.model_myschool_person_details"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = model.action_reformat_all_json()
        </field>
    </record>
</odoo>