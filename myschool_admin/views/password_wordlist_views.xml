<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_myschool_password_wordlist_list" model="ir.ui.view">
        <field name="name">myschool.password.wordlist.list</field>
        <field name="model">myschool.password.wordlist</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active">
                <field name="name"/>
                <field name="list_type"/>
                <field name="difficulty" optional="show"/>
                <field name="line_count" string="# regels"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="view_myschool_password_wordlist_form" model="ir.ui.view">
        <field name="name">myschool.password.wordlist.form</field>
        <field name="model">myschool.password.wordlist</field>
        <field name="arch" type="xml">
            <form string="Wachtwoord-woordenlijst">
                <sheet>
                    <widget name="web_ribbon" title="Inactief"
                            bg_color="text-bg-secondary" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="bv. 1e graad — heel makkelijk"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="list_type" widget="radio"/>
                            <field name="difficulty"
                                   invisible="list_type != 'passwords'"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="line_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Omschrijving">
                        <field name="description" nolabel="1" placeholder="Waar dient deze lijst voor?"/>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="list_type != 'words'">
                        <i class="fa fa-info-circle me-1" title="Info" role="img"/>
                        <strong>Woordenlijst voor wachtzinnen</strong> — gebruik korte, makkelijk uit te
                        spreken woorden (3-7 letters). Templates in <em>passphrase</em>-modus combineren
                        N woorden uit deze lijst tot een wachtzin. Minimaal ~300 woorden aanbevolen voor
                        voldoende entropie.
                    </div>
                    <group invisible="list_type != 'passwords'"
                           string="Wachtwoorden (één per regel)">
                        <field name="content" nolabel="1"
                               widget="text"
                               placeholder="boterham&#10;appelsap&#10;potlood&#10;# Lege regels en regels die met # beginnen worden genegeerd"
                               style="font-family: ui-monospace, 'SFMono-Regular', monospace; min-height: 280px;"/>
                    </group>
                    <group invisible="list_type != 'words'"
                           string="Woorden (één per regel)">
                        <field name="content" nolabel="1"
                               widget="text"
                               placeholder="fiets&#10;boterham&#10;zonnebloem&#10;potlood&#10;regenboog&#10;# Voor wachtzinnen: gebruik korte, herkenbare woorden"
                               style="font-family: ui-monospace, 'SFMono-Regular', monospace; min-height: 280px;"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_myschool_password_wordlist" model="ir.actions.act_window">
        <field name="name">Wachtwoord-woordenlijsten</field>
        <field name="res_model">myschool.password.wordlist</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuwe woordenlijst aan
            </p>
            <p>
                Eenvoudige wachtwoorden voor jongere leerlingen.
                Eén wachtwoord per regel, lege regels en commentaar (#) worden genegeerd.
            </p>
        </field>
    </record>

</odoo>
