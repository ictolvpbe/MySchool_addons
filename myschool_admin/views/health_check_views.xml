<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================
         Health Check — main wizard form
         ===================================================== -->
    <record id="view_health_check_form" model="ir.ui.view">
        <field name="name">myschool.health.check.form</field>
        <field name="model">myschool.health.check</field>
        <field name="arch" type="xml">
            <form string="Health Check">
                <sheet>
                    <div class="oe_title">
                        <h1>MySchool Health Check</h1>
                        <p class="text-muted">
                            Controleer of de objecten in MySchool volledig zijn
                            ingevuld en of de OUs en groepen in AD overeenkomen
                            met de configuratie.
                        </p>
                    </div>

                    <group>
                        <group string="Scope">
                            <field name="check_orgs"/>
                            <field name="check_org_fields"
                                   invisible="not check_orgs"/>
                            <field name="check_org_ad_sync"
                                   invisible="not check_orgs"/>
                            <field name="only_active"/>
                        </group>
                        <group string="Resultaat">
                            <field name="last_run_at" readonly="1"/>
                            <field name="issue_count" readonly="1"/>
                            <field name="error_count" readonly="1"/>
                            <field name="warning_count" readonly="1"/>
                        </group>
                    </group>

                    <div class="o_row mb-3">
                        <button name="action_run" type="object"
                                string="Run checks" class="btn-primary"/>
                        <button name="action_fix_all" type="object"
                                string="Fix all (auto-fixable)"
                                class="btn-warning"
                                invisible="issue_count == 0"
                                confirm="Automatische fixes toepassen op alle bevindingen?"/>
                    </div>

                    <field name="summary" readonly="1" nolabel="1"
                           invisible="not summary"/>

                    <separator string="Bevindingen"/>
                    <field name="issue_ids" nolabel="1">
                        <list create="false" delete="false"
                              decoration-danger="severity == 'error'"
                              decoration-warning="severity == 'warning'"
                              decoration-info="severity == 'info'"
                              decoration-muted="is_fixed">
                            <field name="severity" widget="badge"
                                   decoration-danger="severity == 'error'"
                                   decoration-warning="severity == 'warning'"
                                   decoration-info="severity == 'info'"/>
                            <field name="object_type"/>
                            <field name="org_id"/>
                            <field name="issue_kind"/>
                            <field name="description"/>
                            <field name="field_name" optional="hide"/>
                            <field name="ldap_dn" optional="show"/>
                            <field name="fix_kind" optional="hide"/>
                            <field name="is_fixed"/>
                            <field name="fix_message" optional="show"/>
                            <button name="action_open_record" type="object"
                                    string="Open" icon="fa-external-link"
                                    invisible="not org_id"/>
                            <button name="action_fix" type="object"
                                    string="Fix" icon="fa-wrench"
                                    invisible="fix_kind == 'none' or is_fixed"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =====================================================
         Action — opens a fresh transient record
         ===================================================== -->
    <record id="action_health_check" model="ir.actions.act_window">
        <field name="name">Health Check</field>
        <field name="res_model">myschool.health.check</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

</odoo>
