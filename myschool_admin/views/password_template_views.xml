<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_myschool_password_template_list" model="ir.ui.view">
        <field name="name">myschool.password.template.list</field>
        <field name="model">myschool.password.template</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active"
                  decoration-info="complexity_label == 'low' or complexity_label == 'very_low'"
                  decoration-success="complexity_label == 'normal'"
                  decoration-warning="complexity_label == 'high'"
                  decoration-danger="complexity_label == 'very_high'">
                <field name="name"/>
                <field name="mode"/>
                <field name="complexity_label"/>
                <field name="length" optional="show"
                       column_invisible="mode != 'complex'"/>
                <field name="phrase_word_count" string="# wrd"
                       optional="show"
                       column_invisible="mode != 'passphrase'"/>
                <field name="phrase_wordlist_id" optional="show"
                       column_invisible="mode != 'passphrase'"/>
                <field name="rule_count" string="# regels"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="view_myschool_password_template_form" model="ir.ui.view">
        <field name="name">myschool.password.template.form</field>
        <field name="model">myschool.password.template</field>
        <field name="arch" type="xml">
            <form string="Wachtwoord-template">
                <header>
                    <button name="action_preview" type="object"
                            string="Voorbeelden tonen"
                            class="btn-info"
                            icon="fa-eye"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Inactief"
                            bg_color="text-bg-secondary" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="bv. Sterk 12-tekens"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="mode" widget="radio"/>
                            <field name="complexity_label"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="complexity_score" widget="progressbar"
                                   options="{'max_value': 100}"/>
                            <field name="rule_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Omschrijving">
                        <field name="description" nolabel="1"
                               placeholder="Waar dient dit template voor?"/>
                    </group>

                    <!-- COMPLEX mode -->
                    <group string="Lengte &amp; samenstelling" invisible="mode != 'complex'">
                        <group>
                            <field name="length"/>
                            <field name="min_lowercase"/>
                            <field name="min_uppercase"/>
                        </group>
                        <group>
                            <field name="min_digits"/>
                            <field name="min_specials"/>
                            <field name="specials_chars"/>
                        </group>
                    </group>
                    <group string="Geavanceerd" invisible="mode != 'complex'">
                        <field name="min_classes"
                               help="Minimum aantal verschillende char-klassen (kleine letters, hoofdletters, cijfers, speciale tekens) dat in elk gegenereerd wachtwoord moet voorkomen. 0 = geen extra check."/>
                    </group>

                    <!-- PASSPHRASE mode -->
                    <group string="Wachtzin-samenstelling" invisible="mode != 'passphrase'">
                        <group>
                            <field name="phrase_wordlist_id"
                                   options="{'no_create_edit': True}"
                                   help="Woordenlijst van type 'Woorden'. Maak die aan onder Instellingen → Wachtwoordbeleid → Woordenlijsten."/>
                            <field name="phrase_word_count"/>
                            <field name="phrase_separator"/>
                        </group>
                        <group>
                            <field name="phrase_capitalize"/>
                            <field name="phrase_add_digits"/>
                            <field name="phrase_add_specials"/>
                            <field name="specials_chars"
                                   string="Speciale-teken-set"
                                   invisible="phrase_add_specials == 0"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert" invisible="mode != 'passphrase'">
                        <i class="fa fa-info-circle me-1"/>
                        4 woorden uit een lijst van 1000 ≈ <strong>40 bits</strong> entropie —
                        vergelijkbaar met een 7-tekens complex wachtwoord, maar veel makkelijker
                        te onthouden. Voeg cijfers/specials toe voor extra sterkte.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_myschool_password_template" model="ir.actions.act_window">
        <field name="name">Wachtwoord-templates</field>
        <field name="res_model">myschool.password.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuw template aan
            </p>
            <p>
                Bundel een lengte + minimum-aantallen per karakter-klasse in een
                herbruikbaar template. Meerdere policy-regels (en meerdere policies)
                kunnen hetzelfde template hergebruiken.
            </p>
        </field>
    </record>

</odoo>
