<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <!-- ===================================================================== -->
    <!-- Organization List View                                                -->
    <!-- Mockup-inspired: type badges, tree path, active decoration            -->
    <!-- ===================================================================== -->

    <record id="view_myschool_org_list" model="ir.ui.view">
        <field name="name">myschool.org.list</field>
        <field name="model">myschool.org</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active"
                  default_order="name">
                <field name="name"/>
                <field name="displayname" string="Weergavenaam" optional="show"/>
                <field name="name_short" optional="show"/>
                <field name="name_tree" string="Tree Path" optional="show"/>
                <field name="inst_nr" optional="show"/>
                <field name="org_type_id" widget="badge"
                       decoration-info="org_type_id.name == 'SCHOOL'"
                       decoration-success="org_type_id.name == 'CLASSGROUP'"
                       decoration-warning="org_type_id.name == 'PERSONGROUP'"/>
                <field name="is_administrative" widget="boolean" optional="show"/>
                <field name="domain_external" optional="hide"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Organization Form View                                                -->
    <!-- Mockup: 05-org-form — icon header, status bar, tabs with AD/OU       -->
    <!-- ===================================================================== -->

    <record id="view_myschool_org_form" model="ir.ui.view">
        <field name="name">myschool.org.form</field>
        <field name="model">myschool.org</field>
        <field name="arch" type="xml">
            <form string="Organisatie">
                <div class="text-muted small mb-2"><em>Organisatie</em></div>
                <header>
                    <button name="action_update_name_tree" type="object"
                            string="Update Name Tree" class="btn-secondary" icon="fa-refresh"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_proprelations"
                                type="object" class="oe_stat_button" icon="fa-link">
                            <field name="proprelation_count" widget="statinfo" string="Relations"/>
                        </button>
                    </div>

                    <!-- Inactive ribbon -->
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="is_active"/>

                    <!-- Title with type badge and tree path -->
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3 class="text-muted">
                            <field name="org_type_id" class="oe_inline" options="{'no_create': True}"/> |
                            <field name="name_tree" readonly="1" class="oe_inline"/> |
                            Inst.nr: <field name="inst_nr" readonly="1" class="oe_inline"/>
                        </h3>
                    </div>

                    <!-- Key fields above tabs -->
                    <group>
                        <group string="Status &amp; Type">
                            <field name="org_type_id"/>
                            <field name="is_active" widget="boolean_toggle"/>
                            <field name="is_administrative"/>
                        </group>
                        <group>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab 1: General -->
                        <page string="General" name="general">
                            <group>
                                <group string="Identity">
                                    <field name="name"/>
                                    <field name="name_short"/>
                                    <field name="displayname" placeholder="Optioneel — UI-label"/>
                                    <field name="inst_nr"/>
                                </group>
                                <group string="Tree Position">
                                    <field name="name_tree" readonly="1" class="ms-field-mono"/>
                                </group>
                            </group>
                            <group>
                                <group string="Features">
                                    <!-- Persongroups represent the group itself
                                         and never spawn children — their flags
                                         stay False and read-only. Departments
                                         that *contain* persongroups (groups
                                         containers) likewise can't carry the
                                         group flags — those belong on the
                                         children. Other org types control
                                         their group/account setup directly. -->
                                    <field name="org_type_id" invisible="1"/>
                                    <field name="is_groups_container" invisible="1"/>
                                    <field name="has_ou" widget="boolean_toggle"
                                           readonly="org_type_id and org_type_id.name == 'PERSONGROUP'"/>
                                    <field name="has_comgroup" widget="boolean_toggle"
                                           readonly="(org_type_id and org_type_id.name == 'PERSONGROUP') or is_groups_container"/>
                                    <field name="has_secgroup" widget="boolean_toggle"
                                           readonly="(org_type_id and org_type_id.name == 'PERSONGROUP') or is_groups_container"/>
                                    <field name="has_odoo_group" widget="boolean_toggle"
                                           readonly="(org_type_id and org_type_id.name == 'PERSONGROUP') or is_groups_container"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2: Address (only for SCHOOL / SCHOOLBOARD) -->
                        <page string="Address" name="address"
                              invisible="org_type_id.name not in ('SCHOOL', 'SCHOOLBOARD')">
                            <group>
                                <group string="Street">
                                    <field name="street"/>
                                    <field name="street_nr"/>
                                </group>
                                <group string="Location">
                                    <field name="postal_code"/>
                                    <field name="community"/>
                                    <field name="country"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2: AD/OU Configuration (mockup: 05-org-form) -->
                        <page string="AD/OU Configuration" name="ad_ou">
                            <group>
                                <group string="Domains">
                                    <field name="domain_internal"/>
                                    <field name="domain_external"/>
                                </group>
                            </group>
                            <group>
                                <group string="OU FQDN">
                                    <field name="ou_fqdn_internal" class="ms-field-mono"/>
                                    <field name="ou_fqdn_external" class="ms-field-mono"/>
                                </group>
                                <group string="Communication Group">
                                    <field name="com_group_name"/>
                                    <field name="com_group_email"/>
                                    <field name="com_group_fqdn_internal" class="ms-field-mono"/>
                                    <field name="com_group_fqdn_external" class="ms-field-mono"/>
                                </group>
                            </group>
                            <group>
                                <group string="Security Group">
                                    <field name="sec_group_name"/>
                                    <field name="sec_group_fqdn_internal" class="ms-field-mono"/>
                                    <field name="sec_group_fqdn_external" class="ms-field-mono"/>
                                </group>
                            </group>
                            <group string="Odoo Groups" invisible="not has_odoo_group">
                                <field name="odoo_group_ids"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"
                                       domain="[('privilege_id', '!=', False)]"
                                       nolabel="1" colspan="2"/>
                            </group>
                        </page>

                        <!-- Tab: Members (only for PERSONGROUP) -->
                        <page string="Members" name="members"
                              invisible="org_type_id.name != 'PERSONGROUP'">
                            <field name="pgp_member_ids" readonly="1">
                                <list decoration-muted="not is_active">
                                    <field name="id_person" string="Person"/>
                                    <field name="is_active" widget="boolean"/>
                                </list>
                            </field>
                        </page>

                        <!-- Tab: Relations -->
                        <page string="Relations" name="relations">
                            <field name="proprelation_all_ids" readonly="1">
                                <list decoration-muted="not is_active">
                                    <field name="name"/>
                                    <field name="proprelation_type_id" widget="badge"
                                           decoration-info="proprelation_type_id.name == 'PPSBR'"
                                           decoration-success="proprelation_type_id.name == 'PERSON-TREE'"
                                           decoration-warning="proprelation_type_id.name == 'BRSO'"/>
                                    <field name="id_person" optional="show"/>
                                    <field name="id_role" optional="show"/>
                                    <field name="id_org_parent" optional="show"/>
                                    <field name="start_date" optional="hide"/>
                                    <field name="end_date" optional="show"/>
                                    <field name="is_active" widget="boolean"/>
                                    <field name="is_master" widget="boolean" optional="show"/>
                                    <field name="automatic_sync" widget="boolean" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Organization Search View                                              -->
    <!-- ===================================================================== -->

    <record id="view_myschool_org_search" model="ir.ui.view">
        <field name="name">myschool.org.search</field>
        <field name="model">myschool.org</field>
        <field name="arch" type="xml">
            <search string="Zoek Organisaties">
                <field name="name" string="Name / Tree / Inst.nr"
                       filter_domain="['|','|',('name', 'ilike', self),('name_tree', 'ilike', self),('inst_nr', 'ilike', self)]"/>
                <field name="name_short"/>
                <field name="org_type_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter string="Schools" name="schools" domain="[('org_type_id.name', '=', 'SCHOOL')]"/>
                <filter string="Classgroups" name="classgroups" domain="[('org_type_id.name', '=', 'CLASSGROUP')]"/>
                <filter string="Persongroups" name="persongroups" domain="[('org_type_id.name', '=', 'PERSONGROUP')]"/>
                <separator/>
                <filter string="Administrative" name="administrative" domain="[('is_administrative', '=', True)]"/>
                <filter string="Non-administrative" name="non_administrative" domain="[('is_administrative', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Organization Action -->
    <record id="action_myschool_org" model="ir.actions.act_window">
        <field name="name">Organisaties</field>
        <field name="res_model">myschool.org</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuwe organisatie aan
            </p>
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Server Actions                                                        -->
    <!-- ===================================================================== -->

    <!-- Update All Name Trees (Action dropdown binding) -->
    <record id="action_server_update_all_name_trees" model="ir.actions.server">
        <field name="name">Update All Org Name Trees</field>
        <field name="model_id" ref="myschool_core.model_myschool_org"/>
        <field name="binding_model_id" ref="myschool_core.model_myschool_org"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
result = env['myschool.org'].update_all_name_trees_cron()
if result and isinstance(result, dict):
    action = result
        </field>
    </record>

    <!-- Update All Name Trees (menu action) -->
    <record id="action_update_all_org_name_trees" model="ir.actions.server">
        <field name="name">Update All Organization Name Trees</field>
        <field name="model_id" ref="myschool_core.model_myschool_org"/>
        <field name="state">code</field>
        <field name="code">
result = env['myschool.org'].update_all_name_trees_cron()
if result and isinstance(result, dict):
    action = result
        </field>
    </record>

    <!-- Sync persongroups from org settings (menu action) -->
    <record id="action_sync_all_persongroups" model="ir.actions.server">
        <field name="name">Sync persongroups (org settings)</field>
        <field name="model_id" ref="myschool_core.model_myschool_org"/>
        <field name="state">code</field>
        <field name="code">
result = env['myschool.org'].sync_all_persongroups()
err_count = len(result.get('errors', []))
err_detail = (' First error: ' + result['errors'][0]) if err_count else ''
action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'Persongroups Sync Complete',
        'message': f"Processed {result.get('orgs_processed', 0)} org(s). {err_count} error(s).{err_detail}",
        'type': 'success' if not err_count else 'warning',
        'sticky': bool(err_count),
    }
}
        </field>
    </record>

    <!-- Update Classgroup Properties (menu action) -->
    <record id="action_recalculate_all_org_trees" model="ir.actions.server">
        <field name="name">Update classgroup properties</field>
        <field name="model_id" ref="myschool_core.model_myschool_org"/>
        <field name="state">code</field>
        <field name="code">
result = env['myschool.org'].recalculate_classgroup_org_trees()
err_detail = (' Skipped: ' + '; '.join(result['errors'][:5])) if result.get('errors') else ''
action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'Update Classgroup Properties Complete',
        'message': f"ORG-TREE: {result['removed']} removed, {result['created']} created. AD/OU fields updated: {result.get('ad_updated', 0)}. Skipped: {result['skipped']} of {result['total']} classgroups.{err_detail}",
        'type': 'success' if not result.get('errors') else 'warning',
        'sticky': True,
    }
}
        </field>
    </record>

    <!-- ===================================================================== -->
    <!-- Wizard Views (Org Roles, Person Roles)                                -->
    <!-- ===================================================================== -->

    <record id="view_org_role_line_list" model="ir.ui.view">
        <field name="name">myschool.org.role.line.list</field>
        <field name="model">myschool.org.role.line</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" editable="bottom">
                <field name="role_label" string="Role" readonly="1"/>
                <field name="role_name" string="System Name" readonly="1" optional="hide"/>
                <field name="is_active" string="Active" readonly="1" widget="boolean"/>
                <field name="is_master" string="Master" widget="boolean_toggle"/>
                <field name="automatic_sync" string="Auto Sync" widget="boolean_toggle"/>
                <button name="action_remove" type="object" string="Remove" icon="fa-trash"/>
            </list>
        </field>
    </record>

    <record id="view_manage_org_roles_wizard_form" model="ir.ui.view">
        <field name="name">myschool.manage.org.roles.wizard.form</field>
        <field name="model">myschool.manage.org.roles.wizard</field>
        <field name="arch" type="xml">
            <form string="Manage Organization Roles" class="o_wizard_form"
                  style="min-width: 900px;">
                <group>
                    <field name="org_id" invisible="1"/>
                    <field name="org_name" string="Organization"/>
                    <field name="school_id" string="School" options="{'no_create': True}"/>
                </group>
                <separator string="Current Roles (BRSO)"/>
                <field name="line_ids" nolabel="1" widget="one2many"/>
                <separator string="Add New Role"/>
                <group>
                    <field name="new_role_id" string="Role" options="{'no_create': True, 'no_create_edit': True}"/>
                    <button name="action_add_role" type="object" string="Add Role" class="btn-primary" icon="fa-plus"/>
                </group>
                <p class="text-muted">
                    <small>Group flags live on the target org. Open the
                    org's form and tick <code>has_comgroup</code> /
                    <code>has_secgroup</code> / <code>has_odoo_group</code>
                    there.</small>
                </p>
                <footer>
                    <button name="action_save" type="object" string="Save" class="btn-primary"/>
                    <button name="action_close" type="object" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_person_role_line_list" model="ir.ui.view">
        <field name="name">myschool.person.role.line.list</field>
        <field name="model">myschool.person.role.line</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" editable="bottom">
                <field name="role_name" string="Role" readonly="1"/>
                <field name="school_name" string="School" readonly="1"/>
                <field name="is_active" string="Active" readonly="1" widget="boolean"/>
                <field name="is_master" string="Master" widget="boolean_toggle"/>
                <field name="automatic_sync" string="Auto Sync" widget="boolean_toggle"/>
                <button name="action_remove" type="object" string="Remove" icon="fa-trash"/>
            </list>
        </field>
    </record>

    <record id="view_manage_person_roles_wizard_form" model="ir.ui.view">
        <field name="name">myschool.manage.person.roles.wizard.form</field>
        <field name="model">myschool.manage.person.roles.wizard</field>
        <field name="arch" type="xml">
            <form string="Beheer persoon-rollen">
                <div class="text-muted small mb-2"><em>Beheer persoon-rollen</em></div>
                <group>
                    <field name="person_id" invisible="1"/>
                    <field name="person_name" string="Person"/>
                </group>
                <separator string="Current Roles (PPSBR)"/>
                <field name="line_ids" nolabel="1" widget="one2many"/>
                <separator string="Add New Role"/>
                <group>
                    <field name="new_role_id" string="Role" options="{'no_create': True}"/>
                    <field name="new_org_id" string="School" options="{'no_create': True}"/>
                    <button name="action_add_role" type="object" string="Add Role" class="btn-primary" icon="fa-plus"/>
                </group>
                <separator/>
                <group>
                    <button name="action_recalc_roles" type="object"
                            string="Recalculate Roles from Assignment"
                            class="btn-secondary" icon="fa-refresh"
                            title="Read hoofd_ambt from person details, resolve via SRBR and create missing PPSBR"/>
                </group>
                <footer>
                    <button name="action_close" type="object" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    </data>
</odoo>
