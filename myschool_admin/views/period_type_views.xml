<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Period Type List View -->
    <record id="view_myschool_period_type_list" model="ir.ui.view">
        <field name="name">myschool.period.type.list</field>
        <field name="model">myschool.period.type</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active">
                <field name="name"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- Period Type Form View -->
    <record id="view_myschool_period_type_form" model="ir.ui.view">
        <field name="name">myschool.period.type.form</field>
        <field name="model">myschool.period.type</field>
        <field name="arch" type="xml">
            <form string="Periode Type">
                <sheet>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Status">
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Period Type Action -->
    <record id="action_myschool_period_type" model="ir.actions.act_window">
        <field name="name">Periode Types</field>
        <field name="res_model">myschool.period.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuw periode type aan
            </p>
        </field>
    </record>
</odoo>