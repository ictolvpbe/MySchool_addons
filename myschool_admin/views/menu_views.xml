<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =========================================================
         MENUSTRUCTUUR — myschool_admin
         =========================================================
         Top-level (5 groepen):
           1. Dashboard         (5)
           2. Stamgegevens      (10)
           3. Operations        (40)
           4. Onderhoud         (50)
           5. Instellingen      (60)  — zie res_config_settings_views.xml

         Integraties (LDAP / Google / Informat config) en Configuratie
         (config items / CI-relaties) zaten vroeger als aparte top-level
         menus; die zijn opgegaan in de unified Settings-pagina. De twee
         operationele tools die nog onder Integraties hingen
         (Informat-sync gericht, Sync test runner) zijn verhuisd naar
         Operations > Sync-triggers — hun natuurlijke thuis.
         ========================================================= -->

    <!-- ========================================= -->
    <!-- ROOT                                       -->
    <!-- ========================================= -->

    <!-- App-tegel opent direct de Organisation Manager (meest gebruikte
         entry point). Dashboard blijft beschikbaar als sub-menu. -->
    <menuitem id="menu_myschool_root"
              name="MySchool Admin"
              sequence="10"
              action="action_object_browser_client"
              web_icon="school,static/description/icon.png"
              groups="myschool_core.group_myschool_core_admin"/>

    <!-- Organisation Manager: geen eigen menu-item — bereikbaar via
         klik op de "MySchool Admin"-app-tegel zelf. -->

