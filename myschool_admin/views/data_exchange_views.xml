<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================= -->
    <!-- DATA EXCHANGE FORM VIEW -->
    <!-- ========================================= -->

    <record id="view_data_exchange_form" model="ir.ui.view">
        <field name="name">myschool.data.exchange.form</field>
        <field name="model">myschool.data.exchange</field>
        <field name="arch" type="xml">
            <form string="Data Exchange">
                <field name="mode" invisible="1"/>

                <!-- EXPORT MODE -->
                <div invisible="mode != 'export'" class="mb-3">
                    <div class="alert alert-info" role="alert">
                        <strong>Export</strong> a JSON snapshot of MySchool data. Kies
                        eventueel een scope (één school of koepel) en/of selecteer
                        welke secties je wil opnemen. Niet-aangevinkte secties komen
                        niet in het JSON-bestand.
                    </div>
                </div>

                <!-- IMPORT MODE -->
                <div invisible="mode != 'import'" class="mb-3">
                    <div class="alert alert-warning" role="alert">
                        <strong>Import</strong> een eerder geëxporteerde JSON. Alleen
                        de hieronder aangevinkte secties worden ingelezen — zo kan je
                        bv. één bestand uploaden en cherry-picken wat je wil
                        materialiseren. Bestaande records worden gematcht via hun
                        natural key en bijgewerkt.
                    </div>
                    <group>
                        <field name="import_file" filename="import_filename" string="JSON File"/>
                        <field name="import_filename" invisible="1"/>
                    </group>
                </div>

                <!-- SCOPE + INCLUDE TOGGLES (visible in both modes) -->
                <group string="Scope">
                    <field name="scope_org_id"
                           options="{'no_create': True, 'no_create_edit': True}"
                           placeholder="Laat leeg voor hele database"/>
                </group>

                <notebook>
                    <page string="Wat opnemen" name="includes">
                        <group>
                            <group string="Structureel">
                                <field name="include_types"/>
                                <field name="include_orgs"/>
                                <field name="include_roles"/>
                                <field name="include_periods"/>
                                <field name="include_proprelations"/>
                            </group>
                            <group string="Optioneel / privacygevoelig">
                                <field name="include_persongroups"/>
                                <field name="include_classgroups"/>
                                <field name="include_persons"/>
                                <field name="include_betasks"/>
                            </group>
                        </group>
                        <group>
                            <group string="Configuratie">
                                <field name="include_config_items"/>
                                <field name="include_ci_relations"/>
                            </group>
                            <group string="Backend tasks">
                                <field name="include_betask_types"/>
                            </group>
                        </group>
                    </page>
                </notebook>

                <!-- RESULT -->
                <div invisible="not result_summary">
                    <field name="result_summary" widget="text" readonly="1" nolabel="1"
                           class="w-100" style="min-height: 200px;"/>
                </div>

                <footer>
                    <button name="action_export" string="Export" type="object"
                            class="btn-primary" invisible="mode != 'export'"/>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary" invisible="mode != 'import'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ========================================= -->
    <!-- ACTIONS -->
    <!-- ========================================= -->

    <record id="action_data_exchange_export" model="ir.actions.act_window">
        <field name="name">Export Data</field>
        <field name="res_model">myschool.data.exchange</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_mode': 'export'}</field>
    </record>

    <record id="action_data_exchange_import" model="ir.actions.act_window">
        <field name="name">Import Data</field>
        <field name="res_model">myschool.data.exchange</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_mode': 'import'}</field>
    </record>

</odoo>
