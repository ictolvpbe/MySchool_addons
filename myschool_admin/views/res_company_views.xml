<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_form_school" model="ir.ui.view">
        <field name="name">res.company.form.school</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="short_name" placeholder="Verkorte naam voor bedrijfskiezer"/>
                <field name="school_id"/>
            </field>
            <!-- Parent (Hoofdbedrijf) must be a SCHOOLBOARD-linked company.
                 Schools are auto-linked as branches via the org-tree sync. -->
            <field name="parent_id" position="attributes">
                <attribute name="domain">[('school_id.org_type_id.name', '=', 'SCHOOLBOARD')]</attribute>
            </field>
        </field>
    </record>
</odoo>
