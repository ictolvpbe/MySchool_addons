<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PropRelation list View -->
    <record id="view_myschool_proprelation_list" model="ir.ui.view">
        <field name="name">myschool.proprelation.list</field>
        <field name="model">myschool.proprelation</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active">
                <field name="name"/>
                <field name="proprelation_type_id" widget="badge"
                       decoration-info="proprelation_type_id.name == 'PPSBR'"
                       decoration-success="proprelation_type_id.name == 'PERSON-TREE'"
                       decoration-warning="proprelation_type_id.name == 'BRSO'"/>
                <field name="id_person" optional="show"/>
                <field name="id_role" optional="show"/>
                <field name="id_org" optional="show"/>
                <field name="id_org_parent" optional="hide"/>
                <field name="id_period" optional="hide"/>
                <field name="is_active" widget="boolean"/>
                <field name="is_master" widget="boolean" optional="show"/>
                <field name="automatic_sync" widget="boolean" optional="show"/>
                <field name="has_accounts" widget="boolean" optional="hide"/>
                <field name="has_ldap_com_group" widget="boolean" optional="hide"/>
                <field name="has_ldap_sec_group" widget="boolean" optional="hide"/>
                <field name="has_odoo_group" widget="boolean" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- PropRelation Form View -->
    <record id="view_myschool_proprelation_form" model="ir.ui.view">
        <field name="name">myschool.proprelation.form</field>
        <field name="model">myschool.proprelation</field>
        <field name="arch" type="xml">
            <form string="Relatie">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <h3 class="text-muted">
                            <field name="proprelation_type_id" class="oe_inline" options="{'no_create': True}"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Relation">
                            <field name="proprelation_type_id"/>
                            <field name="start_date"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                        <group string="Flags">
                            <field name="is_administrative"/>
                            <field name="is_organisational"/>
                            <field name="is_master"/>
                            <field name="automatic_sync" widget="boolean_toggle"/>
                            <field name="has_accounts" widget="boolean_toggle"/>
                            <field name="has_ldap_com_group" widget="boolean_toggle"/>
                            <field name="has_ldap_sec_group" widget="boolean_toggle"/>
                            <field name="has_odoo_group" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Persoon Relaties" name="person_relations">
                            <group>
                                <field name="id_person"/>
                                <field name="id_person_child"/>
                                <field name="id_person_parent"/>
                            </group>
                        </page>

                        <page string="Rol Relaties" name="role_relations">
                            <group>
                                <field name="id_role"/>
                                <field name="id_role_parent"/>
                                <field name="id_role_child"/>
                            </group>
                        </page>

                        <page string="Organisatie Relaties" name="org_relations">
                            <group>
                                <field name="id_org"/>
                                <field name="id_org_name_tree"/>
                                <field name="id_org_parent"/>
                                <field name="id_org_parent_name_tree"/>
                                <field name="id_org_child"/>
                                <field name="id_org_child_name_tree"/>
                            </group>
                        </page>

                        <page string="Periode Relaties" name="period_relations">
                            <group>
                                <field name="id_period"/>
                                <field name="id_period_parent"/>
                                <field name="id_period_child"/>
                            </group>
                        </page>

                        <!-- Status flags moved to main group above -->
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- PropRelation Search View -->
    <record id="view_myschool_proprelation_search" model="ir.ui.view">
        <field name="name">myschool.proprelation.search</field>
        <field name="model">myschool.proprelation</field>
        <field name="arch" type="xml">
            <search string="Zoek Relaties">
                <field name="name"/>
                <field name="proprelation_type_id"/>
                <field name="id_person"/>
                <field name="id_role"/>
                <field name="id_org"/>
                <field name="id_period"/>
                <separator/>
                <filter string="Actief" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Inactief" name="inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter string="ORG-TREE" name="type_org_tree" domain="[('proprelation_type_id.name', '=', 'ORG-TREE')]"/>
                <filter string="PERSON-TREE" name="type_person_tree" domain="[('proprelation_type_id.name', '=', 'PERSON-TREE')]"/>
                <filter string="PPSBR" name="type_ppsbr" domain="[('proprelation_type_id.name', '=', 'PPSBR')]"/>
                <filter string="BRSO" name="type_brso" domain="[('proprelation_type_id.name', '=', 'BRSO')]"/>
                <filter string="SRBR" name="type_srbr" domain="[('proprelation_type_id.name', '=', 'SRBR')]"/>
                <separator/>
                <filter string="Administratief" name="administrative" domain="[('is_administrative', '=', True)]"/>
                <filter string="Organisatorisch" name="organisational" domain="[('is_organisational', '=', True)]"/>
                <filter string="Master" name="master" domain="[('is_master', '=', True)]"/>
                <separator/>
                <filter string="Auto Sync" name="auto_sync" domain="[('automatic_sync', '=', True)]"/>
                <filter string="Manual" name="manual_sync" domain="[('automatic_sync', '=', False)]"/>
                <separator/>
                <filter string="Has Accounts" name="has_accounts" domain="[('has_accounts', '=', True)]"/>
                <filter string="LDAP COM Group" name="ldap_com" domain="[('has_ldap_com_group', '=', True)]"/>
                <filter string="LDAP SEC Group" name="ldap_sec" domain="[('has_ldap_sec_group', '=', True)]"/>
                <filter string="Odoo Group" name="odoo_group" domain="[('has_odoo_group', '=', True)]"/>
<!--                <group expand="0" string="Groepeer op">-->
<!--                    <filter string="Type" name="group_type" context="{'group_by': 'proprelation_type_id'}"/>-->
<!--                    <filter string="Persoon" name="group_person" context="{'group_by': 'id_person'}"/>-->
<!--                    <filter string="Organisatie" name="group_org" context="{'group_by': 'id_org'}"/>-->
<!--                </group>-->
            </search>
        </field>
    </record>

    <!-- PropRelation Action -->
    <record id="action_myschool_proprelation" model="ir.actions.act_window">
        <field name="name">Relaties</field>
        <field name="res_model">myschool.proprelation</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuwe relatie aan
            </p>
        </field>
    </record>



    <data>
        <!-- Server Action for Update All Proprelation Names (appears in Action dropdown) -->
        <record id="action_server_update_all_proprelation_names" model="ir.actions.server">
            <field name="name">Update All Proprelation Names</field>
            <field name="model_id" ref="myschool_core.model_myschool_proprelation"/>
            <field name="binding_model_id" ref="myschool_core.model_myschool_proprelation"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">
result = env['myschool.proprelation'].update_all_proprelation_names()
if result and isinstance(result, dict):
    action = result
            </field>
        </record>
        
        <!-- Server Action for Update All Proprelation Names (used by menu item) -->
        <record id="action_update_all_proprelation_names" model="ir.actions.server">
            <field name="name">Update All Proprelation Names</field>
            <field name="model_id" ref="myschool_core.model_myschool_proprelation"/>
            <field name="state">code</field>
            <field name="code">
result = env['myschool.proprelation'].update_all_proprelation_names()
if result and isinstance(result, dict):
    action = result
            </field>
        </record>
        
