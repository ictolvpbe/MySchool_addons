<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Period List View -->
    <record id="view_myschool_period_list" model="ir.ui.view">
        <field name="name">myschool.period.list</field>
        <field name="model">myschool.period</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active"
                  default_order="start_date desc, name">
                <field name="name"/>
                <field name="name_in_sap" optional="show"/>
                <field name="period_type_id" widget="badge"
                       decoration-info="period_type_id.name == 'SCHOOLJAAR'"
                       decoration-success="period_type_id.name == 'SEMESTER'"
                       decoration-warning="period_type_id.name == 'TRIMESTER'"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <!-- Period Form View -->
    <record id="view_myschool_period_form" model="ir.ui.view">
        <field name="name">myschool.period.form</field>
        <field name="model">myschool.period</field>
        <field name="arch" type="xml">
            <form string="Periode">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="is_active"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3 class="text-muted">
                            <field name="period_type_id" class="oe_inline" options="{'no_create': True}"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="name"/>
                            <field name="name_in_sap"/>
                            <field name="period_type_id"/>
                        </group>
                        <group string="Duration &amp; Status">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="is_active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Period Search View -->
    <record id="view_myschool_period_search" model="ir.ui.view">
        <field name="name">myschool.period.search</field>
        <field name="model">myschool.period</field>
        <field name="arch" type="xml">
            <search string="Zoek Periodes">
                <field name="name" string="Name / SAP Name"
                       filter_domain="['|',('name', 'ilike', self),('name_in_sap', 'ilike', self)]"/>
                <field name="period_type_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('is_active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Period Action -->
    <record id="action_myschool_period" model="ir.actions.act_window">
        <field name="name">Periodes</field>
        <field name="res_model">myschool.period</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuwe periode aan
            </p>
        </field>
    </record>
</odoo>