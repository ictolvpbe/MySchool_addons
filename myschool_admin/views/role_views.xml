<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- ===================================================================== -->
    <!-- Role Views                                                            -->
    <!-- ===================================================================== -->
    
    <!-- Res Groups selection list for role form -->
    <record id="view_res_groups_list_for_role" model="ir.ui.view">
        <field name="name">res.groups.list.for.role</field>
        <field name="model">res.groups</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Odoo Groups">
                <field name="module_category_name" string="Module"/>
                <field name="name" string="Rol"/>
            </list>
        </field>
    </record>

    <!-- Role Form View -->
    <record id="view_role_form" model="ir.ui.view">
        <field name="name">myschool.role.form</field>
        <field name="model">myschool.role</field>
        <field name="arch" type="xml">
            <form string="Role">
                <header/>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger"
                            invisible="is_active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="label" placeholder="Display Name (e.g. Medewerker)"/>
                        </h1>
                        <h3>
                            <field name="name" placeholder="System Name (e.g. EMPLOYEE)"/>
                        </h3>
                        <h4>
                            <field name="shortname" placeholder="Short Name (Code)"/>
                        </h4>
                    </div>
                    
                    <group>
                        <group string="Classification">
                            <field name="role_type_id" 
                                   options="{'no_create': False, 'no_create_edit': False}"/>
                            <field name="priority"/>
                        </group>
                        <group string="Status">
                            <field name="is_active" widget="boolean_toggle"/>
                            <field name="automatic_sync" widget="boolean_toggle"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Access Settings">
                            <field name="has_ui_access"/>
                            <field name="has_accounts"/>
                            <field name="has_group"/>
                        </group>
                        <group string="Legacy">
                            <field name="old_id"/>
                        </group>
                    </group>

                    <group string="Odoo Groepen" name="odoo_groups">
                        <group>
                            <field name="has_odoo_group" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <button name="action_sync_group_members"
                                    type="object"
                                    string="Sync Groepsleden"
                                    class="btn-primary"
                                    icon="fa-refresh"
                                    invisible="not has_odoo_group"/>
                            <button name="action_sync_persongroup_members"
                                    type="object"
                                    string="Sync Persongroups"
                                    class="btn-secondary"
                                    icon="fa-refresh"
                                    invisible="not has_group"/>
                        </group>
                    </group>
                    <group invisible="not has_odoo_group">
                        <field name="odoo_group_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"
                               domain="[('privilege_id.category_id.name', 'in', ['Professionalisering', 'Activiteiten', 'Drukwerk', 'Planner'])]"
                               context="{'tree_view_ref': 'myschool_admin.view_res_groups_list_for_role'}"
                               nolabel="1" colspan="2"/>
                        <field name="odoo_group_display" nolabel="1" colspan="2" readonly="1"
                               invisible="not odoo_group_ids"/>
                    </group>

                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe this role and its permissions..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- Role List View -->
    <record id="view_role_list" model="ir.ui.view">
        <field name="name">myschool.role.list</field>
        <field name="model">myschool.role</field>
        <field name="arch" type="xml">
            <list string="Roles" multi_edit="1"
                  decoration-muted="not is_active"
                  default_order="priority desc, name">
                <field name="label" optional="show"/>
                <field name="name"/>
                <field name="shortname" widget="badge"/>
                <field name="role_type_id" widget="badge" optional="show"
                       decoration-info="role_type_id.name == 'EMPLOYEE'"
                       decoration-success="role_type_id.name == 'STUDENT'"
                       decoration-warning="role_type_id.name == 'GUARDIAN'"/>
                <field name="priority" optional="show"/>
                <field name="has_ui_access" widget="boolean" optional="show"/>
                <field name="has_group" widget="boolean" optional="hide"/>
                <field name="has_accounts" widget="boolean" optional="hide"/>
                <field name="automatic_sync" widget="boolean_toggle" optional="hide"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>
    
    <!-- Role Search View -->
    <record id="view_role_search" model="ir.ui.view">
        <field name="name">myschool.role.search</field>
        <field name="model">myschool.role</field>
        <field name="arch" type="xml">
            <search string="Search Roles">
                <field name="name"/>
                <field name="label"/>
                <field name="shortname"/>
                <field name="role_type_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('is_active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter string="Has UI Access" name="ui_access" domain="[('has_ui_access', '=', True)]"/>
                <filter string="Has Group" name="has_group" domain="[('has_group', '=', True)]"/>
                <filter string="Has Accounts" name="has_accounts" domain="[('has_accounts', '=', True)]"/>
                <separator/>
                <filter string="Auto Sync" name="auto_sync" domain="[('automatic_sync', '=', True)]"/>
<!--                <group expand="0" string="Group By">-->
<!--                    <filter string="Role Type" name="group_role_type" context="{'group_by': 'role_type_id'}"/>-->
<!--                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>-->
<!--                </group>-->
            </search>
        </field>
    </record>
    
    <!-- Role Action -->
    <record id="action_myschool_role" model="ir.actions.act_window">
        <field name="name">Roles</field>
        <field name="res_model">myschool.role</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_role_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Role
            </p>
            <p>
                Roles define permissions and access levels for persons in the system.
                Examples: EMPLOYEE, STUDENT, TEACHER, GUARDIAN.
            </p>
        </field>
    </record>
    
    <!-- Role for selection in other forms (minimal view) -->
    <record id="view_role_list_select" model="ir.ui.view">
        <field name="name">myschool.role.list.select</field>
        <field name="model">myschool.role</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <list string="Select Role">
                <field name="label"/>
                <field name="name"/>
                <field name="shortname"/>
                <field name="role_type_id"/>
            </list>
        </field>
    </record>
    
</odoo>
