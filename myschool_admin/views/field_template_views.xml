<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_field_template_list" model="ir.ui.view">
        <field name="name">myschool.field.template.list</field>
        <field name="model">myschool.field.template</field>
        <field name="arch" type="xml">
            <list string="Field Templates"
                  decoration-muted="not active">
                <field name="priority"/>
                <field name="name"/>
                <field name="field_name"/>
                <field name="template"/>
                <field name="org_ids" widget="many2many_tags" optional="show"/>
                <field name="person_type_ids" widget="many2many_tags" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_field_template_form" model="ir.ui.view">
        <field name="name">myschool.field.template.form</field>
        <field name="model">myschool.field.template</field>
        <field name="arch" type="xml">
            <form string="Field Template">
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. CN basisschool studenten"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="field_name"/>
                            <field name="priority"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="org_ids" widget="many2many_tags"
                                   options="{'no_create_edit': True}"
                                   placeholder="All schools"/>
                            <field name="person_type_ids" widget="many2many_tags"
                                   options="{'no_create_edit': True}"
                                   placeholder="All person types"/>
                        </group>
                    </group>
                    <group>
                        <field name="template" placeholder="'t'&amp;&lt;sap_ref&gt;+1631"/>
                        <field name="note" placeholder="Optional notes for fellow admins"/>
                    </group>
                    <separator string="Preview"/>
                    <group>
                        <group>
                            <field name="preview_person_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="preview_org_id"
                                   options="{'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="preview_output" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <p class="mb-1"><b>Template syntaxis</b> — segmenten gescheiden door <code>&amp;</code>:
                            <code>'literal'</code>, <code>&lt;field&gt;</code>, <code>&lt;org.field&gt;</code>,
                            <code>&lt;school.field&gt;</code>, <code>&lt;field&gt;+N</code>/<code>-N</code>,
                            <code>&lt;field&gt;:filter</code>.</p>
                        <p class="mb-0"><b>Filters</b>:
                            <code>lower</code>, <code>upper</code>, <code>slug</code>,
                            <code>nodiacritics</code>, <code>trunc(N)</code>, <code>last(C)</code>.</p>
                        <p class="mb-0 mt-1">
                            <small>
                            Voorbeelden:
                            <code>'t'&amp;&lt;sap_ref&gt;+1631</code> ⇒ <code>t1700</code> (sap_ref=69) ·
                            <code>&lt;first_name&gt;:slug&amp;'.'&amp;&lt;name&gt;:slug&amp;'@'&amp;&lt;school.domain_external&gt;</code>
                            </small>
                        </p>
                        <p class="mb-0 mt-1">
                            <small>
                            <b>Verwijzen naar een ander template-veld</b>: gebruik
                            de naam zoals een gewoon veld, bv. in een
                            <code>email_cloud</code>-template:
                            <code>&lt;cn&gt;&amp;'@'&amp;&lt;school.domain_external&gt;</code>.
                            De evaluator zoekt automatisch het bijpassende
                            <code>cn</code>-template (via Schools / Person types
                            / priority) en zet het resultaat in.
                            </small>
                        </p>
                    </div>
                    <separator string="Beschikbare velden"/>
                    <field name="available_fields_html" nolabel="1" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_field_template_search" model="ir.ui.view">
        <field name="name">myschool.field.template.search</field>
        <field name="model">myschool.field.template</field>
        <field name="arch" type="xml">
            <search string="Search Field Templates">
                <field name="name"/>
                <field name="template"/>
                <field name="field_name"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
                <separator/>
                <filter name="cn" string="CN" domain="[('field_name','=','cn')]"/>
                <filter name="email_cloud" string="Email Cloud"
                        domain="[('field_name','=','email_cloud')]"/>
                <filter name="last_name" string="Last Name"
                        domain="[('field_name','=','last_name')]"/>
                <separator/>
                <filter name="group_by_field" string="Field"
                        context="{'group_by': 'field_name'}"/>
            </search>
        </field>
    </record>

    <record id="action_field_template" model="ir.actions.act_window">
        <field name="name">Field Templates</field>
        <field name="res_model">myschool.field.template</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_field_template_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure templates for computed person-fields.
            </p>
            <p>
                A field template lets you describe how a value (cn, email_cloud, …)
                is composed from person- and org-attributes. Use it to keep account
                naming conventions out of the code and configurable per school.
            </p>
        </field>
    </record>

</odoo>
