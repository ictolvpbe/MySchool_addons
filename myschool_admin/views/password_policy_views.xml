<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Policy
         ============================================================ -->

    <record id="view_myschool_password_policy_list" model="ir.ui.view">
        <field name="name">myschool.password.policy.list</field>
        <field name="model">myschool.password.policy</field>
        <field name="arch" type="xml">
            <list decoration-muted="not is_active"
                  decoration-success="is_system_default">
                <field name="name"/>
                <field name="description" optional="show"/>
                <field name="rule_count" string="# regels"/>
                <field name="school_count" string="# scholen"/>
                <field name="is_system_default" widget="boolean" string="Systeemdefault"/>
                <field name="is_active" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="view_myschool_password_policy_form" model="ir.ui.view">
        <field name="name">myschool.password.policy.form</field>
        <field name="model">myschool.password.policy</field>
        <field name="arch" type="xml">
            <form string="Wachtwoordbeleid">
                <sheet>
                    <widget name="web_ribbon" title="Inactief"
                            bg_color="text-bg-secondary" invisible="is_active"/>
                    <widget name="web_ribbon" title="Systeemdefault"
                            bg_color="text-bg-success" invisible="not is_system_default"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="bv. Standaard 2026"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="is_active" widget="boolean_toggle"/>
                            <field name="is_system_default"
                                   help="Het systeem valt op dit beleid terug als een school geen eigen beleid heeft."/>
                        </group>
                        <group>
                            <field name="rule_count" readonly="1"/>
                            <field name="school_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Omschrijving">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page name="rules" string="Regels">
                            <p class="text-muted">
                                Regels worden in volgorde geëvalueerd; de eerste match wint.
                                Een regel zonder filters (alle filters leeg) matcht álles —
                                gebruik daarvoor de <strong>default-regel</strong> als vangregel.
                            </p>
                            <field name="rule_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="person_type_ids" widget="many2many_tags" optional="show"/>
                                    <field name="role_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="min_age" optional="show"/>
                                    <field name="max_age" optional="show"/>
                                    <field name="mode"/>
                                    <field name="template_id" optional="show"
                                           column_invisible="parent.id == False"/>
                                    <field name="wordlist_id" optional="show"
                                           column_invisible="parent.id == False"/>
                                    <field name="is_default_rule" widget="boolean" string="Default"/>
                                </list>
                                <form string="Regel">
                                    <sheet>
                                        <div class="oe_title">
                                            <h2><field name="name" placeholder="bv. STUDENT 12+"/></h2>
                                        </div>
                                        <group>
                                            <group string="Volgorde &amp; vangregel">
                                                <field name="sequence"/>
                                                <field name="is_default_rule"
                                                       help="Vangregel: gebruikt wanneer geen andere regel matcht."/>
                                            </group>
                                            <group string="Modus">
                                                <field name="mode" widget="radio"/>
                                            </group>
                                        </group>
                                        <group string="Match-criteria (leeg = match-alles)">
                                            <field name="person_type_ids" widget="many2many_tags"/>
                                            <field name="role_ids" widget="many2many_tags"/>
                                            <group>
                                                <field name="min_age"/>
                                                <field name="max_age"/>
                                            </group>
                                        </group>
                                        <group string="Generatie via template" invisible="mode != 'generated'">
                                            <field name="template_id"
                                                   options="{'no_create': False}"
                                                   help="Selecteer een herbruikbaar template uit Instellingen → Wachtwoordbeleid → Templates."/>
                                            <div class="text-muted" colspan="2"
                                                 invisible="template_id">
                                                <em>Geen template gekozen → de inline-instellingen hieronder worden gebruikt (legacy).</em>
                                            </div>
                                        </group>
                                        <group string="Inline-instellingen (legacy fallback)"
                                               invisible="mode != 'generated' or template_id">
                                            <group>
                                                <field name="gen_length"/>
                                                <field name="gen_lowercase"/>
                                                <field name="gen_uppercase"/>
                                            </group>
                                            <group>
                                                <field name="gen_digits"/>
                                                <field name="gen_specials"/>
                                                <field name="gen_specials_chars"/>
                                            </group>
                                        </group>
                                        <group string="Woordenlijst" invisible="mode != 'wordlist'">
                                            <field name="wordlist_id"
                                                   options="{'no_create': True}"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page name="schools" string="Gekoppelde scholen">
                            <field name="school_ids" nolabel="1" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="org_type_id"/>
                                </list>
                            </field>
                            <p class="text-muted">
                                Koppel een school via het school-formulier (veld "Wachtwoordbeleid").
                            </p>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_myschool_password_policy" model="ir.actions.act_window">
        <field name="name">Wachtwoordbeleid</field>
        <field name="res_model">myschool.password.policy</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Maak een nieuw wachtwoordbeleid aan
            </p>
            <p>
                Een beleid bundelt regels die per persoon-type, rol en leeftijd
                bepalen of een wachtwoord gegenereerd wordt (complex) of uit
                een woordenlijst gekozen wordt (jongere leerlingen).
            </p>
        </field>
    </record>

    <!-- ============================================================
         School-form uitbreiding: password_policy_id
         ============================================================ -->

    <record id="view_myschool_org_form_password_policy" model="ir.ui.view">
        <field name="name">myschool.org.form.password.policy</field>
        <field name="model">myschool.org</field>
        <field name="inherit_id" ref="myschool_admin.view_myschool_org_form"/>
        <field name="arch" type="xml">
            <!-- Probeer eerst inside the security/config notebook page;
                 fallback achteraan de sheet als die page niet bestaat. -->
            <xpath expr="//sheet" position="inside">
                <group string="Wachtwoordbeleid"
                       invisible="not org_type_id or context.get('hide_password_policy')">
                    <field name="password_policy_id"
                           options="{'no_create_edit': True}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
