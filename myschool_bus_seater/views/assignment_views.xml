<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <!-- Assignment Form View -->
    <record id="view_assignment_form" model="ir.ui.view">
        <field name="name">bus_seater.assignment.form</field>
        <field name="model">bus_seater.assignment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="bus_id"/>
                            <field name="seat_id"/>
                            <field name="seat_number"/>
                        </group>
                        <group>
                            <field name="person_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Assignment List View -->
    <record id="view_assignment_list" model="ir.ui.view">
        <field name="name">bus_seater.assignment.list</field>
        <field name="model">bus_seater.assignment</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="bus_id"/>
                <field name="person_id"/>
                <field name="seat_number"/>
                <field name="seat_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Assignment Search View -->
    <record id="view_assignment_search" model="ir.ui.view">
        <field name="name">bus_seater.assignment.search</field>
        <field name="model">bus_seater.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="person_id"/>
                <field name="bus_id"/>
                <filter name="group_bus" string="Bus" context="{'group_by': 'bus_id'}"/>
            </search>
        </field>
    </record>

    <!-- Assignment Action -->
    <record id="action_assignment" model="ir.actions.act_window">
        <field name="name">Toewijzingen</field>
        <field name="res_model">bus_seater.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

</data></odoo>
