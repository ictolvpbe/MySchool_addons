<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <!-- Route Form View -->
    <record id="view_route_form" model="ir.ui.view">
        <field name="name">bus_seater.route.form</field>
        <field name="model">bus_seater.route</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Route Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="bus_id"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="stop_count"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Notes..."/>
                    <notebook>
                        <page string="Stops" name="stops">
                            <field name="stop_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="address"/>
                                    <field name="arrival_time" widget="float_time"/>
                                    <field name="departure_time" widget="float_time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Route List View -->
    <record id="view_route_list" model="ir.ui.view">
        <field name="name">bus_seater.route.list</field>
        <field name="model">bus_seater.route</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="bus_id"/>
                <field name="stop_count" string="Stops"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <!-- Route Search View -->
    <record id="view_route_search" model="ir.ui.view">
        <field name="name">bus_seater.route.search</field>
        <field name="model">bus_seater.route</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="bus_id"/>
                <filter name="active" string="Active" domain="[('is_active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('is_active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Route Action -->
    <record id="action_route" model="ir.actions.act_window">
        <field name="name">Routes</field>
        <field name="res_model">bus_seater.route</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</data></odoo>
