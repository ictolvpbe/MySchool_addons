<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="0">

    <record id="privilege_bus_seater" model="res.groups.privilege">
        <field name="name">Bus Seater</field>
    </record>

    <record id="group_bus_seater_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_bus_seater"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bus_seater_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_bus_seater"/>
        <field name="implied_ids" eval="[(4, ref('group_bus_seater_user'))]"/>
    </record>

</data></odoo>
