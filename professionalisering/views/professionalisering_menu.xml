<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Main action (no search_default — Python injects defaults per role) -->
    <record id="action_professionalisering_main" model="ir.actions.act_window">
        <field name="name">Aanvragen</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Action: My Requests (no search_default — Python injects per role) -->
    <record id="action_professionalisering_my" model="ir.actions.act_window">
        <field name="name">Aanvragen</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Action: To Approve (Directie) -->
    <record id="action_professionalisering_approve" model="ir.actions.act_window">
        <field name="name">Te Beoordelen</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_to_approve': 1}</field>
    </record>

    <!-- Action: Payments (Boekhouding) -->
    <record id="action_professionalisering_payments" model="ir.actions.act_window">
        <field name="name">Betalingen</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_payment_pending': 1}</field>
    </record>

    <!-- Action: Replacements (Vervangingen) -->
    <record id="action_professionalisering_replacements" model="ir.actions.act_window">
        <field name="name">Vervangingen</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_replacement_pending': 1}</field>
    </record>

    <!-- Action: All Requests -->
    <record id="action_professionalisering_all" model="ir.actions.act_window">
        <field name="name">Alle Aanvragen</field>
        <field name="res_model">professionalisering.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Action: My Invitations -->
    <record id="action_professionalisering_invites" model="ir.actions.act_window">
        <field name="name">Mijn Uitnodigingen</field>
        <field name="res_model">professionalisering.invite</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_professionalisering_root"
              name="Professionalisering"
              action="action_professionalisering_main"
              sequence="55"/>

    <!-- Submenus -->
    <menuitem id="menu_professionalisering_approve"
              name="Te Beoordelen"
              parent="menu_professionalisering_root"
              action="action_professionalisering_approve"
              groups="professionalisering.group_professionalisering_directie"
              sequence="10"/>

    <menuitem id="menu_professionalisering_payments"
              name="Betalingen"
              parent="menu_professionalisering_root"
              action="action_professionalisering_payments"
              groups="professionalisering.group_professionalisering_boekhouding"
              sequence="20"/>

    <menuitem id="menu_professionalisering_replacements"
              name="Vervangingen"
              parent="menu_professionalisering_root"
              action="action_professionalisering_replacements"
              groups="professionalisering.group_professionalisering_vervangingen"
              sequence="30"/>

    <menuitem id="menu_professionalisering_all"
              name="Alle Aanvragen"
              parent="menu_professionalisering_root"
              action="action_professionalisering_all"
              groups="professionalisering.group_professionalisering_admin"
              sequence="40"/>

    <menuitem id="menu_professionalisering_my"
              name="Mijn Aanvragen"
              parent="menu_professionalisering_root"
              action="action_professionalisering_my"
              sequence="50"/>

    <menuitem id="menu_professionalisering_invites"
              name="Mijn Uitnodigingen"
              parent="menu_professionalisering_root"
              action="action_professionalisering_invites"
              sequence="60"/>
</odoo>
