<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_professionalisering" model="ir.module.category">
        <field name="name">Professionalisering</field>
        <field name="sequence">55</field>
    </record>

    <record id="privilege_professionalisering" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_professionalisering"/>
        <field name="sequence">10</field>
    </record>

    <!-- Personeelslid (was: Medewerker) -->
    <record id="group_professionalisering_user" model="res.groups">
        <field name="name">Personeelslid</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Drukwerk -->
    <record id="group_professionalisering_drukwerk" model="res.groups">
        <field name="name">Drukwerk</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Aankoop -->
    <record id="group_professionalisering_aankoop" model="res.groups">
        <field name="name">Aankoop</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Boekhouding -->
    <record id="group_professionalisering_boekhouding" model="res.groups">
        <field name="name">Boekhouding</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">40</field>
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Vervangingen -->
    <record id="group_professionalisering_vervangingen" model="res.groups">
        <field name="name">Vervangingen</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">50</field>
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Directie -->
    <record id="group_professionalisering_directie" model="res.groups">
        <field name="name">Directie</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">60</field>
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Beheerder -->
    <record id="group_professionalisering_admin" model="res.groups">
        <field name="name">Beheerder</field>
        <field name="privilege_id" ref="privilege_professionalisering"/>
        <field name="sequence">70</field>
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_directie'))]"/>
    </record>

    <!-- EMPLOYEE role gets base professionalisering access -->
    <record id="myschool_core.group_myschool_employee" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Combined roles → per-module groups -->
    <record id="myschool_core.group_combined_boekhouding" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_boekhouding'))]"/>
    </record>
    <record id="myschool_core.group_combined_vervangingen" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_vervangingen'))]"/>
    </record>
    <record id="myschool_core.group_combined_directie" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_directie'))]"/>
    </record>
    <record id="myschool_core.group_combined_beheerder" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_professionalisering_admin'))]"/>
    </record>
</odoo>
