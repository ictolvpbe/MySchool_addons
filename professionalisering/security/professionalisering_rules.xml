<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        School filtering logic using school_company_id + child_of:
        - In a specific school (e.g. SO, company_id=4): child_of [4] = only company 4
        - In OLVP (parent, company_id=1): child_of [1] = companies 1,3,4,5 = all schools
        - Users with only 1 school: they can only switch to that school or OLVP
          so child_of always gives the right result
    -->

    <!-- Medewerker: own records + invited, filtered by active company school -->
    <record id="rule_professionalisering_school_filter" model="ir.rule">
        <field name="name">Professionalisering: medewerker ziet eigen aanvragen van actieve school</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['&amp;', '|', ('employee_id.user_id', '=', user.id), ('invite_ids.employee_id.user_id', '=', user.id), '|', ('school_company_id', 'child_of', [company_id]), ('school_company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Directie -->
    <record id="rule_professionalisering_directie_all" model="ir.rule">
        <field name="name">Professionalisering: directie ziet actieve school</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('school_company_id', 'child_of', [company_id]), ('school_company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_directie'))]"/>
    </record>

    <!-- Boekhouding -->
    <record id="rule_professionalisering_boekhouding_school" model="ir.rule">
        <field name="name">Professionalisering: boekhouding ziet actieve school</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('school_company_id', 'child_of', [company_id]), ('school_company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_boekhouding'))]"/>
    </record>

    <!-- Vervangingen -->
    <record id="rule_professionalisering_vervangingen_school" model="ir.rule">
        <field name="name">Professionalisering: vervangingen ziet actieve school</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('school_company_id', 'child_of', [company_id]), ('school_company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_vervangingen'))]"/>
    </record>

    <!-- Beheerder -->
    <record id="rule_professionalisering_admin_all" model="ir.rule">
        <field name="name">Professionalisering: beheerder ziet actieve school</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('school_company_id', 'child_of', [company_id]), ('school_company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_admin'))]"/>
    </record>
</odoo>
