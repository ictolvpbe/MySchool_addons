<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Medewerker: own records + invited records, filtered by current company's school -->
    <record id="rule_professionalisering_school_filter" model="ir.rule">
        <field name="name">Professionalisering: medewerker ziet eigen aanvragen van huidige school</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('invite_ids.employee_id.user_id', '=', user.id)] + ([('school_id', 'in', [user.company_id.school_id.id, False])] if user.company_id.school_id else [(1, '=', 1)])</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_user'))]"/>
    </record>

    <!-- Directie: current company's school (all records if no school on company) -->
    <record id="rule_professionalisering_directie_all" model="ir.rule">
        <field name="name">Professionalisering: directie ziet school van huidig bedrijf</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">[('school_id', 'in', [user.company_id.school_id.id, False])] if user.company_id.school_id else [(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_directie'))]"/>
    </record>

    <!-- Boekhouding: current company's school + invited records -->
    <record id="rule_professionalisering_boekhouding_school" model="ir.rule">
        <field name="name">Professionalisering: boekhouding ziet school van huidig bedrijf en uitnodigingen</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('invite_ids.employee_id.user_id', '=', user.id)] + ([('school_id', 'in', [user.company_id.school_id.id, False])] if user.company_id.school_id else [(1, '=', 1)])</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_boekhouding'))]"/>
    </record>

    <!-- Vervangingen: current company's school + invited records -->
    <record id="rule_professionalisering_vervangingen_school" model="ir.rule">
        <field name="name">Professionalisering: vervangingen ziet school van huidig bedrijf en uitnodigingen</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">['|', ('invite_ids.employee_id.user_id', '=', user.id)] + ([('school_id', 'in', [user.company_id.school_id.id, False])] if user.company_id.school_id else [(1, '=', 1)])</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_vervangingen'))]"/>
    </record>

    <!-- Beheerder: see all records -->
    <record id="rule_professionalisering_admin_all" model="ir.rule">
        <field name="name">Professionalisering: beheerder ziet alles</field>
        <field name="model_id" ref="model_professionalisering_record"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_professionalisering_admin'))]"/>
    </record>
</odoo>
