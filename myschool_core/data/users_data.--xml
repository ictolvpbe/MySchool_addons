            <field name="password">olvpolvp</field>
            <field name="groups_id" eval="[
                (4, ref('base.group_user')),
                (4, ref('group_myschool_teacher')),
            ]"/>
        </record>

        <!-- 3) ict — ICT -->
        <record id="user_ict" model="res.users">
            <field name="name">ICT</field>
            <field name="login">ict</field>
            <field name="password">olvpolvp</field>
            <field name="groups_id" eval="[
                (4, ref('base.group_user')),
                (4, ref('group_myschool_ict')),
            ]"/>
        </record>

        <!-- 4) boekhouding.so — ACCOUNTING -->
        <record id="user_boekhouding_so" model="res.users">
            <field name="name">Boekhouding SO</field>
            <field name="login">boekhouding.so</field>
