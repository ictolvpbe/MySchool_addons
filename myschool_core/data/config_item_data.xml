<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ci_employee_account_deactivation_days" model="myschool.config.item">
            <field name="name">EmployeeAccountDeactivationDays</field>
            <field name="scope">global</field>
            <field name="type">config</field>
            <field name="integer_value">30</field>
            <field name="description">Aantal dagen na wegvallen assignments voordat het account gedeactiveerd wordt</field>
        </record>

        <record id="ci_employee_account_removal_days" model="myschool.config.item">
            <field name="name">EmployeeAccountRemovalDays</field>
            <field name="scope">global</field>
            <field name="type">config</field>
            <field name="integer_value">90</field>
            <field name="description">Aantal dagen na wegvallen assignments voordat het account verwijderd wordt</field>
        </record>

    </data>
</odoo>
