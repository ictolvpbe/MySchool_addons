<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            ChromeOS inventory sync — pulls every Chromebook in the
            Workspace tenant nightly and links them to myschool.asset
            rows by serialNumber. Idempotent; safe to run more often.

            Disabled by default (active=False). Admins activate it
            once a Workspace config exists and at least one asset has
            its serial_number filled in. Activating prematurely means
            the cron runs but only logs unmatched devices.
        -->
        <record forcecreate="True" id="ir_cron_sync_chromeos_inventory" model="ir.cron">
            <field name="name">Cloud: Sync ChromeOS Inventory</field>
            <field name="model_id" ref="model_myschool_betask_processor"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_chromeos_inventory()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
