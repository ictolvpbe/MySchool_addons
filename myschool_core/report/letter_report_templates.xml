<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Generic QWeb wrapper used by every myschool.letter.template
        record. The wrapper:
          • takes ``docs`` (= a recordset of letter templates, length 1)
          • reads the data dict for ``target_model`` + ``target_record_id``
          • re-resolves the target record at render time and calls the
            template's ``render_html`` so the same Jinja substitution
            machinery is used for preview *and* production paths.

        ``t-out`` (rather than ``t-raw``) is used because Odoo 19's
        QWeb engine handles HTML escaping automatically; passing a
        Markup-wrapped string keeps the rendered HTML intact.
    -->
    <template id="report_letter_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="template">
                <t t-set="target_model" t-value="data and data.get('target_model')"/>
                <t t-set="target_record_id" t-value="data and data.get('target_record_id')"/>
                <t t-set="record" t-value="
                    env[target_model].browse(target_record_id)
                    if target_model and target_record_id else None"/>
                <t t-set="rendered_body" t-value="
                    template.render_html(record) if record else ''"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <t t-out="rendered_body"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!--
        ir.actions.report record bound to the wrapper above.

        report_name: the QWeb view's full xmlid that the report engine
        renders. report_type 'qweb-pdf' means: render to HTML then run
        wkhtmltopdf. Records are passed as letter-template ids; the
        actual record-of-interest comes via ``data`` because templates
        and rendered records are different models.
    -->
    <record id="action_report_letter_template" model="ir.actions.report">
        <field name="name">Letter</field>
        <field name="model">myschool.letter.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">myschool_core.report_letter_document</field>
        <field name="report_file">myschool_core.report_letter_document</field>
        <field name="binding_model_id" eval="False"/>
        <field name="print_report_name">'Letter - %s' % object.code</field>
    </record>

</odoo>
