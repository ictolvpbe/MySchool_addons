<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_users_form_school_ids" model="ir.ui.view">
        <field name="name">res.users.form.school_ids</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="Scholen">
                    <field name="school_ids" widget="many2many_tags"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
