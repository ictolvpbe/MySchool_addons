<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Form view -->
    <record id="view_smartschool_config_form" model="ir.ui.view">
        <field name="name">myschool.smartschool.config.form</field>
        <field name="model">myschool.smartschool.config</field>
        <field name="arch" type="xml">
            <form string="Smartschool Configuration">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_discover_api"
                            string="Discover API"
                            type="object"
                            class="btn-secondary"
                            help="List SOAP operations + error-code table. Useful when an unknown error code surfaces during a saveUser/setAccountStatus/... call."/>
                    <field name="last_test_result"
                           widget="badge"
                           decoration-success="last_test_result == 'success'"
                           decoration-danger="last_test_result == 'failed'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_organizations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-building">
                            <field name="org_count" widget="statinfo" string="Orgs"/>
                        </button>
                    </div>
                    <widget name="web_ribbon"
                            title="Archived"
                            bg_color="bg-danger"
                            invisible="active"/>
                    <widget name="web_ribbon"
                            title="DRY RUN"
                            bg_color="bg-warning"
                            invisible="not dry_run or not active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. BAWA Smartschool"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Platform">
                            <field name="platform_url"
                                   placeholder="https://bawa.smartschool.be"/>
                            <field name="api_key"
                                   password="True"
                                   groups="base.group_system"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Defaults">
                            <field name="default_role_teacher"/>
                            <field name="force_password_reset"/>
                            <field name="dry_run"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Organizations" name="orgs">
                            <field name="org_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Last Test" name="test">
                            <group string="Connection">
                                <field name="last_test_date" readonly="1"/>
                                <field name="last_test_result" readonly="1"/>
                                <field name="last_test_message" readonly="1"/>
                            </group>
                        </page>
                        <page string="API Discovery" name="discovery">
                            <group>
                                <field name="last_discovery_at" readonly="1"/>
                            </group>
                            <field name="last_discovery_report"
                                   readonly="1" widget="text" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="view_smartschool_config_list" model="ir.ui.view">
        <field name="name">myschool.smartschool.config.list</field>
        <field name="model">myschool.smartschool.config</field>
        <field name="arch" type="xml">
            <list string="Smartschool Configurations">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="platform_url"/>
                <field name="org_count"/>
                <field name="last_test_result" widget="badge"
                       decoration-success="last_test_result == 'success'"
                       decoration-danger="last_test_result == 'failed'"/>
                <field name="last_test_date"/>
                <field name="dry_run" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_smartschool_config_search" model="ir.ui.view">
        <field name="name">myschool.smartschool.config.search</field>
        <field name="model">myschool.smartschool.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="platform_url"/>
                <filter string="Active"
                        name="active"
                        domain="[('active', '=', True)]"/>
                <filter string="Archived"
                        name="inactive"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Test OK"
                        name="test_ok"
                        domain="[('last_test_result', '=', 'success')]"/>
                <filter string="Test failed"
                        name="test_failed"
                        domain="[('last_test_result', '=', 'failed')]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_smartschool_config" model="ir.actions.act_window">
        <field name="name">Smartschool</field>
        <field name="res_model">myschool.smartschool.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_smartschool_config_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
