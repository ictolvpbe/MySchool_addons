<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="h5p_learning_path_view_list" model="ir.ui.view">
        <field name="name">h5p.learning.path.list</field>
        <field name="model">h5p.learning.path</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="content_count"/>
                <field name="is_published" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="h5p_learning_path_view_form" model="ir.ui.view">
        <field name="name">h5p.learning.path.form</field>
        <field name="model">h5p.learning.path</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Learning Path Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="is_published"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="content_type"/>
                                    <field name="h5p_file" filename="h5p_filename"/>
                                    <field name="h5p_filename" column_invisible="True"/>
                                    <field name="result_count" string="Results"/>
                                    <field name="avg_score" string="Avg %"/>
                                    <button name="action_preview" type="object"
                                        string="Play" icon="fa-play-circle"
                                        class="btn btn-link"
                                        invisible="not h5p_file"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="h5p_learning_path_action" model="ir.actions.act_window">
        <field name="name">Learning Paths</field>
        <field name="res_model">h5p.learning.path</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
