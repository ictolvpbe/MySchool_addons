<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="h5p_result_view_list" model="ir.ui.view">
        <field name="name">h5p.result.list</field>
        <field name="model">h5p.result</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="attempt_date"/>
                <field name="content_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="score"/>
                <field name="max_score"/>
                <field name="score_percent" widget="progressbar"/>
                <field name="completion"/>
                <field name="duration"/>
                <field name="xapi_verb"/>
            </list>
        </field>
    </record>

    <record id="h5p_result_view_form" model="ir.ui.view">
        <field name="name">h5p.result.form</field>
        <field name="model">h5p.result</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="content_id"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="attempt_date"/>
                        </group>
                        <group>
                            <field name="score"/>
                            <field name="max_score"/>
                            <field name="score_percent"/>
                            <field name="completion"/>
                            <field name="duration"/>
                            <field name="xapi_verb"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw xAPI Data" name="xapi">
                            <field name="xapi_data"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="h5p_result_view_search" model="ir.ui.view">
        <field name="name">h5p.result.search</field>
        <field name="model">h5p.result</field>
        <field name="arch" type="xml">
            <search>
                <field name="content_id"/>
                <field name="user_id"/>
                <filter string="Completed" name="completed"
                    domain="[('completion', '=', True)]"/>
                <separator/>
                <filter string="Content" name="group_content"
                    context="{'group_by': 'content_id'}"/>
                <filter string="Learner" name="group_user"
                    context="{'group_by': 'user_id'}"/>
            </search>
        </field>
    </record>

    <record id="h5p_result_action" model="ir.actions.act_window">
        <field name="name">Results</field>
        <field name="res_model">h5p.result</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
