<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_extra_klas_wizard_form" model="ir.ui.view">
        <field name="name">drukwerk.extra.klas.wizard.form</field>
        <field name="model">drukwerk.extra.klas.wizard</field>
        <field name="arch" type="xml">
            <form string="Andere klas toevoegen">
                <field name="drukwerk_id" invisible="1"/>
                <field name="school_id" invisible="1"/>
                <field name="school_klas_ids" invisible="1" widget="many2many_tags"/>
                <div class="alert alert-info mb-3" role="alert">
                    Selecteer hieronder een of meerdere klassen die niet aan jou worden lesgegeven.
                    De klassen worden toegevoegd aan deze drukwerkaanvraag.
                </div>
                <group>
                    <field name="klas_ids"
                           widget="many2many_tags"
                           domain="[('id', 'in', school_klas_ids)]"
                           options="{'no_create': True, 'no_create_edit': True, 'no_open': True}"
                           nolabel="1"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            string="Toevoegen"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuleren" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
