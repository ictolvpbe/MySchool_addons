<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_count_e_export_wizard_form" model="ir.ui.view">
        <field name="name">drukwerk.count.e.export.wizard.form</field>
        <field name="model">drukwerk.count.e.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Count-e">
                <div class="alert alert-info mb-3" role="alert" invisible="csv_file">
                    Selecteer het datumbereik en de school. Enkel records met status
                    <strong>Afgedrukt</strong> (en optioneel <strong>Gestockeerd</strong>) worden
                    geëxporteerd in het Count-e formaat.
                </div>
                <div class="alert alert-success mb-3" role="alert" invisible="not csv_file">
                    Bestand is klaar (<field name="record_count" class="oe_inline"/> regels).
                    Klik op het downloadicoon naast "CSV bestand" om te downloaden.
                </div>
                <div class="alert alert-warning mb-3" role="alert" invisible="not skipped_count">
                    <strong><field name="skipped_count" class="oe_inline"/> leerling(en) overgeslagen</strong>
                    omdat ze geen SAP-referentie hebben (veld "SAP Referentie (pPersoon)" op de leerlingfiche).
                    Vul deze aan en exporteer opnieuw.
                </div>
                <group invisible="not skipped_details" string="Overgeslagen leerlingen">
                    <field name="skipped_details" nolabel="1" readonly="1"/>
                </group>
                <group>
                    <group>
                        <field name="school_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="datum_van"/>
                        <field name="datum_tot"/>
                        <field name="include_gestockeerd"/>
                    </group>
                    <group invisible="not csv_file">
                        <field name="csv_filename" invisible="1"/>
                        <field name="csv_file" filename="csv_filename" readonly="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_export"
                            string="Exporteer"
                            type="object"
                            class="btn-primary"
                            invisible="csv_file"/>
                    <button string="Sluiten" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_count_e_export_wizard" model="ir.actions.act_window">
        <field name="name">Export Count-e</field>
        <field name="res_model">drukwerk.count.e.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
