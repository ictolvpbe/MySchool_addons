<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_drukwerk_config_form" model="ir.ui.view">
        <field name="name">drukwerk.config.form</field>
        <field name="model">drukwerk.config</field>
        <field name="arch" type="xml">
            <form string="Drukwerk Instellingen">
                <sheet>
                    <group>
                        <group string="Prijzen">
                            <field name="prijs_per_pagina"/>
                            <field name="prijs_kleur"/>
                            <field name="prijs_a3"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_drukwerk_config_open" model="ir.actions.server">
        <field name="name">Drukwerk Instellingen</field>
        <field name="model_id" ref="model_drukwerk_config"/>
        <field name="state">code</field>
        <field name="code">
config = env['drukwerk.config']._get_defaults()
action = {
    'type': 'ir.actions.act_window',
    'name': 'Instellingen',
    'res_model': 'drukwerk.config',
    'view_mode': 'form',
    'res_id': config.id,
    'target': 'current',
}
        </field>
    </record>

</odoo>
