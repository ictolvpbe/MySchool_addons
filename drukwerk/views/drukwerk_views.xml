<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_drukwerk_form" model="ir.ui.view">
        <field name="name">drukwerk.record.form</field>
        <field name="model">drukwerk.record</field>
        <field name="arch" type="xml">
            <form class="drukwerk_form">
                <header>
                    <!-- Personeelslid: open submit dialog (popup with extra tabs, then confirm) -->
                    <button name="action_open_details"
                            string="Volgende"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'form_invullen'"/>

                    <!-- Drukwerk team / Admin: wijzigen (reset naar formulier) -->
                    <button name="action_reset_to_form"
                            string="Wijzigen"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'afdrukken'"
                            groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin"/>
                    <!-- Drukwerk team / Admin: verwijderen -->
                    <button name="action_delete"
                            string="Verwijderen"
                            type="object"
                            class="btn-danger"
                            confirm="Weet je zeker dat je deze aanvraag wil verwijderen? Dit kan niet ongedaan worden gemaakt."
                            groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin"/>

                    <!-- Drukwerk: print PDF -->
                    <button name="action_download_pdf"
                            string="Afdrukken"
                            type="object"
                            class="btn-secondary"
                            icon="fa-print"
                            groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin"
                            invisible="state != 'afdrukken'"/>
                    <!-- Drukwerk: mark printed -->
                    <button name="action_mark_printed"
                            string="Afgedrukt"
                            type="object"
                            class="btn-primary"
                            groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin"
                            invisible="state != 'afdrukken'"/>

                    <!-- Iedereen met toegang: stockeren vanaf 'Afgerond' -->
                    <button name="action_stockeren"
                            string="Stockeren"
                            type="object"
                            class="btn-secondary"
                            icon="fa-archive"
                            invisible="state != 'done'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="form_invullen,afdrukken,done,gestockeerd"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h3 class="mt-1">
                            <span class="text-muted">
                                Aangemaakt door: <field name="create_uid" readonly="1" class="oe_inline" nolabel="1"/>
                            </span>
                        </h3>
                    </div>

                    <field name="currency_id" invisible="1"/>
                    <field name="available_klas_ids" invisible="1"/>
                    <field name="is_owner" invisible="1"/>
                    <field name="can_select_color" invisible="1"/>
                    <field name="student_ids" invisible="1"/>

                    <group>
                        <group>
                            <field name="drukwerk_type"
                                   widget="radio"
                                   required="1"
                                   readonly="not can_edit_content"/>
                        </group>
                    </group>

                    <!-- Aanvraag details: zichtbaar in concept/formulier én voor de
                         eigenaar in afdrukken-fase (zodat hij/zij nog kan corrigeren) -->
                    <group invisible="not drukwerk_type or (state == 'afdrukken' and not is_owner)">
                        <group string="Aanvraag">
                            <field name="titel"
                                   placeholder="bv. Werkbladen wiskunde H3"
                                   readonly="not can_edit_content"/>
                            <field name="print_deadline"
                                   readonly="not can_edit_content"/>
                            <field name="school_id"
                                   options="{'no_open': True}"
                                   readonly="not can_edit_content"/>
                            <field name="klas_ids" widget="many2many_tags"
                                   readonly="not can_edit_content"/>
                            <label for="student_count" string="Leerlingen"
                                   invisible="not klas_ids"/>
                            <div invisible="not klas_ids">
                                <button name="action_view_students"
                                        type="object"
                                        class="btn-link ps-0"
                                        icon="fa-users">
                                    <field name="student_count" widget="statinfo" nolabel="1"/>
                                </button>
                            </div>
                        </group>
                        <group string="Totalen">
                            <field name="total_pages"/>
                            <field name="total_cost"
                                   invisible="drukwerk_type == 'examen'"/>
                            <field name="cost_per_student"
                                   invisible="drukwerk_type == 'examen'"/>
                        </group>
                    </group>

                    <!-- Document section -->
                    <group string="Document" invisible="not drukwerk_type or (state == 'afdrukken' and not is_owner)">
                        <group>
                            <field name="document_filename" invisible="1"/>
                            <field name="document_file" filename="document_filename"
                                   widget="binary"
                                   options="{'accepted_file_extensions': '.pdf'}"
                                   readonly="not can_edit_content"/>
                            <field name="aantal_paginas" readonly="1"/>
                            <field name="aantal_kopies" readonly="1"/>
                            <field name="kopie_leerkracht"
                                   readonly="not can_edit_content"/>
                        </group>
                        <group>
                            <field name="kleur"
                                   readonly="not can_edit_content or not can_select_color"/>
                            <field name="formaat"
                                   readonly="not can_edit_content"/>
                            <field name="dik_papier"
                                   invisible="drukwerk_type != 'gewoon'"
                                   readonly="not can_edit_content"/>
                        </group>
                    </group>

                    <!-- Volgende-knop onderaan de form (links uitgelijnd) -->
                    <div class="d-flex justify-content-start mt-3 mb-3"
                         invisible="state != 'form_invullen'">
                        <button name="action_open_details"
                                string="Volgende"
                                type="object"
                                class="btn-primary"/>
                    </div>

                    <!-- Extra info knop: opent dialoog (alleen als "Volgende" niet meer zichtbaar is) -->
                    <div class="d-flex justify-content-end mt-3 mb-3"
                         invisible="not drukwerk_type or state in ('form_invullen', 'afdrukken')">
                        <button name="action_open_details"
                                string="Extra info beheren"
                                type="object"
                                class="btn-secondary"
                                icon="fa-edit"/>
                    </div>

                    <!-- Compact summary for afdrukken state — alleen voor niet-eigenaars
                         (eigenaar krijgt de bewerkbare versie hierboven) -->
                    <group invisible="state != 'afdrukken' or is_owner">
                        <group>
                            <field name="titel" readonly="1"/>
                            <field name="student_count" string="Leerlingen"/>
                            <field name="total_pages"/>
                            <field name="print_deadline" readonly="1"/>
                        </group>
                        <group>
                            <field name="document_filename" invisible="1"/>
                            <field name="document_file" filename="document_filename"
                                   widget="binary" readonly="1"/>
                            <field name="aantal_paginas" readonly="1"/>
                            <field name="aantal_kopies" readonly="1"/>
                            <field name="kleur" readonly="1"/>
                            <field name="formaat" readonly="1"/>
                            <field name="dik_papier" readonly="1"
                                   invisible="drukwerk_type != 'gewoon'"/>
                        </group>
                    </group>

                    <!-- Print options for afdrukken state — drukwerk team kan alles bewerken -->
                    <group string="Printerinstellingen"
                           invisible="state != 'afdrukken'"
                           groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin">
                        <group>
                            <field name="printer_code" readonly="1"/>
                            <field name="kleur"/>
                            <field name="formaat"/>
                            <field name="dik_papier"
                                   invisible="drukwerk_type != 'gewoon'"/>
                            <field name="dubbelzijdig"/>
                            <field name="nieten"/>
                            <field name="perforeren"/>
                            <field name="liggend" readonly="1"
                                   help="Automatisch gedetecteerd uit de PDF"/>
                        </group>
                        <group>
                            <field name="sorteren"/>
                            <field name="a3_plooien"/>
                            <field name="boekje_a4"/>
                            <field name="papier_kleur"/>
                            <field name="gekleurd_papier"
                                   invisible="papier_kleur == 'geen'"/>
                        </group>
                    </group>

                    <!-- Toelichting visible for drukwerk/admin in afdrukken state (read-only) -->
                    <group string="Toelichting"
                           invisible="state != 'afdrukken'"
                           groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin">
                        <field name="description" nolabel="1"
                               readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Dialog Form View: Extra info (Afdrukopties + Toelichting) -->
    <record id="view_drukwerk_form_details" model="ir.ui.view">
        <field name="name">drukwerk.record.form.details</field>
        <field name="model">drukwerk.record</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Extra info" class="o_drukwerk_wizard_form">
                <field name="state" invisible="1"/>
                <field name="drukwerk_type" invisible="1"/>
                <notebook>
                    <page string="Afdrukopties" name="details_afdrukopties">
                        <group>
                            <group>
                                <field name="dubbelzijdig"
                                       readonly="not can_edit_content"/>
                                <field name="nieten"
                                       readonly="not can_edit_content"/>
                                <field name="perforeren"
                                       readonly="not can_edit_content"/>
                                <field name="liggend" readonly="1"
                                       help="Automatisch gedetecteerd uit de PDF"/>
                                <field name="sorteren"
                                       readonly="not can_edit_content"/>
                            </group>
                            <group>
                                <field name="a3_plooien"
                                       readonly="not can_edit_content"/>
                                <field name="boekje_a4"
                                       readonly="not can_edit_content"/>
                                <field name="papier_kleur"
                                       readonly="not can_edit_content"/>
                                <field name="gekleurd_papier"
                                       invisible="papier_kleur == 'geen'"
                                       readonly="not can_edit_content"/>
                            </group>
                        </group>
                    </page>
                    <page string="Toelichting" name="details_toelichting">
                        <field name="description" nolabel="1"
                               placeholder="Eventuele extra informatie voor de drukkerij..."
                               readonly="state not in ('draft', 'form_invullen')"/>
                    </page>
                </notebook>
                <footer>
                    <button name="action_submit_from_dialog"
                            string="Indienen &amp; bevestigen"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'form_invullen'"/>
                    <button string="Opslaan"
                            class="btn-primary"
                            special="save"
                            invisible="state == 'form_invullen'"/>
                    <button string="Annuleren" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_drukwerk_list" model="ir.ui.view">
        <field name="name">drukwerk.record.list</field>
        <field name="model">drukwerk.record</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_stockeren"
                            type="object"
                            string="Stockeren"
                            icon="fa-archive"
                            display="always"/>
                </header>
                <field name="name"/>
                <field name="create_date" string="Aanvraagdatum" optional="show"/>
                <field name="create_uid" string="Aangemaakt door"/>
                <field name="drukwerk_type"/>
                <field name="titel"/>
                <field name="print_deadline" optional="show"/>
                <field name="school_id" optional="show"/>
                <field name="klas_ids" widget="many2many_tags" optional="show"/>
                <field name="student_count" string="Leerlingen"/>
                <field name="total_pages" string="Pagina's"/>
                <field name="total_cost" string="Kost"/>
                <field name="cost_per_student" string="Kost / leerling" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('form_invullen', 'afdrukken')"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'gestockeerd'"
                />
                <button name="action_download_pdf"
                        string="Afdrukken"
                        type="object"
                        icon="fa-print"
                        class="btn-primary"
                        groups="drukwerk.group_drukwerk_drukwerk,drukwerk.group_drukwerk_admin"
                        invisible="state != 'afdrukken'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_drukwerk_search" model="ir.ui.view">
        <field name="name">drukwerk.record.search</field>
        <field name="model">drukwerk.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="titel"/>
                <field name="name"/>
                <filter string="Mijn aanvragen" name="my_requests"
                        domain="[('create_uid', '=', uid)]"/>
                <separator/>
                <filter string="Concept" name="state_form_invullen"
                        domain="[('state', 'in', ('draft', 'form_invullen'))]"/>
                <filter string="Af te drukken" name="to_print"
                        domain="[('state', '=', 'afdrukken')]"/>
                <filter string="Afgedrukt" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Gestockeerd" name="state_gestockeerd"
                        domain="[('state', '=', 'gestockeerd')]"/>
                <filter string="Niet gestockeerd" name="not_gestockeerd"
                        domain="[('state', '!=', 'gestockeerd')]"/>
                <separator/>
                <filter string="Gewoon drukwerk" name="gewoon"
                        domain="[('drukwerk_type', '=', 'gewoon')]"/>
                <filter string="Examen drukwerk" name="examen"
                        domain="[('drukwerk_type', '=', 'examen')]"/>
                <group>
                    <filter string="Status" name="group_state"
                            domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="School" name="group_school"
                            domain="[]" context="{'group_by': 'school_id'}"/>
                    <filter string="Klas" name="group_klas"
                            domain="[]" context="{'group_by': 'klas_ids'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
