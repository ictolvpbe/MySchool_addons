<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_drukwerk" model="ir.actions.act_window">
        <field name="name">Drukwerk</field>
        <field name="res_model">drukwerk.record</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <!-- Boekhouding: overzicht per klas, gesorteerd op datum -->
    <record id="action_drukwerk_boekhouding_overzicht" model="ir.actions.act_window">
        <field name="name">Overzicht per klas</field>
        <field name="res_model">drukwerk.record</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_drukwerk_search"/>
        <field name="domain">[('drukwerk_type', '=', 'gewoon'), ('state', '=', 'done')]</field>
        <field name="context">{'search_default_group_klas': 1}</field>
    </record>

    <menuitem id="menu_drukwerk_root"
              name="Drukwerk"
              sequence="75"/>

    <menuitem id="menu_drukwerk_aanvragen"
              name="Aanvragen"
              parent="menu_drukwerk_root"
              action="action_drukwerk"
              sequence="10"/>

    <menuitem id="menu_drukwerk_boekhouding_overzicht"
              name="Overzicht per klas"
              parent="menu_drukwerk_root"
              action="action_drukwerk_boekhouding_overzicht"
              groups="drukwerk.group_drukwerk_boekhouding,drukwerk.group_drukwerk_admin"
              sequence="15"/>

    <menuitem id="menu_drukwerk_instellingen"
              name="Prijsinstellingen"
              parent="menu_drukwerk_root"
              action="action_drukwerk_config_open"
              sequence="20"/>
</odoo>
