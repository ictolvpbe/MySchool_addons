<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_drukwerk_print_deadline_reminder" model="ir.cron">
            <field name="name">Drukwerk: herinnering drukdatum</field>
            <field name="model_id" ref="model_drukwerk_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_print_deadline_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="cron_drukwerk_auto_stock" model="ir.cron">
            <field name="name">Drukwerk: automatisch stockeren na X dagen</field>
            <field name="model_id" ref="model_drukwerk_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Default threshold: 30 dagen. Aanpasbaar via Instellingen → Technisch
             → Parameters → Systeemparameters (key: drukwerk.auto_stock_after_days). -->
        <record id="config_drukwerk_auto_stock_days" model="ir.config_parameter">
            <field name="key">drukwerk.auto_stock_after_days</field>
            <field name="value">30</field>
        </record>
    </data>
</odoo>
