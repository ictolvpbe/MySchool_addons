<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_drukwerk" model="ir.module.category">
        <field name="name">Drukwerk</field>
        <field name="sequence">70</field>
    </record>

    <record id="privilege_drukwerk" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_drukwerk"/>
        <field name="sequence">10</field>
    </record>

    <!-- Personeelslid -->
    <record id="group_drukwerk_personeelslid" model="res.groups">
        <field name="name">Personeelslid</field>
        <field name="privilege_id" ref="privilege_drukwerk"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('myschool_core.group_myschool_core_user'))]"/>
    </record>

    <!-- Drukwerk -->
    <record id="group_drukwerk_drukwerk" model="res.groups">
        <field name="name">Drukwerk</field>
        <field name="privilege_id" ref="privilege_drukwerk"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_drukwerk_personeelslid'))]"/>
    </record>

    <!-- Boekhouding -->
    <record id="group_drukwerk_boekhouding" model="res.groups">
        <field name="name">Boekhouding</field>
        <field name="privilege_id" ref="privilege_drukwerk"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('group_drukwerk_personeelslid'))]"/>
    </record>

    <!-- Beheerder (Admin) -->
    <record id="group_drukwerk_admin" model="res.groups">
        <field name="name">Beheerder</field>
        <field name="privilege_id" ref="privilege_drukwerk"/>
        <field name="sequence">40</field>
        <field name="implied_ids" eval="[
            (4, ref('group_drukwerk_drukwerk')),
            (4, ref('group_drukwerk_boekhouding')),
        ]"/>
    </record>

    <!-- MySchool admin gets drukwerk admin -->
    <record id="myschool_core.group_myschool_core_admin" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_drukwerk_admin'))]"/>
    </record>
</odoo>
