<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- A&I User Group - Read access -->
        <record id="group_ai_user" model="res.groups">
            <field name="name">A&amp;I User</field>
            <field name="implied_ids" eval="[(4, ref('myschool_core.group_myschool_core_user'))]"/>
            <field name="comment">Read access to Asset &amp; Inventory models, filtered by access policies.</field>
        </record>

        <!-- A&I Manager Group - Read & Write access -->
        <record id="group_ai_manager" model="res.groups">
            <field name="name">A&amp;I Manager</field>
            <field name="implied_ids" eval="[(4, ref('myschool_assets.group_ai_user'))]"/>
            <field name="comment">Read and write access to Asset &amp; Inventory models, filtered by access policies.</field>
        </record>

        <!-- A&I Admin Group - Full access -->
        <record id="group_ai_admin" model="res.groups">
            <field name="name">A&amp;I Admin</field>
            <field name="implied_ids" eval="[(4, ref('myschool_assets.group_ai_manager'))]"/>
            <field name="comment">Full access to all Asset &amp; Inventory models and configuration.</field>
        </record>

        <!-- ============================================================ -->
        <!-- Record Rules                                                 -->
        <!-- ============================================================ -->

        <!-- Admin: full access to all assets -->
        <record id="ai_asset_admin_rule" model="ir.rule">
            <field name="name">A&amp;I Asset: Admin Full Access</field>
            <field name="model_id" ref="myschool_core.model_myschool_asset"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_admin'))]"/>
        </record>

        <!-- User: read access based on access policies -->
        <record id="ai_asset_user_read_rule" model="ir.rule">
            <field name="name">A&amp;I Asset: Policy-based Read Access</field>
            <field name="model_id" ref="myschool_core.model_myschool_asset"/>
            <field name="domain_force">[('allowed_group_read_ids', 'in', user.all_group_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('group_ai_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: write access based on access policies -->
        <record id="ai_asset_manager_write_rule" model="ir.rule">
            <field name="name">A&amp;I Asset: Policy-based Write Access</field>
            <field name="model_id" ref="myschool_core.model_myschool_asset"/>
            <field name="domain_force">[('allowed_group_write_ids', 'in', user.all_group_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('group_ai_manager'))]"/>
        </record>

    </data>
</odoo>
