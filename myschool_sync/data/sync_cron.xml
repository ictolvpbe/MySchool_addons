<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Weekly cleanup of old sync logs -->
    <record id="ir_cron_cleanup_sync_logs" model="ir.cron">
        <field name="name">Sync: Cleanup Old Logs</field>
        <field name="model_id" ref="model_sync_log"/>
        <field name="state">code</field>
        <field name="code">model.cleanup_old_logs(days=90)</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="priority">8</field>
    </record>

</odoo>
