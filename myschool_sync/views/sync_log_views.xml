<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ======================== -->
    <!-- sync.log FORM VIEW       -->
    <!-- ======================== -->
    <record id="view_sync_log_form" model="ir.ui.view">
        <field name="name">sync.log.form</field>
        <field name="model">sync.log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_name"/>
                            <field name="record_natural_key"/>
                            <field name="action" widget="badge"
                                   decoration-success="action in ('create', 'update', 'skip')"
                                   decoration-danger="action == 'error'"/>
                        </group>
                        <group>
                            <field name="direction" widget="badge"/>
                            <field name="sync_target_id"/>
                            <field name="success"/>
                            <field name="betask_id"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Payload">
                        <field name="payload" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ======================== -->
    <!-- sync.log LIST VIEW       -->
    <!-- ======================== -->
    <record id="view_sync_log_list" model="ir.ui.view">
        <field name="name">sync.log.list</field>
        <field name="model">sync.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" decoration-danger="action == 'error'"
                  decoration-muted="action == 'skip'">
                <field name="name"/>
                <field name="create_date" string="Date"/>
                <field name="model_name"/>
                <field name="record_natural_key"/>
                <field name="action" widget="badge"
                       decoration-success="action in ('create', 'update')"
                       decoration-info="action == 'skip'"
                       decoration-danger="action == 'error'"/>
                <field name="direction" widget="badge"/>
                <field name="sync_target_id"/>
                <field name="success"/>
            </list>
        </field>
    </record>

    <!-- ======================== -->
    <!-- sync.log SEARCH VIEW     -->
    <!-- ======================== -->
    <record id="view_sync_log_search" model="ir.ui.view">
        <field name="name">sync.log.search</field>
        <field name="model">sync.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_name"/>
                <field name="record_natural_key"/>
                <field name="sync_target_id"/>
                <filter name="errors" string="Errors" domain="[('action', '=', 'error')]"/>
                <filter name="inbound" string="Inbound" domain="[('direction', '=', 'inbound')]"/>
                <filter name="outbound" string="Outbound" domain="[('direction', '=', 'outbound')]"/>
                <separator/>
                <filter name="group_model" string="Model" context="{'group_by': 'model_name'}"/>
                <filter name="group_action" string="Action" context="{'group_by': 'action'}"/>
                <filter name="group_target" string="Target" context="{'group_by': 'sync_target_id'}"/>
            </search>
        </field>
    </record>

    <!-- ======================== -->
    <!-- sync.log ACTION          -->
    <!-- ======================== -->
    <record id="action_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">sync.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sync_log_search"/>
    </record>

</odoo>
