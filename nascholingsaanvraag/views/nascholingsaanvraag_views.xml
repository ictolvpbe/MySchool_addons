<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_nascholingsaanvraag_form" model="ir.ui.view">
        <field name="name">nascholingsaanvraag.record.form</field>
        <field name="model">nascholingsaanvraag.record</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Employee: Submit -->
                    <button name="action_submit"
                            string="Indienen"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <!-- Employee: Reset to draft after rejection -->
                    <button name="action_reset_draft"
                            string="Opnieuw indienen"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'rejected'"/>
                    <!-- Directie: Approve -->
                    <button name="action_approve"
                            string="Goedkeuren"
                            type="object"
                            class="btn-primary"
                            groups="nascholingsaanvraag.group_nascholingsaanvraag_directie"
                            invisible="state != 'submitted'"/>
                    <!-- Directie: Reject -->
                    <button name="action_reject"
                            string="Afkeuren"
                            type="object"
                            class="btn-danger"
                            groups="nascholingsaanvraag.group_nascholingsaanvraag_directie"
                            invisible="state != 'submitted'"/>
                    <!-- Boekhouding: Confirm payment -->
                    <button name="action_confirm_payment"
                            string="Betaling bevestigd"
                            type="object"
                            class="btn-primary"
                            groups="nascholingsaanvraag.group_nascholingsaanvraag_boekhouding"
                            invisible="state != 'approved' or payment_done == True"/>
                    <!-- Vervangingen: Confirm replacement -->
                    <button name="action_confirm_replacement"
                            string="Vervanging ingepland"
                            type="object"
                            class="btn-primary"
                            groups="nascholingsaanvraag.group_nascholingsaanvraag_vervangingen"
                            invisible="state != 'approved' or replacement_done == True"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="titel" readonly="state != 'draft'"/>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="verschillende_dagen" readonly="state != 'draft'"/>
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="state != 'draft'" invisible="verschillende_dagen == True"/>
                            <field name="cost" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="directie_id" invisible="state not in ('approved', 'rejected', 'done')"/>
                            <field name="payment_done" readonly="1" invisible="state not in ('approved', 'done')"/>
                            <field name="replacement_done" readonly="1" invisible="state not in ('approved', 'done')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Datums" invisible="verschillende_dagen != True">
                            <field name="date_line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="cost"/>
                                </list>
                            </field>
                        </page>
                        <page string="Beschrijving">
                            <field name="description" readonly="state != 'draft'"/>
                        </page>
                        <page string="Afkeuring" invisible="state not in ('submitted', 'rejected')">
                            <group>
                                <field name="rejection_reason"
                                       readonly="state != 'submitted'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_nascholingsaanvraag_list" model="ir.ui.view">
        <field name="name">nascholingsaanvraag.record.list</field>
        <field name="model">nascholingsaanvraag.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="titel"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="cost"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state in ('approved', 'done')" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_nascholingsaanvraag_search" model="ir.ui.view">
        <field name="name">nascholingsaanvraag.record.search</field>
        <field name="model">nascholingsaanvraag.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="titel"/>
                <field name="employee_id"/>
                <field name="name"/>
                <filter string="Mijn aanvragen" name="my_requests" domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Te beoordelen" name="to_approve" domain="[('state', '=', 'submitted')]"/>
                <filter string="Betaling openstaand" name="payment_pending" domain="[('state', '=', 'approved'), ('payment_done', '=', False)]"/>
                <filter string="Vervanging openstaand" name="replacement_pending" domain="[('state', '=', 'approved'), ('replacement_done', '=', False)]"/>
                <separator/>
                <filter string="Concept" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Ingediend" name="state_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Goedgekeurd" name="state_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Afgekeurd" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Afgerond" name="state_done" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Status" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Medewerker" name="group_employee" domain="[]" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
