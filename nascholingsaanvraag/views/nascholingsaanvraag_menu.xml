<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action: My Requests -->
    <record id="action_nascholingsaanvraag_my" model="ir.actions.act_window">
        <field name="name">Mijn Aanvragen</field>
        <field name="res_model">nascholingsaanvraag.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <!-- Action: To Approve (Directie) -->
    <record id="action_nascholingsaanvraag_approve" model="ir.actions.act_window">
        <field name="name">Te Beoordelen</field>
        <field name="res_model">nascholingsaanvraag.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'submitted')]</field>
    </record>

    <!-- Action: Payments (Boekhouding) -->
    <record id="action_nascholingsaanvraag_payments" model="ir.actions.act_window">
        <field name="name">Betalingen</field>
        <field name="res_model">nascholingsaanvraag.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'approved'), ('payment_done', '=', False)]</field>
    </record>

    <!-- Action: Replacements (Vervangingen) -->
    <record id="action_nascholingsaanvraag_replacements" model="ir.actions.act_window">
        <field name="name">Vervangingen</field>
        <field name="res_model">nascholingsaanvraag.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'approved'), ('replacement_done', '=', False)]</field>
    </record>

    <!-- Action: All Requests -->
    <record id="action_nascholingsaanvraag_all" model="ir.actions.act_window">
        <field name="name">Alle Aanvragen</field>
        <field name="res_model">nascholingsaanvraag.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_nascholingsaanvraag_root"
              name="Nascholingsaanvraag"
              sequence="50"/>

    <!-- Submenus -->
    <menuitem id="menu_nascholingsaanvraag_my"
              name="Mijn Aanvragen"
              parent="menu_nascholingsaanvraag_root"
              action="action_nascholingsaanvraag_my"
              sequence="10"/>

    <menuitem id="menu_nascholingsaanvraag_approve"
              name="Te Beoordelen"
              parent="menu_nascholingsaanvraag_root"
              action="action_nascholingsaanvraag_approve"
              groups="nascholingsaanvraag.group_nascholingsaanvraag_directie"
              sequence="20"/>

    <menuitem id="menu_nascholingsaanvraag_payments"
              name="Betalingen"
              parent="menu_nascholingsaanvraag_root"
              action="action_nascholingsaanvraag_payments"
              groups="nascholingsaanvraag.group_nascholingsaanvraag_boekhouding"
              sequence="30"/>

    <menuitem id="menu_nascholingsaanvraag_replacements"
              name="Vervangingen"
              parent="menu_nascholingsaanvraag_root"
              action="action_nascholingsaanvraag_replacements"
              groups="nascholingsaanvraag.group_nascholingsaanvraag_vervangingen"
              sequence="40"/>

    <menuitem id="menu_nascholingsaanvraag_all"
              name="Alle Aanvragen"
              parent="menu_nascholingsaanvraag_root"
              action="action_nascholingsaanvraag_all"
              groups="nascholingsaanvraag.group_nascholingsaanvraag_admin"
              sequence="50"/>
</odoo>
