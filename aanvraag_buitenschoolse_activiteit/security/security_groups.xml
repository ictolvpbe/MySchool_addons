<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_buitenschoolse_activiteit" model="ir.module.category">
        <field name="name">Buitenschoolse Activiteit</field>
        <field name="sequence">55</field>
    </record>

    <record id="privilege_buitenschoolse_activiteit" model="res.groups.privilege">
        <field name="name">Rol</field>
        <field name="placeholder">Geen toegang</field>
        <field name="category_id" ref="module_category_buitenschoolse_activiteit"/>
        <field name="sequence">10</field>
    </record>

    <!-- Hierarchical groups: Medewerker -> Directie -> Beheerder -->
    <record id="group_buitenschoolse_activiteit_user" model="res.groups">
        <field name="name">Medewerker</field>
        <field name="privilege_id" ref="privilege_buitenschoolse_activiteit"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_buitenschoolse_activiteit_directie" model="res.groups">
        <field name="name">Directie</field>
        <field name="privilege_id" ref="privilege_buitenschoolse_activiteit"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_buitenschoolse_activiteit_user'))]"/>
    </record>

    <record id="group_buitenschoolse_activiteit_admin" model="res.groups">
        <field name="name">Beheerder</field>
        <field name="privilege_id" ref="privilege_buitenschoolse_activiteit"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('group_buitenschoolse_activiteit_directie'))]"/>
    </record>

    <!-- Independent group: Boekhouding -->
    <record id="group_buitenschoolse_activiteit_boekhouding" model="res.groups">
        <field name="name">Buitenschoolse Activiteit - Boekhouding</field>
        <field name="implied_ids" eval="[(4, ref('group_buitenschoolse_activiteit_user'))]"/>
    </record>
</odoo>
