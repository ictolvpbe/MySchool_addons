<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Medewerker: only see own records -->
    <record id="rule_buitenschoolse_activiteit_school_filter" model="ir.rule">
        <field name="name">Buitenschoolse Activiteit: medewerker ziet eigen aanvragen</field>
        <field name="model_id" ref="model_aanvraag_buitenschoolse_activiteit_record"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_buitenschoolse_activiteit_user'))]"/>
    </record>

    <!-- Directie: see all records -->
    <record id="rule_buitenschoolse_activiteit_directie_all" model="ir.rule">
        <field name="name">Buitenschoolse Activiteit: directie ziet alles</field>
        <field name="model_id" ref="model_aanvraag_buitenschoolse_activiteit_record"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_buitenschoolse_activiteit_directie'))]"/>
    </record>

    <!-- Boekhouding: see records from their school(s) -->
    <record id="rule_buitenschoolse_activiteit_boekhouding_school" model="ir.rule">
        <field name="name">Buitenschoolse Activiteit: boekhouding ziet eigen school</field>
        <field name="model_id" ref="model_aanvraag_buitenschoolse_activiteit_record"/>
        <field name="domain_force">[('school_id', 'in', user.school_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_buitenschoolse_activiteit_boekhouding'))]"/>
    </record>

    <!-- Vervangingen: see records from their school(s) -->
    <record id="rule_buitenschoolse_activiteit_vervangingen_school" model="ir.rule">
        <field name="name">Buitenschoolse Activiteit: vervangingen ziet eigen school</field>
        <field name="model_id" ref="model_aanvraag_buitenschoolse_activiteit_record"/>
        <field name="domain_force">[('school_id', 'in', user.school_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_buitenschoolse_activiteit_vervangingen'))]"/>
    </record>

    <!-- Beheerder: see all records -->
    <record id="rule_buitenschoolse_activiteit_admin_all" model="ir.rule">
        <field name="name">Buitenschoolse Activiteit: beheerder ziet alles</field>
        <field name="model_id" ref="model_aanvraag_buitenschoolse_activiteit_record"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_buitenschoolse_activiteit_admin'))]"/>
    </record>
</odoo>
