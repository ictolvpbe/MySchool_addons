<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action: My Requests -->
    <record id="action_buitenschoolse_activiteit_my" model="ir.actions.act_window">
        <field name="name">Mijn Aanvragen</field>
        <field name="res_model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <!-- Action: To Approve (Directie) -->
    <record id="action_buitenschoolse_activiteit_approve" model="ir.actions.act_window">
        <field name="name">Te Beoordelen</field>
        <field name="res_model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'submitted')]</field>
    </record>

    <!-- Action: Payments (Boekhouding) -->
    <record id="action_buitenschoolse_activiteit_payments" model="ir.actions.act_window">
        <field name="name">Betalingen</field>
        <field name="res_model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'approved'), ('payment_done', '=', False)]</field>
    </record>

    <!-- Action: Replacements (Vervangingen) -->
    <record id="action_buitenschoolse_activiteit_replacements" model="ir.actions.act_window">
        <field name="name">Vervangingen</field>
        <field name="res_model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'approved'), ('replacement_done', '=', False)]</field>
    </record>

    <!-- Action: All Requests -->
    <record id="action_buitenschoolse_activiteit_all" model="ir.actions.act_window">
        <field name="name">Alle Aanvragen</field>
        <field name="res_model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_buitenschoolse_activiteit_root"
              name="Buitenschoolse Activiteit"
              sequence="55"/>

    <!-- Submenus -->
    <menuitem id="menu_buitenschoolse_activiteit_my"
              name="Mijn Aanvragen"
              parent="menu_buitenschoolse_activiteit_root"
              action="action_buitenschoolse_activiteit_my"
              sequence="10"/>

    <menuitem id="menu_buitenschoolse_activiteit_approve"
              name="Te Beoordelen"
              parent="menu_buitenschoolse_activiteit_root"
              action="action_buitenschoolse_activiteit_approve"
              groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"
              sequence="20"/>

    <menuitem id="menu_buitenschoolse_activiteit_payments"
              name="Betalingen"
              parent="menu_buitenschoolse_activiteit_root"
              action="action_buitenschoolse_activiteit_payments"
              groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_boekhouding"
              sequence="30"/>

    <menuitem id="menu_buitenschoolse_activiteit_replacements"
              name="Vervangingen"
              parent="menu_buitenschoolse_activiteit_root"
              action="action_buitenschoolse_activiteit_replacements"
              groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_vervangingen"
              sequence="35"/>

    <menuitem id="menu_buitenschoolse_activiteit_all"
              name="Alle Aanvragen"
              parent="menu_buitenschoolse_activiteit_root"
              action="action_buitenschoolse_activiteit_all"
              groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_admin"
              sequence="40"/>
</odoo>
