<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_buitenschoolse_activiteit_form" model="ir.ui.view">
        <field name="name">aanvraag_buitenschoolse_activiteit.record.form</field>
        <field name="model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="is_owner" invisible="1"/>
                    <button name="action_submit"
                            string="Indienen"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft"
                            string="Opnieuw indienen"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'rejected' or not is_owner"/>
                    <button name="action_approve"
                            string="Goedkeuren"
                            type="object"
                            class="btn-primary"
                            groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject"
                            string="Afkeuren"
                            type="object"
                            class="btn-danger"
                            groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"
                            invisible="state != 'submitted'"/>
                    <button name="action_confirm_reservatie"
                            string="Reservatie bevestigd"
                            type="object"
                            class="btn-primary"
                            groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"
                            invisible="state != 'approved' or reservatie_done == True"/>
                    <button name="action_confirm_payment"
                            string="Betaling bevestigd"
                            type="object"
                            class="btn-primary"
                            groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_boekhouding"
                            invisible="state != 'approved' or payment_done == True"/>
                    <button name="action_confirm_replacement"
                            string="Vervanging ingepland"
                            type="object"
                            class="btn-primary"
                            groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_vervangingen"
                            invisible="state != 'approved' or replacement_done == True"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <field name="priority" widget="priority"
                           groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"/>
                    <group>
                        <group>
                            <field name="titel" readonly="state != 'draft'"/>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="school_id" readonly="state != 'draft'"/>
                            <field name="bestemming" readonly="state != 'draft'"/>
                            <field name="datum" readonly="state != 'draft'"/>
                            <field name="aantal_leerlingen" readonly="state != 'draft'"/>
                            <field name="cost" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="assigned_to"
                                   invisible="state == 'draft'"
                                   readonly="state not in ('submitted', 'approved')"
                                   groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"/>
                            <field name="directie_id" invisible="state not in ('approved', 'rejected', 'done')"/>
                            <field name="reservatie_done" readonly="1" invisible="state not in ('approved', 'done')"/>
                            <field name="payment_done" readonly="1" invisible="state not in ('approved', 'done')"/>
                            <field name="replacement_id"
                                   invisible="state not in ('approved', 'done')"
                                   readonly="replacement_done == True"/>
                            <field name="replacement_done" readonly="1" invisible="state not in ('approved', 'done')"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Beschrijving">
                            <field name="description" readonly="state != 'draft'"/>
                        </page>
                        <page string="Afkeuring" invisible="state not in ('submitted', 'rejected')">
                            <group>
                                <field name="rejection_reason"
                                       readonly="state != 'submitted'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_buitenschoolse_activiteit_list" model="ir.ui.view">
        <field name="name">aanvraag_buitenschoolse_activiteit.record.list</field>
        <field name="model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="priority" widget="priority" optional="show"
                       groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"/>
                <field name="titel"/>
                <field name="employee_id"/>
                <field name="school_id"/>
                <field name="bestemming"/>
                <field name="datum_display"/>
                <field name="aantal_leerlingen"/>
                <field name="cost"/>
                <field name="assigned_to" optional="show"
                       groups="aanvraag_buitenschoolse_activiteit.group_buitenschoolse_activiteit_directie"/>
                <field name="replacement_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state in ('approved', 'done')"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_buitenschoolse_activiteit_search" model="ir.ui.view">
        <field name="name">aanvraag_buitenschoolse_activiteit.record.search</field>
        <field name="model">aanvraag_buitenschoolse_activiteit.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="titel"/>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="bestemming"/>
                <field name="assigned_to"/>
                <filter string="Mijn aanvragen" name="my_requests" domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Aan mij toegewezen" name="assigned_to_me" domain="[('assigned_to.user_id', '=', uid)]"/>
                <filter string="Te beoordelen" name="to_approve" domain="[('state', '=', 'submitted')]"/>
                <filter string="Betaling openstaand" name="payment_pending" domain="[('state', '=', 'approved'), ('payment_done', '=', False)]"/>
                <filter string="Vervanging openstaand" name="replacement_pending" domain="[('state', '=', 'approved'), ('replacement_done', '=', False)]"/>
                <separator/>
                <filter string="Concept" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Ingediend" name="state_submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Goedgekeurd" name="state_approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Afgekeurd" name="state_rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Afgerond" name="state_done" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Status" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Medewerker" name="group_employee" domain="[]" context="{'group_by': 'employee_id'}"/>
                    <filter string="School" name="group_school" domain="[]" context="{'group_by': 'school_id'}"/>
                    <filter string="Prioriteit" name="group_priority" domain="[]" context="{'group_by': 'priority'}"/>
                    <filter string="Toegewezen aan" name="group_assigned" domain="[]" context="{'group_by': 'assigned_to'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
