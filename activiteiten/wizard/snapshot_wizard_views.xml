<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_snapshot_wizard_form" model="ir.ui.view">
        <field name="name">activiteiten.snapshot.wizard.form</field>
        <field name="model">activiteiten.snapshot.wizard</field>
        <field name="arch" type="xml">
            <form string="Deelnemers op peildatum">
                <group>
                    <field name="activiteit_id" invisible="1"/>
                    <field name="snapshot_type" invisible="1"/>
                    <field name="peildatum"/>
                    <field name="person_count" string="Aantal"/>
                </group>
                <field name="line_ids" readonly="1">
                    <list>
                        <field name="person_name" string="Naam"/>
                        <field name="date_from" string="Vanaf"/>
                        <field name="date_to" string="Tot"/>
                    </list>
                </field>
                <footer>
                    <button name="action_view_persons"
                            string="Openen als lijst"
                            type="object"
                            class="btn-primary"/>
                    <button string="Sluiten" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
