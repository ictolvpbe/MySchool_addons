<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Personeelslid: own records, filtered by active company school -->
    <record id="rule_activiteiten_personeelslid" model="ir.rule">
        <field name="name">Activiteiten: personeelslid ziet eigen aanvragen van actieve school</field>
        <field name="model_id" ref="model_activiteiten_record"/>
        <field name="domain_force">['&amp;', ('create_uid', '=', user.id), '|', ('school_company_id', 'child_of', [company_id]), ('school_company_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_activiteiten_personeelslid'))]"/>
    </record>

    <!-- Directie -->
    <record id="rule_activiteiten_directie" model="ir.rule">
        <field name="name">Activiteiten: directie ziet actieve school</field>
