<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action: My Requests (Personeelslid) -->
    <record id="action_activiteiten_my" model="ir.actions.act_window">
        <field name="name">Mijn Aanvragen</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <!-- Action: Bus Controle (Aankoop) -->
    <record id="action_activiteiten_bus_check" model="ir.actions.act_window">
        <field name="name">Bus Controle</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'bus_check')]</field>
    </record>

    <!-- Action: Te Beoordelen (Directie) -->
    <record id="action_activiteiten_approve" model="ir.actions.act_window">
        <field name="name">Te Beoordelen</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending_approval')]</field>
    </record>

    <!-- Action: S-Code (Boekhouding) -->
    <record id="action_activiteiten_boekhouding" model="ir.actions.act_window">
        <field name="name">S-Code &amp; Verzekering</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ('approved', 's_code'))]</field>
    </record>

    <!-- Action: Vervangingen -->
    <record id="action_activiteiten_vervangingen" model="ir.actions.act_window">
        <field name="name">Vervangingen</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ('s_code', 'approved')), ('vervanging_done', '=', False)]</field>
    </record>

    <!-- Action: All Requests (Admin) -->
    <record id="action_activiteiten_all" model="ir.actions.act_window">
        <field name="name">Alle Aanvragen</field>
        <field name="res_model">activiteiten.record</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root Menu -->
    <menuitem id="menu_activiteiten_root"
              name="Activiteiten"
              sequence="60"/>

    <!-- Submenus -->
    <menuitem id="menu_activiteiten_my"
              name="Mijn Aanvragen"
              parent="menu_activiteiten_root"
              action="action_activiteiten_my"
              sequence="10"/>

    <menuitem id="menu_activiteiten_bus_check"
              name="Bus Controle"
              parent="menu_activiteiten_root"
              action="action_activiteiten_bus_check"
              groups="activiteiten.group_activiteiten_aankoop"
              sequence="15"/>

    <menuitem id="menu_activiteiten_approve"
              name="Te Beoordelen"
              parent="menu_activiteiten_root"
              action="action_activiteiten_approve"
              groups="activiteiten.group_activiteiten_directie"
              sequence="20"/>

    <menuitem id="menu_activiteiten_boekhouding"
              name="S-Code &amp; Verzekering"
              parent="menu_activiteiten_root"
              action="action_activiteiten_boekhouding"
              groups="activiteiten.group_activiteiten_boekhouding"
              sequence="30"/>

    <menuitem id="menu_activiteiten_vervangingen"
              name="Vervangingen"
              parent="menu_activiteiten_root"
              action="action_activiteiten_vervangingen"
              groups="activiteiten.group_activiteiten_vervangingen"
              sequence="35"/>

    <menuitem id="menu_activiteiten_all"
              name="Alle Aanvragen"
              parent="menu_activiteiten_root"
              action="action_activiteiten_all"
              groups="activiteiten.group_activiteiten_admin"
              sequence="40"/>
</odoo>
