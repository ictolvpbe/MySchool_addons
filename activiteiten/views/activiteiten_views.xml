<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_activiteiten_form" model="ir.ui.view">
        <field name="name">activiteiten.record.form</field>
        <field name="model">activiteiten.record</field>
        <field name="arch" type="xml">
            <form class="o_activiteiten_record_form">
                <header>
                    <!-- Personeelslid: open submit dialog (popup with tabs, then confirm) -->
                    <button name="action_open_details"
                            string="Indienen"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('draft', 'form_invullen', 'bus_refused')"/>

                    <!-- Personeelslid: reset to form after rejection or bus refusal (owner) -->
                    <button name="action_reset_to_form"
                            string="Opnieuw indienen"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ('rejected', 'bus_refused') or not is_owner"/>
                    <!-- Admin: reset to form after rejection or bus refusal (non-owner) -->
                    <button name="action_reset_to_form"
                            string="Opnieuw indienen"
                            type="object"
                            class="btn-secondary"
                            groups="activiteiten.group_activiteiten_admin"
                            invisible="state not in ('rejected', 'bus_refused') or is_owner"/>

                    <!-- Aankoop: bus check -->
                    <button name="action_bus_approved"
                            string="Bus beschikbaar"
                            type="object"
                            class="btn-primary"
                            groups="activiteiten.group_activiteiten_aankoop,activiteiten.group_activiteiten_admin"
                            invisible="state != 'bus_check'"/>
                    <button name="action_bus_refused"
                            string="Bus niet beschikbaar"
                            type="object"
                            class="btn-danger"
                            groups="activiteiten.group_activiteiten_aankoop,activiteiten.group_activiteiten_admin"
                            invisible="state != 'bus_check'"/>

                    <!-- Directie: approve/reject -->
                    <button name="action_approve"
                            string="Goedkeuren"
                            type="object"
                            class="btn-primary"
                            groups="activiteiten.group_activiteiten_directie,activiteiten.group_activiteiten_admin"
                            invisible="state != 'pending_approval'"/>
                    <button name="action_reject"
                            string="Afkeuren"
                            type="object"
                            class="btn-danger"
                            groups="activiteiten.group_activiteiten_directie,activiteiten.group_activiteiten_admin"
                            invisible="state != 'pending_approval'"/>

                    <!-- Boekhouding: S-Code bevestigen -->
                    <button name="action_confirm_s_code"
                            string="S-Code bevestigen"
                            type="object"
                            class="btn-primary"
                            groups="activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_admin"
                            invisible="state != 's_code'"/>



                    <!-- Owner or Admin: delete unsubmitted only -->
                    <field name="is_owner" invisible="1"/>
                    <button name="action_delete"
                            string="Verwijderen"
                            type="object"
                            class="btn-danger"
                            invisible="(not is_owner) or state not in ('draft', 'form_invullen')"
                            confirm="Weet u zeker dat u deze aanvraag wilt verwijderen?"/>
                    <button name="action_delete"
                            string="Verwijderen"
                            type="object"
                            class="btn-danger"
                            groups="activiteiten.group_activiteiten_admin"
                            invisible="is_owner or state not in ('draft', 'form_invullen')"
                            confirm="Weet u zeker dat u deze aanvraag wilt verwijderen?"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,form_invullen,pending_approval,s_code,done"
                           groups="activiteiten.group_activiteiten_directie,activiteiten.group_activiteiten_admin,activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_vervangingen,activiteiten.group_activiteiten_aankoop"/>
                    <field name="display_state" widget="statusbar"
                           statusbar_visible="draft,form_invullen,pending_approval,approved,done"
                           groups="!activiteiten.group_activiteiten_directie,!activiteiten.group_activiteiten_admin,!activiteiten.group_activiteiten_boekhouding,!activiteiten.group_activiteiten_vervangingen,!activiteiten.group_activiteiten_aankoop"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_snapshot_students"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users"
                                invisible="not klas_ids">
                            <field name="student_count" string="Leerlingen" widget="statinfo"/>
                        </button>
                        <button name="action_open_snapshot_leerkrachten"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user"
                                invisible="not leerkracht_ids">
                            <field name="leerkracht_count" string="Leerkrachten" widget="statinfo"/>
                        </button>
                    </div>
                    <!-- Form header: title + subtitle -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h3 class="mt-1">
                            <span class="text-muted">
                                Gemaakt door: <field name="create_uid" readonly="1" class="oe_inline" nolabel="1"/>
                                <span invisible="not titel"> — </span>
                                <field name="titel" readonly="1" class="oe_inline" invisible="not titel"/>
                            </span>
                        </h3>
                    </div>

                    <field name="currency_id" invisible="1"/>
                    <field name="allowed_school_json" invisible="1"/>
                    <field name="available_klas_ids" invisible="1"/>
                    <field name="available_leerkracht_ids" invisible="1"/>

                    <!-- Two-column field grid with group titles -->
                    <group>
                        <!-- LEFT COLUMN: Activiteit + Planning -->
                        <group>
                            <separator string="Activiteit"/>
                            <field name="activity_type"
                                   required="1"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="titel"
                                   placeholder="bv. Schooluitstap naar Technopolis"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="school_id"
                                   options="{'no_open': True}"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="klas_ids" widget="many2many_tags"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="lokaal"
                                   placeholder="bv. A101, Turnzaal, ..."
                                   invisible="activity_type != 'binnenschools'"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="locatie_adres"
                                   placeholder="bv. Technologielaan 1, 2800 Mechelen"
                                   invisible="activity_type != 'buitenschools'"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="bus_nodig"
                                   invisible="activity_type == 'binnenschools'"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>

                            <separator string="Planning"/>
                            <field name="datetime"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                            <field name="datetime_end"
                                   readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                        </group>

                        <!-- RIGHT COLUMN: Bus + Financieel -->
                        <group>
                            <!-- Bus section -->
                            <separator string="Bus"
                                       invisible="not bus_nodig or state in ('draft', 'form_invullen')"/>
                            <field name="bus_price"
                                   placeholder="bv. 250.00"
                                   invisible="not bus_nodig or state in ('draft', 'form_invullen')"
                                   readonly="state != 'bus_check'"
                                   groups="activiteiten.group_activiteiten_aankoop,activiteiten.group_activiteiten_admin"/>
                            <field name="aantal_bussen"
                                   invisible="not bus_nodig or state in ('draft', 'form_invullen')"
                                   readonly="state != 'bus_check'"
                                   groups="activiteiten.group_activiteiten_aankoop,activiteiten.group_activiteiten_admin"/>
                            <field name="bus_available"
                                   invisible="not bus_nodig or state in ('draft', 'form_invullen', 'bus_check')"
                                   readonly="1"/>
                            <button name="action_open_busverdeling"
                                    string="Busverdeling"
                                    type="object"
                                    class="btn-secondary"
                                    icon="fa-bus"
                                    invisible="not bus_nodig or state != 'done'"
                                    groups="activiteiten.group_activiteiten_aankoop,activiteiten.group_activiteiten_admin"/>

                            <!-- Financieel section -->
                            <separator string="Financieel"
                                       invisible="state not in ('s_code', 'vervanging', 'done')"/>
                            <field name="s_code_name"
                                   placeholder="bv. S-1234"
                                   invisible="state not in ('s_code', 'vervanging', 'done')"
                                   readonly="state != 's_code'"
                                   groups="activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_admin"/>
                            <field name="verzekering_done"
                                   readonly="1"
                                   invisible="state not in ('s_code', 'vervanging', 'done')"/>
                        </group>
                    </group>

                    <!-- Extra info knop: opent dialoog (alleen als "Indienen" niet meer zichtbaar is) -->
                    <div class="d-flex justify-content-end mt-3 mb-3"
                         invisible="not activity_type or state in ('draft', 'form_invullen', 'bus_refused')">
                        <button name="action_open_details"
                                string="Extra info beheren"
                                type="object"
                                class="btn-secondary"
                                icon="fa-edit"/>
                    </div>

                    <!-- Afkeuring: zichtbaar voor medewerker na afkeuring -->
                    <div class="alert alert-danger" role="alert"
                         invisible="state != 'rejected'">
                        <strong>Afkeuring:</strong>
                        <field name="rejection_reason" readonly="1" nolabel="1" class="oe_inline"/>
                    </div>

                    <!-- Afkeuring: directie moet reden invullen voor afkeuring -->
                    <group groups="activiteiten.group_activiteiten_directie,activiteiten.group_activiteiten_admin"
                           invisible="state != 'pending_approval'">
                        <field name="rejection_reason"
                               string="Reden voor afkeuring"
                               placeholder="Geef de reden op waarom deze activiteit wordt afgekeurd..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Dialog Form View: Extra info (Begeleiders, Opmerkingen, Kosten, Documenten) -->
    <record id="view_activiteiten_form_details" model="ir.ui.view">
        <field name="name">activiteiten.record.form.details</field>
        <field name="model">activiteiten.record</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Extra info" class="o_activiteiten_wizard_form">
                <field name="activity_type" invisible="1"/>
                <field name="available_leerkracht_ids" invisible="1"/>
                <field name="can_manage_invites" invisible="1"/>
                <field name="state" invisible="1"/>
                <header>
                    <field name="wizard_step" widget="statusbar" options="{'clickable': '0'}"/>
                </header>
                <sheet>
                    <!-- Stap 1: Begeleiders -->
                    <group invisible="wizard_step != '1'">
                        <field name="invite_ids" nolabel="1"
                               readonly="not can_manage_invites or state not in ('draft', 'form_invullen', 'bus_refused', 'approved', 's_code', 'vervanging', 'done')">
                            <list editable="bottom">
                                <field name="person_id"
                                       domain="[('id', 'in', parent.available_leerkracht_ids)]"
                                       options="{'no_quick_create': True, 'no_create': True}"/>
                            </list>
                        </field>
                    </group>
                    <!-- Stap 2: Opmerkingen -->
                    <group invisible="wizard_step != '2'">
                        <field name="description" nolabel="1"
                               placeholder="Geef een korte beschrijving van de activiteit, het doel en eventuele bijzonderheden..."
                               readonly="state not in ('draft', 'form_invullen', 'bus_refused')"/>
                    </group>
                    <!-- Stap 3: Kosten -->
                    <div invisible="wizard_step != '3'">
                        <div class="row">
                            <div class="col-6">
                                <h4 class="mt-4 mb-3">Vaste kosten</h4>
                                <field name="kosten_vast_ids"
                                       context="{'default_kosten_type': 'vast'}"
                                       nolabel="1"
                                       readonly="state not in ('draft', 'form_invullen', 'bus_refused', 's_code', 'vervanging')">
                                    <list editable="bottom" create="1" delete="1">
                                        <field name="is_auto" column_invisible="1"/>
                                        <field name="kosten_type" column_invisible="1"/>
                                        <field name="omschrijving" readonly="is_auto"/>
                                        <field name="bedrag" readonly="is_auto"/>
                                        <field name="currency_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </div>
                            <div class="col-6">
                                <h4 class="mt-4 mb-3">Variabele kosten</h4>
                                <field name="kosten_variabel_ids"
                                       context="{'default_kosten_type': 'variabel'}"
                                       nolabel="1"
                                       readonly="state not in ('draft', 'form_invullen', 'bus_refused', 's_code', 'vervanging', 'done')">
                                    <list editable="bottom" create="1" delete="1">
                                        <field name="is_auto" column_invisible="1"/>
                                        <field name="kosten_type" column_invisible="1"/>
                                        <field name="omschrijving" readonly="is_auto"/>
                                        <field name="bedrag" readonly="is_auto"/>
                                        <field name="currency_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </div>
                        </div>
                        <group class="mt-3">
                            <field name="bijdragen_regeling"
                                   readonly="state not in ('s_code', 'draft', 'form_invullen', 'bus_refused', 'pending_approval')"
                                   groups="activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_admin"/>
                            <field name="totale_kost" readonly="1"/>
                        </group>
                    </div>
                    <!-- Stap 4: Documenten -->
                    <group invisible="wizard_step != '4'">
                        <field name="document_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_wizard_prev"
                            string="Vorige"
                            type="object"
                            class="btn-secondary"
                            invisible="wizard_step == '1'"/>
                    <button name="action_wizard_next"
                            string="Volgende"
                            type="object"
                            class="btn-primary"
                            invisible="wizard_step == '4'"/>
                    <button name="action_submit_from_dialog"
                            string="Indienen &amp; bevestigen"
                            type="object"
                            class="btn-success"
                            invisible="wizard_step != '4' or state not in ('draft', 'form_invullen', 'bus_refused')"/>
                    <button string="Opslaan"
                            class="btn-primary"
                            special="save"
                            invisible="wizard_step != '4' or state in ('draft', 'form_invullen', 'bus_refused')"/>
                    <button string="Annuleren" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_activiteiten_list" model="ir.ui.view">
        <field name="name">activiteiten.record.list</field>
        <field name="model">activiteiten.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="create_uid" string="Aangemaakt door" optional="show"/>
                <field name="titel"/>
                <field name="school_id" optional="show"/>
                <field name="klas_ids" widget="many2many_tags" optional="show"/>
                <field name="activity_type"/>
                <field name="dates_display" widget="html"/>
                <field name="price" optional="hide"/>
                <field name="kosten_display" string="Kosten" widget="html"
                       groups="activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_admin"/>
                <field name="totale_kost" string="Totaal"
                       groups="activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_admin"/>
                <field name="is_active" optional="hide"/>
                <field name="bus_available" optional="hide"/>
                <field name="verzekering_done" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('form_invullen', 'bus_check', 'pending_approval')"
                       decoration-success="state in ('approved', 's_code', 'vervanging', 'done')"
                       decoration-danger="state in ('rejected', 'bus_refused')"
                       groups="activiteiten.group_activiteiten_directie,activiteiten.group_activiteiten_admin,activiteiten.group_activiteiten_boekhouding,activiteiten.group_activiteiten_vervangingen,activiteiten.group_activiteiten_aankoop"/>
                <field name="display_state" widget="badge"
                       decoration-info="display_state == 'draft'"
                       decoration-warning="display_state in ('form_invullen', 'bus_check', 'pending_approval')"
                       decoration-success="display_state in ('approved', 'done')"
                       decoration-danger="display_state in ('rejected', 'bus_refused')"
                       groups="!activiteiten.group_activiteiten_directie,!activiteiten.group_activiteiten_admin,!activiteiten.group_activiteiten_boekhouding,!activiteiten.group_activiteiten_vervangingen,!activiteiten.group_activiteiten_aankoop"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_activiteiten_search" model="ir.ui.view">
        <field name="name">activiteiten.record.search</field>
        <field name="model">activiteiten.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="titel"/>
                <field name="name"/>
                <field name="activity_type"/>
                <filter string="Mijn aanvragen" name="my_requests"
                        domain="[('create_uid', '=', uid)]"/>
                <separator/>
                <filter string="Binnenschools" name="binnenschools"
                        domain="[('activity_type', '=', 'binnenschools')]"/>
                <filter string="Buitenschools" name="buitenschools"
                        domain="[('activity_type', '=', 'buitenschools')]"/>
                <separator/>
                <filter string="Te beoordelen" name="to_approve"
                        domain="[('state', '=', 'pending_approval')]"/>
                <filter string="Bus controle" name="bus_check"
                        domain="[('state', '=', 'bus_check')]"/>
                <filter string="S-Code openstaand" name="s_code_pending"
                        domain="[('state', '=', 's_code')]"/>
                <filter string="Vervanging openstaand" name="replacement_pending"
                        domain="[('state', '=', 'vervanging')]"/>
                <separator/>
                <filter string="Concept" name="state_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Goedgekeurd" name="state_approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Afgekeurd" name="state_rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <filter string="Afgerond" name="state_done"
                        domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Status" name="group_state"
                            domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Type" name="group_type"
                            domain="[]" context="{'group_by': 'activity_type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
