<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Invite Form View (readonly — documentatie) -->
    <record id="view_activiteiten_invite_form" model="ir.ui.view">
        <field name="name">activiteiten.invite.form</field>
        <field name="model">activiteiten.invite</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="activiteit_titel"/>
                            <field name="invited_by"/>
                        </group>
                        <group>
                            <field name="person_id"/>
                            <field name="activiteit_state"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Invite List View (readonly) -->
    <record id="view_activiteiten_invite_list" model="ir.ui.view">
        <field name="name">activiteiten.invite.list</field>
        <field name="model">activiteiten.invite</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="activiteit_titel"/>
                <field name="invited_by"/>
                <field name="activiteit_state" widget="badge"
                       decoration-info="activiteit_state in ('draft', 'form_invullen', 'bus_check', 'pending_approval')"
                       decoration-success="activiteit_state in ('s_code', 'vervanging', 'done')"
                       decoration-danger="activiteit_state in ('rejected', 'bus_refused')"/>
            </list>
        </field>
    </record>
</odoo>
