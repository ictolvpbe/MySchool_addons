<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_activiteiten_config_form" model="ir.ui.view">
        <field name="name">activiteiten.config.form</field>
        <field name="model">activiteiten.config</field>
        <field name="arch" type="xml">
            <form string="Activiteiten Instellingen">
                <sheet>
                    <group>
                        <group string="Verzekering">
                            <field name="verzekering_pct"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_activiteiten_config_open" model="ir.actions.server">
        <field name="name">Instellingen</field>
        <field name="model_id" ref="model_activiteiten_config"/>
        <field name="state">code</field>
        <field name="code">
config = env['activiteiten.config']._get_defaults()
action = {
    'type': 'ir.actions.act_window',
    'name': 'Instellingen',
    'res_model': 'activiteiten.config',
    'view_mode': 'form',
    'res_id': config.id,
    'target': 'current',
    'views': [(False, 'form')],
}
        </field>
    </record>

</odoo>
